+        ),
     ];
     let version_file = config.codex_home.join(VERSION_FILE_NAME);
     push_cached_version_details(&mut details, &version_file);
@@ -129,7 +132,11 @@ fn push_cached_version_details(details: &mut Vec<String>, version_file: &Path) {
     }
 }
 
-fn update_action_label(context: &InstallContext) -> &'static str {
+fn update_action_label(context: &InstallContext, fedora_package: bool) -> &'static str {
+    if fedora_package {
+        return "dnf upgrade codex-cli";
+    }
+
     match &context.method {
         InstallMethod::Npm => "npm install -g @openai/codex",
         InstallMethod::Bun => "bun install -g @openai/codex",
@@ -219,25 +226,30 @@ mod tests {
     #[test]
     fn update_action_labels_install_contexts() {
+        let other = InstallContext {
+            method: InstallMethod::Other,
+            package_layout: None,
+        };
+        assert_eq!(update_action_label(&other, true), "dnf upgrade codex-cli");
         assert_eq!(
-            update_action_label(&InstallContext {
-                method: InstallMethod::Npm,
-                package_layout: None,
-            }),
+            update_action_label(
+                &InstallContext {
+                    method: InstallMethod::Npm,
+                    package_layout: None,
+                },
+                false,
+            ),
             "npm install -g @openai/codex"
         );
         assert_eq!(
-            update_action_label(&InstallContext {
-                method: InstallMethod::Pnpm,
-                package_layout: None,
-            }),
+            update_action_label(
+                &InstallContext {
+                    method: InstallMethod::Pnpm,
+                    package_layout: None,
+                },
+                false,
+            ),
             "pnpm add -g @openai/codex"
         );
-        assert_eq!(
-            update_action_label(&InstallContext {
-                method: InstallMethod::Other,
-                package_layout: None,
-            }),
-            "manual or unknown"
-        );
+        assert_eq!(update_action_label(&other, false), "manual or unknown");
     }
 }
diff --git a/codex-rs/cli/src/main.rs b/codex-rs/cli/src/main.rs
--- a/codex-rs/cli/src/main.rs
+++ b/codex-rs/cli/src/main.rs
@@ -806,6 +806,12 @@ fn run_update_command() -> anyhow::Result<()> {
 
     #[cfg(not(debug_assertions))]
     {
+        if codex_install_context::is_fedora_package() {
+            anyhow::bail!(
+                "Codex updates are managed by Fedora. Run `dnf upgrade codex-cli` to update."
+            );
+        }
+
         let Some(action) = codex_tui::get_update_action() else {
             anyhow::bail!(
                 "Could not detect the Codex installation method. Please update manually: https://developers.openai.com/codex/cli/"
