From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Use Fedora's native Clang target triples

Fedora installs compiler-rt under architecture-specific redhat-linux-gnu
directories and configures Clang for those targets. Chromium's build files use
upstream GNU triples, which makes the system-toolchain build look for a
nonexistent builtins archive on Fedora.

--- a/build/config/clang/BUILD.gn
+++ b/build/config/clang/BUILD.gn
@@ -184,6 +184,6 @@ template("clang_lib") {
       } else if (is_linux || is_chromeos) {
         if (current_cpu == "x64") {
-          _dir = "x86_64-unknown-linux-gnu"
+          _dir = "x86_64-redhat-linux-gnu"
         } else if (current_cpu == "x86") {
           _dir = "i386-unknown-linux-gnu"
         } else if (current_cpu == "arm") {
@@ -192 +192 @@
-          _dir = "aarch64-unknown-linux-gnu"
+          _dir = "aarch64-redhat-linux-gnu"
--- a/build/config/compiler/BUILD.gn
+++ b/build/config/compiler/BUILD.gn
@@ -1291,2 +1291,2 @@
-        cflags += [ "--target=x86_64-unknown-linux-gnu" ]
-        ldflags += [ "--target=x86_64-unknown-linux-gnu" ]
+        cflags += [ "--target=x86_64-redhat-linux-gnu" ]
+        ldflags += [ "--target=x86_64-redhat-linux-gnu" ]
@@ -1326,2 +1326,2 @@
-        cflags += [ "--target=aarch64-linux-gnu" ]
-        ldflags += [ "--target=aarch64-linux-gnu" ]
+        cflags += [ "--target=aarch64-redhat-linux-gnu" ]
+        ldflags += [ "--target=aarch64-redhat-linux-gnu" ]
