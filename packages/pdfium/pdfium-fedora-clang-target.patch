From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Use Fedora's native Clang toolchain

Fedora installs compiler-rt under architecture-specific redhat-linux-gnu
directories and configures Clang for those targets. Chromium's build files use
upstream GNU triples, which makes the system-toolchain build look for a
nonexistent builtins archive on Fedora. Chromium's release build also enables
two diagnostics supported by its newer bundled Clang but rejected by Fedora
Clang 22; retain the array-bounds instrumentation and trap while omitting those
unsupported feature-detection and warning options. Fedora Chromium carries the
same feature-detection flag removal for its system-Clang build.

--- a/build/config/clang/BUILD.gn
+++ b/build/config/clang/BUILD.gn
@@ -184,6 +184,6 @@ template("clang_lib") {
       } else if (is_linux || is_chromeos) {
         if (current_cpu == "x64") {
-          _dir = "x86_64-unknown-linux-gnu"
+          _dir = "x86_64-redhat-linux-gnu"
         } else if (current_cpu == "x86") {
           _dir = "i386-unknown-linux-gnu"
         } else if (current_cpu == "arm") {
@@ -192 +192 @@
-          _dir = "aarch64-unknown-linux-gnu"
+          _dir = "aarch64-redhat-linux-gnu"
--- a/build/config/compiler/BUILD.gn
+++ b/build/config/compiler/BUILD.gn
@@ -1292,2 +1292,2 @@
-        cflags += [ "--target=x86_64-unknown-linux-gnu" ]
-        ldflags += [ "--target=x86_64-unknown-linux-gnu" ]
+        cflags += [ "--target=x86_64-redhat-linux-gnu" ]
+        ldflags += [ "--target=x86_64-redhat-linux-gnu" ]
@@ -1327,2 +1327,2 @@
-        cflags += [ "--target=aarch64-linux-gnu" ]
-        ldflags += [ "--target=aarch64-linux-gnu" ]
+        cflags += [ "--target=aarch64-redhat-linux-gnu" ]
+        ldflags += [ "--target=aarch64-redhat-linux-gnu" ]
@@ -1855,18 +1855,6 @@ config("sanitize_c_array_bounds") {
     cflags = [
       "-fsanitize=array-bounds",
       "-fsanitize-trap=array-bounds",
-
-      # Some code users feature detection to determine if UBSAN (or any
-      # sanitizer) is enabled, they then do expensive debug like operations. We
-      # want to suppress this behaviour since we want to keep performance costs
-      # as low as possible while having these checks.
-      "-fsanitize-ignore-for-ubsan-feature=array-bounds",
-
-      # Because we've enabled array-bounds sanitizing we also want to suppress
-      # the related warning about "unsafe-buffer-usage-in-static-sized-array",
-      # since we know that the array bounds sanitizing will catch any out-of-
-      # bounds accesses.
-      "-Wno-unsafe-buffer-usage-in-static-sized-array",
     ]
   }
 }
