From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Give PDFium private component libraries unique names

PDFium's component build links private copies of its pinned Abseil and ICU
sources.  Avoid colliding with Fedora's system library namespace while keeping
the components beside libpdfium.so for its $ORIGIN runtime lookup.

--- a/third_party/abseil-cpp/BUILD.gn
+++ b/third_party/abseil-cpp/BUILD.gn
@@ -18,6 +18,7 @@ config("absl_component_build") {
 }
 
 component("absl") {
+  output_name = "pdfium_absl"
   public_deps = [ ":absl_component_deps" ]
   if (is_component_build) {
     public_configs = [ ":absl_component_build" ]
--- a/third_party/icu/BUILD.gn
+++ b/third_party/icu/BUILD.gn
@@ -399 +399 @@
-  output_name = "icuuc"
+  output_name = "pdfium_icuuc"
