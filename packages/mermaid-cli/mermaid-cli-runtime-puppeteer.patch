From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Declare the locked Puppeteer release as a runtime dependency

Mermaid CLI imports Puppeteer unconditionally from src/index.js, but upstream
declares it only as a peer and development dependency. Fedora installs a
self-contained application closure, so make the locked 25.2.1 release an
explicit production dependency while preserving upstream's peer contract.

--- a/package.json
+++ b/package.json
@@ -37,7 +37,8 @@
     "import-meta-resolve": "^4.1.0",
     "katex": "^0.16.25",
     "mermaid": "^11.14.0",
-    "p-limit": "^6.2.0"
+    "p-limit": "^6.2.0",
+    "puppeteer": "25.2.1"
   },
   "optionalDependencies": {
     "@mermaid-js/layout-tidy-tree": "^0.2.1"
@@ -54,7 +55,6 @@
     "globals": "^17.6.0",
     "jest": "^30.0.5",
     "prettier": "^3.8.3",
-    "puppeteer": "^25.0.0",
     "typescript": "^6.0.3",
     "typescript-eslint": "^8.59.3",
     "vite": "^6.0.2",
