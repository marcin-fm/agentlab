From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Fix V8 GCC preprocessing, flags, and include completeness

GCC does not accept Clang's `__has_warning` predicate in a compound `#if`, the
Linux GCC assembly path receives a Clang-only BTI marker, and one Wasm source
relies on a transitive include for managed object definitions. Keep Clang warning
handling unchanged while making the Fedora GCC path portable and include the
required definition directly.
---
diff --git a/v8/BUILD.gn b/v8/BUILD.gn
--- a/v8/BUILD.gn
+++ b/v8/BUILD.gn
@@ -1621,6 +1621,7 @@
   if (v8_current_cpu == "arm64") {
     defines += [ "V8_TARGET_ARCH_ARM64" ]
-    if (current_cpu == "arm64" && v8_control_flow_integrity && is_clang) {
+    if (current_cpu == "arm64" && v8_control_flow_integrity && is_clang &&
+        !is_linux) {
       # Mark assembly code as BTI-compatible.
       asmflags = [ "-mmark-bti-property" ]
     }
diff --git a/v8/src/base/macros.h b/v8/src/base/macros.h
--- a/v8/src/base/macros.h
+++ b/v8/src/base/macros.h
@@ -635,8 +635,8 @@ bool is_inbounds(float_t v) {
 #endif  // defined(__clang__)
 
 // Disable/enable -Wlifetime-safety warnings in code.
-#if defined(__clang__) && defined(__has_warning) && \
-    __has_warning("-Wlifetime-safety")
+#if defined(__clang__) && defined(__has_warning)
+#if __has_warning("-Wlifetime-safety")
 #define START_IGNORE_LIFETIME_SAFETY_WARNINGS() \
   _Pragma("clang diagnostic push")              \
       _Pragma("clang diagnostic ignored \"-Wlifetime-safety\"")
@@ -644,11 +644,15 @@ bool is_inbounds(float_t v) {
 #else
 #define START_IGNORE_LIFETIME_SAFETY_WARNINGS()
 #define END_IGNORE_LIFETIME_SAFETY_WARNINGS()
-#endif  // defined(__clang__)
+#endif  // __has_warning("-Wlifetime-safety")
+#else
+#define START_IGNORE_LIFETIME_SAFETY_WARNINGS()
+#define END_IGNORE_LIFETIME_SAFETY_WARNINGS()
+#endif  // defined(__clang__) && defined(__has_warning)
 
 // Disable/enable -Wreturn-stack-address warnings in code.
-#if defined(__clang__) && defined(__has_warning) && \
-    __has_warning("-Wreturn-stack-address")
+#if defined(__clang__) && defined(__has_warning)
+#if __has_warning("-Wreturn-stack-address")
 #define START_IGNORE_RETURN_STACK_ADDRESS_WARNINGS() \
   _Pragma("clang diagnostic push")                   \
       _Pragma("clang diagnostic ignored \"-Wreturn-stack-address\"")
@@ -657,6 +661,10 @@ bool is_inbounds(float_t v) {
 #else
 #define START_IGNORE_RETURN_STACK_ADDRESS_WARNINGS()
 #define END_IGNORE_RETURN_STACK_ADDRESS_WARNINGS()
-#endif  // defined(__clang__)
+#endif  // __has_warning("-Wreturn-stack-address")
+#else
+#define START_IGNORE_RETURN_STACK_ADDRESS_WARNINGS()
+#define END_IGNORE_RETURN_STACK_ADDRESS_WARNINGS()
+#endif  // defined(__clang__) && defined(__has_warning)
 
 #endif  // V8_BASE_MACROS_H_
diff --git a/v8/src/wasm/constant-expression-interface.cc b/v8/src/wasm/constant-expression-interface.cc
--- a/v8/src/wasm/constant-expression-interface.cc
+++ b/v8/src/wasm/constant-expression-interface.cc
@@ -8,6 +8,7 @@
 #include "src/execution/isolate.h"
 #include "src/handles/handles-inl.h"
 #include "src/objects/fixed-array-inl.h"
+#include "src/objects/managed-inl.h"
 #include "src/objects/map-inl.h"
 #include "src/wasm/decoder.h"
 #include "src/wasm/wasm-objects-inl.h"
