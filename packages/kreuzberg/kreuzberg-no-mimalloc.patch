From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Do not select mimalloc for the Fedora Node build

Avoid the optional allocator dependency in the Fedora-provided Node binding.

diff --git a/crates/kreuzberg-node/Cargo.toml b/crates/kreuzberg-node/Cargo.toml
--- a/crates/kreuzberg-node/Cargo.toml
+++ b/crates/kreuzberg-node/Cargo.toml
@@ -56,8 +56,5 @@ serde = { workspace = true }
 serde_json = { workspace = true }
 tokio = { workspace = true, features = ["time"] }
 
-[target.'cfg(all(any(windows, unix), target_arch = "x86_64", not(target_env = "musl")))'.dependencies]
-mimalloc-rust = "0.2"
-
 [build-dependencies]
 napi-build = "2.3"
