From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Discover Fedora runtime library paths

Fedora installs ONNX Runtime in the architecture-specific libdir. Include the
64-bit Fedora path in Kreuzberg's automatic dynamic-library discovery. PDFium
keeps its unversioned linker name in the development package, so try the
versioned runtime library before the generic system lookup.

diff --git a/crates/kreuzberg/src/ort_discovery.rs b/crates/kreuzberg/src/ort_discovery.rs
--- a/crates/kreuzberg/src/ort_discovery.rs
+++ b/crates/kreuzberg/src/ort_discovery.rs
@@ -68,2 +68,3 @@ fn platform_candidates() -> &'static [&'static str] {
     &[
+        "/usr/lib64/libonnxruntime.so",
         "/usr/lib/libonnxruntime.so",
diff --git a/crates/kreuzberg/src/pdf/bindings.rs b/crates/kreuzberg/src/pdf/bindings.rs
--- a/crates/kreuzberg/src/pdf/bindings.rs
+++ b/crates/kreuzberg/src/pdf/bindings.rs
@@ -96,6 +96,13 @@
         }
     }
 
+    #[cfg(all(feature = "system-pdfium", target_os = "linux"))]
+    for path in ["/usr/lib64/libpdfium.so.146", "/usr/lib/libpdfium.so.146"] {
+        if let Ok(bindings) = Pdfium::bind_to_library(path) {
+            return Ok(bindings);
+        }
+    }
+
     Pdfium::bind_to_system_library().map_err(|e| format!("Failed to bind to system Pdfium library: {}", e))
 }
 
