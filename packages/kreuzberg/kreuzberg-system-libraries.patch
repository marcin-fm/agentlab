From: Marcin FM <marcin@lgic.pl>
Subject: [PATCH] Use Fedora system libraries and runtime feature scope

Fedora builds must not download or embed upstream PDFium, Tesseract, or ONNX
Runtime binaries. Preserve the documented Node extraction, OCR, embeddings,
layout, and tree-sitter surfaces while omitting server-only API, MCP,
OpenTelemetry, and Liter LLM features that are not exposed by the Node API.

diff --git a/crates/kreuzberg-node/Cargo.toml b/crates/kreuzberg-node/Cargo.toml
--- a/crates/kreuzberg-node/Cargo.toml
+++ b/crates/kreuzberg-node/Cargo.toml
@@ -22,7 +22,31 @@
 bytes = { workspace = true }
 ctor = { workspace = true }
 html-to-markdown-rs = { workspace = true }
-kreuzberg = { workspace = true, features = ["bundled-pdfium", "full"] }
+kreuzberg = { workspace = true, features = [
+    "system-pdfium",
+    "pdf",
+    "excel",
+    "office",
+    "hwp",
+    "iwork",
+    "email",
+    "html",
+    "xml",
+    "archives",
+    "language-detection",
+    "quality",
+    "keywords",
+    "mdx",
+    "chunking-tokenizers",
+    "ocr",
+    "paddle-ocr",
+    "layout-detection",
+    "embeddings",
+    "tree-sitter",
+    "ort-dynamic",
+    "tokio-runtime",
+    "simd-utf8",
+] }
 kreuzberg-ffi = { workspace = true }
 napi = { version = "3", default-features = false, features = ["napi8", "async", "serde-json"] }
 napi-derive = "3"
diff --git a/crates/kreuzberg-ffi/Cargo.toml b/crates/kreuzberg-ffi/Cargo.toml
