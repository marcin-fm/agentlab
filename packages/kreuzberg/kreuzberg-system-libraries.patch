-kreuzberg = { workspace = true, features = ["bundled-pdfium", "full"] }
+kreuzberg = { workspace = true, features = [
+    "system-pdfium",
+    "pdf",
+    "excel",
+    "office",
+    "hwp",
+    "iwork",
+    "email",
+    "html",
+    "xml",
+    "archives",
+    "language-detection",
+    "quality",
+    "keywords",
+    "mdx",
+    "chunking-tokenizers",
+    "ocr",
+    "paddle-ocr",
+    "layout-detection",
+    "embeddings",
+    "tree-sitter",
+    "ort-dynamic",
+    "tokio-runtime",
+    "simd-utf8",
+] }
