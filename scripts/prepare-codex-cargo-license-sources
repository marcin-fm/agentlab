    add_source.call("rust-shed-sorted-vector-map-apache", "https://raw.githubusercontent.com/facebookexperimental/rust-shed/756ae7daba100d194aa0260131937b7d96672549/LICENSE-APACHE", "bb28c48e3e078166e91cfc2b6db7ffebb8a0973b9e23b3df060561292d8d69ec", 10140, ["Apache-2.0"], "rust-shed-sorted-vector-map-Apache-2.0.txt")

    release = lambda do |directory, checksum, expression, repository, commit, path, ids, install_ids, manifest, sha, size|
      receipt.fetch("mappings") << {
        "directory" => directory, "crate_checksum" => checksum, "declared_expression" => expression,
        "source_repository" => repository, "source_commit" => commit, "package_path" => path,
        "source_ids" => ids, "install_source_ids" => install_ids, "provenance_mode" => "release-history",
        "release_manifest_source_id" => manifest,
        "manifest_relation" => {
          "kind" => "exact-byte-equality", "upstream_sha256" => sha, "upstream_size_bytes" => size,
          "vendor_sha256" => sha, "vendor_size_bytes" => size, "explanation" => nil
        }
      }
    end
    release.call("display_container-0.9.0", "0a110a75c96bedec8e65823dea00a1d710288b7a369d95fd8a0f5127639466fa", "MIT OR Apache-2.0", "https://github.com/facebookincubator/gazebo", "13efb6d415c4729178dfccc36fa9c87491f0813d", "display_container", %w[gazebo-display-container-mit gazebo-display-container-apache], %w[buck2-lock-free-mit apache-2.0-50e675], "gazebo-display-container-manifest", "9eb42b9aa1fa21f8d29340d5a1f299ee4a4490db25f116e9452abe7717afad39", 392)
    release.call("strong_hash-0.1.0", "0831334aea34390b6b6ec7af0a27f9ee6324ad3a69463e6b240d83d6b7bce9c9", "MIT OR Apache-2.0", "https://github.com/facebook/buck2", "7ef58762149c23402d89f13af2cb293481ef950e", "gazebo/strong_hash", %w[buck2-strong-hash-mit buck2-strong-hash-apache], %w[buck2-lock-free-mit apache-2.0-50e675], "buck2-strong-hash-manifest", "8e4b2ca9d3e354abbedbef94e22e19d8358bf497979bb6ec4c4bde0e1b3b5a23", 413)
    release.call("sorted_vector_map-0.2.1", "94bf565ee1681b4473aa5a9d71d807347c28021bd1d8947cb626b02f42a0141f", "MIT OR Apache-2.0", "https://github.com/facebookexperimental/rust-shed", "756ae7daba100d194aa0260131937b7d96672549", "shed/sorted_vector_map", %w[rust-shed-sorted-vector-map-mit rust-shed-sorted-vector-map-apache], %w[rust-shed-sorted-vector-map-mit rust-shed-sorted-vector-map-apache], "rust-shed-sorted-vector-map-manifest", "0da5cfbb775c83164b4296b49d20e98b92e83a8904103be3a2990c3f18d47ed6", 702)
    resolved = %w[display_container-0.9.0 sorted_vector_map-0.2.1 strong_hash-0.1.0]
    receipt["unresolved"].reject! { |item| resolved.include?(item.fetch("directory")) }
    populate_mapping_evidence!(receipt)
    receipt
  end

  def upgrade_v4!(receipt, package)
    return receipt if receipt["schema"] == "agentlab-codex-cargo-supplemental-license-sources/v4"

    upgrade_v3!(receipt, package)
    receipt["policy_holds"] = []
    receipt["fedora_precedents"] = [FEDORA_NOTIFY_PRECEDENT]
    receipt
  end

  def upgrade_v5!(receipt, package)
    return receipt if receipt["schema"] == "agentlab-codex-cargo-supplemental-license-sources/v5"

    upgrade_v4!(receipt, package)
    receipt.fetch("sources") << {
      "id" => "bech32-0.11.0-mit", "kind" => "archive_member",
      "immutable_url" => "https://static.crates.io/crates/bech32/bech32-0.11.0.crate",
      "expected_transport_sha256" => "d965446196e3b7decd44aa7ee49e31d630118f90ef12f97900f262eb915c951d",
      "member_path" => "bech32-0.11.0/LICENSE-MIT",
      "expected_extracted_sha256" => "9877c7b48cde1462f4e8688263aa96f3f1bd9717250718d3d2d9ebb031414fb9",
      "expected_extracted_size_bytes" => 1055, "spdx_ids" => ["MIT"], "install" => true,
      "install_filename" => "bech32-0.11.0-MIT.txt"
    }
    receipt.fetch("mappings") << {
      "directory" => "bech32-0.9.1", "crate_checksum" => "d86b93f97252c47b41663388e6d155714a9d0c398b99f1005cbc5f978b29f445",
      "declared_expression" => "MIT", "source_repository" => "https://github.com/rust-bitcoin/rust-bech32",
