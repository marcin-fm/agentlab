      ["io_tee-0.1.1", "4b3f7cef34251886990511df1c61443aa928499d598a9473929ab5a90a527304", "MIT OR Apache-2.0", "https://github.com/TheOnlyMrCat/io_tee", %w[spdx-mit spdx-apache], "https://github.com/TheOnlyMrCat/io_tee/issues/1", "Request that the published crate ship its declared MIT and Apache-2.0 license texts."],
      ["linux-keyutils-0.2.4", "761e49ec5fd8a5a463f9b84e877c373d888935b71c6be78f3767fe2ae6bed18e", "Apache-2.0 OR MIT", "https://github.com/landhb/linux-keyutils", %w[spdx-apache spdx-mit], "https://github.com/landhb/linux-keyutils/issues/21", "Request that the published crate ship its declared Apache-2.0 and MIT license texts."],
      ["sse-stream-0.2.1", "eb4dc4d33c68ec1f27d386b5610a351922656e1fdf5c05bbaad930cd1519479a", "MIT OR Apache-2.0", "https://github.com/4t145/sse-stream", %w[spdx-mit spdx-apache], "https://github.com/4t145/sse-stream/issues/14", "Request that the published crate ship its declared MIT and Apache-2.0 license texts."]
    ]
    requests.each do |directory, checksum, expression, repository, source_ids, issue, scope|
      receipt.fetch("mappings") << {
        "directory" => directory, "crate_checksum" => checksum, "declared_expression" => expression,
        "source_repository" => repository, "source_ids" => source_ids, "install_source_ids" => source_ids,
        "provenance_mode" => "canonical-standard",
        "upstream_request" => { "url" => issue, "status" => "open", "scope" => scope },
        "policy_basis" => policy_basis, "canonical_authority" => authority
      }
    end
    resolved = requests.map(&:first)
    receipt.fetch("unresolved").reject! { |item| resolved.include?(item.fetch("directory")) }
    receipt.fetch("archive")["installable_texts"] = 25
    receipt
  end

  def generate!(receipt, cache:, output:, vendor_archive:, package:, offline:)
    _resolver, inventory, audit = checked_inputs!(receipt, package)
    Dir.mktmpdir("agentlab-codex-license-sources-", temporary_root) do |temporary|
      vendor_root = extract_vendor!(vendor_archive, temporary, receipt)
      verify_mappings!(receipt, vendor_root, inventory, audit)
      icu = receipt.fetch("icu_mapping")
      payload_source = receipt.fetch("sources").find { |source| source.fetch("id") == "icu-data-payload" }
      payload = source_bytes!(payload_source, cache, offline:)
      vendored_payload = File.binread(File.join(vendor_root, icu.fetch("directory"), "src", "icudtl.dat"))
      raise CodexCargoVendor::Error, "ICU payload does not match vendored deno_core_icudata" unless payload == vendored_payload

      texts = receipt.fetch("sources").select { |source| source.fetch("install", true) && source.fetch("id") != "icu-data-payload" }.map do |source|
        [source, source_bytes!(source, cache, offline:)]
      end
      texts.each do |source, bytes|
        source["expected_extracted_size_bytes"] = bytes.bytesize
        source["expected_extracted_sha256"] ||= Digest::SHA256.hexdigest(bytes)
      end
      populate_mapping_evidence!(receipt)
      verify_mappings!(receipt, vendor_root, inventory, audit, cache:, offline:)
      root = "codex-cli-#{receipt.dig('release', 'version')}-supplemental-license-sources"
      File.open(output, "wb") do |file|
        Zlib::GzipWriter.wrap(file) do |gzip|
          Gem::Package::TarWriter.new(gzip) do |tar|
            texts.sort_by { |source, _| source.fetch("install_filename") }.each do |source, bytes|
              tar.add_file_simple("#{root}/#{source.fetch('install_filename')}", 0o644, bytes.bytesize) { |entry| entry.write(bytes) }
            end
          end
        end
      end
      receipt["archive"] = { "filename" => File.basename(output), "root" => root, "installable_texts" => texts.length, "transport_identity_required" => false }
    end
  end

  def verify_archive!(receipt, archive)
    expected = receipt.fetch("sources").select { |source| source.fetch("install", true) && source.fetch("id") != "icu-data-payload" }.to_h do |source|
      [source.fetch("install_filename"), source]
    end
    root = receipt.dig("archive", "root")
    seen = {}
    Zlib::GzipReader.open(archive) do |gzip|
      Gem::Package::TarReader.new(gzip) do |tar|
        tar.each do |entry|
          raise CodexCargoVendor::Error, "non-file supplemental archive entry" unless entry.file?
          path = CodexCargoVendor.tar_header_path(entry.header)
          raise CodexCargoVendor::Error, "unsafe supplemental archive path" unless path.start_with?("#{root}/") && !path.delete_prefix("#{root}/").include?("/")
          name = path.delete_prefix("#{root}/")
          source = expected.fetch(name) { raise CodexCargoVendor::Error, "unexpected supplemental archive member #{name}" }
          raise CodexCargoVendor::Error, "duplicate supplemental archive member #{name}" if seen.key?(name)
          bytes = entry.read
          raise CodexCargoVendor::Error, "supplemental text SHA-256 mismatch: #{name}" unless Digest::SHA256.hexdigest(bytes) == source.fetch("expected_extracted_sha256")
          raise CodexCargoVendor::Error, "supplemental text size mismatch: #{name}" unless bytes.bytesize == source.fetch("expected_extracted_size_bytes")
          seen[name] = true
        end
      end
    end
    raise CodexCargoVendor::Error, "supplemental archive member set mismatch" unless seen.keys.sort == expected.keys.sort
  end

  def check!(receipt, archive:, vendor_archive:, package:)
    _resolver, inventory, audit = checked_inputs!(receipt, package)
    Dir.mktmpdir("agentlab-codex-license-check-", temporary_root) do |temporary|
      vendor_root = extract_vendor!(vendor_archive, temporary, receipt)
      verify_mappings!(receipt, vendor_root, inventory, audit)
      payload = File.binread(File.join(vendor_root, receipt.dig("icu_mapping", "directory"), "src", "icudtl.dat"))
      raise CodexCargoVendor::Error, "vendored ICU payload SHA-256 mismatch" unless Digest::SHA256.hexdigest(payload) == ICU_PAYLOAD_SHA256
      raise CodexCargoVendor::Error, "vendored ICU payload size mismatch" unless payload.bytesize == ICU_PAYLOAD_BYTES
    end
    verify_archive!(receipt, archive)
  end

  def parse_options
    options = {}
    OptionParser.new do |parser|
      parser.on("--spec PATH") { |value| options[:spec] = value }
      parser.on("--plan PATH") { |value| options[:plan] = value }
      parser.on("--receipt PATH") { |value| options[:receipt] = value }
      parser.on("--archive PATH") { |value| options[:archive] = value }
      parser.on("--vendor-archive PATH") { |value| options[:vendor_archive] = value }
      parser.on("--cache-dir PATH") { |value| options[:cache] = value }
      parser.on("--offline-cache") { options[:offline] = true }
      parser.on("--refresh") { options[:refresh] = true }
      parser.on("--check") { options[:check] = true }
    end.parse!
    options
  end
end

if $PROGRAM_NAME == __FILE__
begin
  options = CodexSupplementalLicenses.parse_options
  if options[:spec]
    spec = File.realpath(options.fetch(:spec))
    package = File.dirname(spec)
    sources = CodexSupplementalLicenses.sources_from_spec(spec)
    receipt_path = options[:receipt] || File.join(package, CodexSupplementalLicenses.source_filename(sources.fetch(14)))
    archive = options[:archive] || File.join(package, CodexSupplementalLicenses.source_filename(sources.fetch(15)))
    vendor_archive = options[:vendor_archive] || File.join(package, CodexSupplementalLicenses.source_filename(sources.fetch(10)))
  else
    receipt_path = options.fetch(:receipt)
    archive = options.fetch(:archive)
    vendor_archive = options.fetch(:vendor_archive)
    package = File.dirname(receipt_path)
  end
  receipt = if options[:refresh]
              CodexSupplementalLicenses.receipt_from_plan(JSON.parse(File.read(options.fetch(:plan))), package)
            else
              JSON.parse(File.read(receipt_path))
            end
  if options[:check]
    CodexSupplementalLicenses.check!(receipt, archive:, vendor_archive:, package:)
  else
    cache = File.expand_path(options.fetch(:cache, File.join(CodexSupplementalLicenses.temporary_root, "agentlab-codex-supplemental-license-validation", "cache")))
    CodexSupplementalLicenses.generate!(receipt, cache:, output: archive, vendor_archive:, package:, offline: options.fetch(:offline, false))
    rendered = JSON.pretty_generate(receipt) + "\n"
    if options[:refresh]
      File.write(receipt_path, rendered)
    elsif File.binread(receipt_path) != rendered
      raise CodexCargoVendor::Error, "supplemental receipt is stale; use --refresh to rewrite"
    end
  end
  puts "Prepared Codex supplemental license sources."
rescue CodexCargoVendor::Error, JSON::ParserError, KeyError, OptionParser::ParseError, SystemCallError => e
  warn "error: #{e.message}"
  exit 1
end
end
