  def upgrade_v6!(receipt, package)
    return receipt if receipt["schema"] == "agentlab-codex-cargo-supplemental-license-sources/v6"

    upgrade_v5!(receipt, package)
    policy_basis = "/srv/wikis/agentlab/policies.md:55"
    authority = {
      "repository" => "https://github.com/spdx/license-list-data",
      "tag" => "v3.28.0",
      "commit" => "c4a7237ec8f4654e867546f9f409749300f1bf4c"
    }
    receipt.fetch("mappings").select { |mapping| mapping.fetch("provenance_mode") == "canonical-standard" }.each do |mapping|
      mapping["policy_basis"] = policy_basis
    end
    requests = [
      ["debugserver-types-0.5.0", "2bf6834a70ed14e8e4e41882df27190bea150f1f6ecf461f1033f8739cd8af4a", "MIT", "https://github.com/Marwes/debugserver-types", ["spdx-mit"], "https://github.com/Marwes/debugserver-types/issues/5", "Request that the published crate ship its declared MIT license text."],
