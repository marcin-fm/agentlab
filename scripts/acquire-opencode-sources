#!/usr/bin/env ruby
# frozen_string_literal: true

require "base64"
require "digest"
require "fileutils"
require "find"
require "json"
require "open3"
require "optparse"
require "pathname"
require "set"
require "tempfile"
require "thread"
require "tmpdir"
require_relative "lib/agentlab"

ROLE_RANK = { "build" => 0, "runtime" => 1 }.freeze
LICENSE_BASENAME = /\A(?:licen[cs]e|copying|notice|copyright)(?:[._-].*)?\z/i
NATIVE_SUFFIXES = %w[.node .so .dylib .dll .exe .a .o .obj .lib].freeze
NATIVE_SOURCE_SUFFIXES = %w[.c .cc .cpp .cxx .h .hh .hpp .hxx .m .mm .rs .s .asm .gyp .gypi].freeze
SOURCE_EXECUTABLE_SUFFIXES = %w[.js .mjs .cjs .ts .tsx .jsx .sh .py .rb .pl .css .html .json .md .wasm].freeze
MAGIC_FORMATS = {
  "\x7FELF".b => "ELF",
  "MZ".b => "PE",
  "\x00asm".b => "WASM",
  "!<arch>\n".b => "static-archive"
}.freeze

def require_workdir(path)
  expanded = File.expand_path(path)
  raise Agentlab::Error, "workdir must be below /srv/tmp" unless expanded.start_with?("/srv/tmp/")

  marker = File.join(expanded, ".agentlab-opencode-source-acquisition")
  if Dir.exist?(expanded)
    raise Agentlab::Error, "refusing unmarked workdir #{expanded}" unless File.file?(marker)
  else
    FileUtils.mkdir_p(expanded)
    File.write(marker, "agentlab opencode source acquisition\n")
  end
  FileUtils.mkdir_p(File.join(expanded, "archives"))
  expanded
end

def integrity_bytes(integrity, label)
  algorithm, encoded = integrity.to_s.split("-", 2)
  raise Agentlab::Error, "#{label}: unsupported integrity algorithm #{algorithm.inspect}" unless algorithm == "sha512"
  raise Agentlab::Error, "#{label}: malformed integrity" unless encoded

  Base64.strict_decode64(encoded)
rescue ArgumentError => e
  raise Agentlab::Error, "#{label}: malformed integrity: #{e.message}"
end

def verify_integrity!(bytes, integrity, label)
  expected = integrity_bytes(integrity, label)
  actual = Digest::SHA512.digest(bytes)
  raise Agentlab::Error, "#{label}: sha512 integrity mismatch" unless actual == expected
end

def source_identity(record)
  case record.fetch("origin")
  when "registry"
    ["registry", record.fetch("source_url"), record.fetch("integrity")]
  when "github"
    ["github", record.fetch("source_url"), record.fetch("source_commit")]
  else
    raise Agentlab::Error, "unsupported selected source origin #{record.fetch('origin').inspect}"
  end
end

def archive_filename(source)
  case source.fetch("origin")
  when "registry"
    digest = integrity_bytes(source.fetch("integrity"), source.fetch("npm_name")).unpack1("H*")
    "sha512-#{digest}.tgz"
  when "github"
    "git-#{source.fetch('source_commit')}.tar.gz"
  end
end

def download_with_retries(url, label)
  attempts = 0
  begin
    attempts += 1
    Agentlab.download(url)
  rescue Agentlab::Error
    raise if attempts >= 3

    sleep(attempts)
    retry
  end
rescue StandardError => e
  raise Agentlab::Error, "#{label}: download failed: #{e.message}"
end

def archive_bytes(source, path, check:)
  if File.file?(path)
    bytes = File.binread(path)
    verify_integrity!(bytes, source.fetch("integrity"), source.fetch("npm_name")) if source.fetch("origin") == "registry"
    return bytes
  end

  raise Agentlab::Error, "missing cached archive #{path}" if check

  bytes = download_with_retries(source.fetch("source_url"), source.fetch("npm_name"))
  verify_integrity!(bytes, source.fetch("integrity"), source.fetch("npm_name")) if source.fetch("origin") == "registry"

  Tempfile.create([".opencode-source-", ".tmp"], File.dirname(path)) do |file|
    file.binmode
    file.write(bytes)
    file.flush
    file.fsync
    File.chmod(0o644, file.path)
    File.rename(file.path, path)
  end
  bytes
end

def safe_archive_path(path)
  clean = Pathname(path).cleanpath.to_s
  return nil if Pathname(path).absolute? || clean == ".." || clean.start_with?("../")

  clean
end

def safe_link?(path, target)
  return false if target.to_s.empty? || Pathname(target).absolute?

  resolved = Pathname(File.join(File.dirname(path), target)).cleanpath.to_s
  resolved != ".." && !resolved.start_with?("../")
end

def source_executable?(path, header)
  basename = File.basename(path)
  SOURCE_EXECUTABLE_SUFFIXES.any? { |suffix| path.downcase.end_with?(suffix) } ||
    basename.match?(LICENSE_BASENAME) || header.start_with?("#!")
end

def inspect_archive(path, source, scan_parent)
  listing, listing_error, listing_status = Open3.capture3("tar", "-tzf", path)
  unless listing_status.success?
    raise Agentlab::Error, "#{source.fetch('npm_name')}: cannot list archive: #{listing_error.strip}"
  end
  listed_paths = listing.lines.map(&:chomp)
  unsafe_paths = listed_paths.filter_map do |raw_path|
    clean = safe_archive_path(raw_path)
    { "path" => raw_path, "reason" => "path-escape" } unless clean
  end
  duplicates = listed_paths.tally.select { |_entry, count| count > 1 }.keys.sort
  duplicates.each { |entry| unsafe_paths << { "path" => entry, "reason" => "duplicate-path" } }

  verbose, verbose_error, verbose_status = Open3.capture3("tar", "-tvzf", path)
  unless verbose_status.success?
    raise Agentlab::Error, "#{source.fetch('npm_name')}: cannot inspect archive types: #{verbose_error.strip}"
  end
  special_entries = verbose.lines.filter_map do |line|
    type = line[0]
    { "entry" => line.strip, "reason" => "special-type-#{type}" } if %w[b c p s].include?(type)
  end
  unless unsafe_paths.empty? && special_entries.empty?
    raise Agentlab::Error, "#{source.fetch('npm_name')}: unsafe archive entries: #{(unsafe_paths + special_entries).first(10).inspect}"
  end

  inspection = nil
  Dir.mktmpdir("source-scan-", scan_parent) do |scan_root|
    _extract_output, extract_error, extract_status = Open3.capture3(
      "tar", "-xzf", path, "-C", scan_root,
      "--no-same-owner", "--no-same-permissions", "--delay-directory-restore"
    )
    unless extract_status.success?
      raise Agentlab::Error, "#{source.fetch('npm_name')}: cannot extract archive: #{extract_error.strip}"
    end

    root = File.realpath(scan_root)
    symlinks = []
    hardlink_inodes = Hash.new { |hash, key| hash[key] = [] }
    license_files = []
    package_jsons = []
    native_payloads = []
    wasm_payloads = []
    executable_payloads = []
    native_source_paths = []
    file_count = 0
    unpacked_size = 0

    Find.find(root) do |entry|
      next if entry == root

      stat = File.lstat(entry)
      relative = Pathname(entry).relative_path_from(Pathname(root)).to_s
      if stat.symlink?
        target = File.readlink(entry)
        expanded_target = File.expand_path(target, File.dirname(entry))
        unless expanded_target == root || expanded_target.start_with?("#{root}/")
          raise Agentlab::Error, "#{source.fetch('npm_name')}: symlink escapes archive root: #{relative} -> #{target}"
        end
        symlinks << { "path" => relative, "target" => target }
        next
      end
      next if stat.directory?
      raise Agentlab::Error, "#{source.fetch('npm_name')}: extracted special file #{relative}" unless stat.file?

      file_count += 1
      unpacked_size += stat.size
      hardlink_inodes[[stat.dev, stat.ino]] << relative if stat.nlink > 1
      basename = File.basename(relative)
      read_full = basename == "package.json" || basename.match?(LICENSE_BASENAME)
      bytes = read_full ? File.binread(entry) : File.binread(entry, [stat.size, 16].min)
      header = bytes.byteslice(0, 16).to_s.b

      if basename == "package.json"
        begin
          package_jsons << { "path" => relative, "data" => JSON.parse(bytes) }
        rescue JSON::ParserError => e
          raise Agentlab::Error, "#{source.fetch('npm_name')}: invalid #{relative}: #{e.message}"
        end
      end
      if basename.match?(LICENSE_BASENAME)
        license_files << {
          "path" => relative,
          "sha256" => Digest::SHA256.hexdigest(bytes),
          "size" => bytes.bytesize
        }
      end

      suffix = NATIVE_SUFFIXES.find { |candidate| relative.downcase.end_with?(candidate) }
      magic = MAGIC_FORMATS.find { |signature, _format| header.start_with?(signature) }&.last
      if suffix || %w[ELF PE static-archive].include?(magic)
        native_payloads << { "path" => relative, "suffix" => suffix, "format" => magic }.compact
      end
      if relative.downcase.end_with?(".wasm") || magic == "WASM"
        wasm_payloads << { "path" => relative, "format" => magic || "suffix" }
      end
      if (stat.mode & 0o111).positive? && !source_executable?(relative, header)
        executable_payloads << { "path" => relative, "mode" => format("%04o", stat.mode & 0o777) }
      end
      if NATIVE_SOURCE_SUFFIXES.any? { |candidate| relative.downcase.end_with?(candidate) } ||
         %w[Cargo.toml binding.gyp CMakeLists.txt].include?(basename)
        native_source_paths << relative
      end
    end

    expected_name = source.fetch("npm_name")
    expected_version = source.fetch("version")
    package_json = package_jsons.find do |record|
      data = record.fetch("data")
      data["name"] == expected_name && (source.fetch("origin") != "registry" || data["version"].to_s == expected_version)
    end
    unless package_json
      identities = package_jsons.map { |record| [record.dig("data", "name"), record.dig("data", "version"), record.fetch("path")] }
      raise Agentlab::Error, "#{expected_name}@#{expected_version}: matching package.json absent; found #{identities.first(10).inspect}"
    end

    metadata = package_json.fetch("data")
    lifecycle = Hash(metadata["scripts"]).slice("preinstall", "install", "postinstall", "prepare")
    hardlinks = hardlink_inodes.values.select { |paths| paths.length > 1 }.map(&:sort).sort
    inspection = {
      "package_json" => package_json.fetch("path"),
      "declared_license" => metadata["license"] || metadata["licenses"],
      "repository" => metadata["repository"],
      "homepage" => metadata["homepage"],
      "license_files" => license_files.sort_by { |record| record.fetch("path") },
      "lifecycle_scripts" => lifecycle.sort.to_h,
      "native_payloads" => native_payloads.sort_by { |record| record.fetch("path") },
      "wasm_payloads" => wasm_payloads.sort_by { |record| record.fetch("path") },
      "executable_payloads" => executable_payloads.sort_by { |record| record.fetch("path") },
      "native_source_paths" => native_source_paths.sort,
      "symlinks" => symlinks.sort_by { |record| record.fetch("path") },
      "hardlinks" => hardlinks,
      "file_count" => file_count,
      "unpacked_size" => unpacked_size
    }
  end
  inspection
end

package = Agentlab.package_named("opencode")
dependencies = Agentlab.load_yaml(File.join(package.directory, "dependencies.yml"))
version = package.upstream.fetch("current_version").to_s
selected_filename = dependencies.dig("source_closure_files", "selected_lock_audit")
selected_path = File.join(package.directory, selected_filename)
selected_config = dependencies.fetch("selected_lock_receipt")
workdir = "/srv/tmp/agentlab-opencode/source-acquisition-#{version}"
output = File.join(package.directory, "opencode-#{version}-source-audit.json")
jobs = 4
plan = false
check = false

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/acquire-opencode-sources [options]"
  parser.on("--workdir PATH", "Marked resumable work directory below /srv/tmp") { |path| workdir = path }
  parser.on("--output PATH", "Source audit receipt path") { |path| output = path }
  parser.on("--jobs N", Integer, "Concurrent downloads (1-4)") { |value| jobs = value }
  parser.on("--plan", "Print deduplicated source counts without downloading") { plan = true }
  parser.on("--check", "Verify cached sources and the existing receipt without downloading") { check = true }
end.parse!

raise Agentlab::Error, "--jobs must be between 1 and 4" unless (1..4).cover?(jobs)
raise Agentlab::Error, "selected lock receipt is missing: #{selected_path}" unless File.file?(selected_path)
actual_selected_sha = Digest::SHA256.file(selected_path).hexdigest
unless actual_selected_sha == selected_config.fetch("sha256")
  raise Agentlab::Error, "selected lock receipt SHA-256 does not match dependencies.yml"
end

selected = JSON.parse(File.read(selected_path))
unless selected.fetch("release").to_s == version && selected.fetch("schema") == "opencode-selected-lock-audit/v1"
  raise Agentlab::Error, "selected lock receipt identity does not match OpenCode #{version}"
end

unique = {}
selected.fetch("packages").each do |record|
  identity = source_identity(record)
  source = unique[identity] ||= {
    "origin" => record.fetch("origin"),
    "source_url" => record.fetch("source_url"),
    "npm_name" => record.fetch("npm_name"),
    "version" => record.fetch("version"),
    "integrity" => record["integrity"],
    "source_commit" => record["source_commit"],
    "package_paths" => [],
    "roles" => Set.new,
    "candidate_for_binary" => false
  }
  unless source.values_at("npm_name", "version") == record.values_at("npm_name", "version")
    raise Agentlab::Error, "one source identity maps to conflicting package identities: #{identity.inspect}"
  end
  source["package_paths"] << record.fetch("package_path")
  source["roles"] << record.fetch("role")
  source["candidate_for_binary"] ||= record.fetch("candidate_for_binary")
end

sources = unique.values.sort_by { |source| [source.fetch("origin"), source.fetch("npm_name"), source.fetch("version")] }
if plan
  counts = { "github" => 0, "registry" => 0 }.merge(
    sources.group_by { |source| source.fetch("origin") }.transform_values(&:length)
  )
  puts JSON.pretty_generate(
    "selected_package_records" => selected.dig("selection", "selected_packages"),
    "unique_sources" => sources.length,
    "origins" => counts.sort.to_h
  )
  exit 0
end

workdir = require_workdir(workdir)
archives_dir = File.join(workdir, "archives")
scan_parent = File.join(workdir, "scan")
FileUtils.mkdir_p(scan_parent)
queue = Queue.new
sources.each { |source| queue << source }
results = []
errors = []
mutex = Mutex.new

workers = jobs.times.map do
  Thread.new do
    loop do
      source = queue.pop(true)
      filename = archive_filename(source)
      archive_path = File.join(archives_dir, filename)
      bytes = archive_bytes(source, archive_path, check: check)
      inspection = inspect_archive(archive_path, source, scan_parent)
      record = {
        "npm_name" => source.fetch("npm_name"),
        "version" => source.fetch("version"),
        "origin" => source.fetch("origin"),
        "source_url" => source.fetch("source_url"),
        "source_commit" => source["source_commit"],
        "integrity" => source["integrity"],
        "sha256" => Digest::SHA256.hexdigest(bytes),
        "size" => bytes.bytesize,
        "archive" => filename,
        "package_paths" => source.fetch("package_paths").uniq.sort,
        "roles" => source.fetch("roles").to_a.sort_by { |role| ROLE_RANK.fetch(role) }.reverse,
        "candidate_for_binary" => source.fetch("candidate_for_binary")
      }.merge(inspection)
      mutex.synchronize { results << record }
    rescue ThreadError
      break
    rescue StandardError => e
      mutex.synchronize { errors << "#{source&.fetch('npm_name', 'unknown')}: #{e.message}" }
    end
  end
end
workers.each(&:join)

unless errors.empty?
  raise Agentlab::Error, "source acquisition failed for #{errors.length} source(s):\n#{errors.sort.first(20).join("\n")}"
end

records = results.sort_by { |record| [record.fetch("origin"), record.fetch("npm_name"), record.fetch("version")] }
origin_counts = { "github" => 0, "registry" => 0 }.merge(
  records.group_by { |record| record.fetch("origin") }.transform_values(&:length)
).sort.to_h
summary = {
  "selected_package_records" => selected.dig("selection", "selected_packages"),
  "unique_sources" => records.length,
  "origins" => origin_counts,
  "sources_without_declared_license" => records.count { |record| record["declared_license"].nil? },
  "sources_without_license_files" => records.count { |record| record.fetch("license_files").empty? },
  "sources_with_lifecycle_scripts" => records.count { |record| !record.fetch("lifecycle_scripts").empty? },
  "lifecycle_script_count" => records.sum { |record| record.fetch("lifecycle_scripts").length },
  "sources_with_native_payloads" => records.count { |record| !record.fetch("native_payloads").empty? },
  "native_payload_count" => records.sum { |record| record.fetch("native_payloads").length },
  "sources_with_wasm_payloads" => records.count { |record| !record.fetch("wasm_payloads").empty? },
  "wasm_payload_count" => records.sum { |record| record.fetch("wasm_payloads").length },
  "sources_with_executable_payloads" => records.count { |record| !record.fetch("executable_payloads").empty? },
  "executable_payload_count" => records.sum { |record| record.fetch("executable_payloads").length },
  "sources_with_native_source" => records.count { |record| !record.fetch("native_source_paths").empty? }
}
receipt = {
  "schema" => "opencode-source-acquisition/v1",
  "package" => package.name,
  "release" => version,
  "source_tag" => package.upstream.fetch("source_tag"),
  "source_commit" => package.upstream.fetch("source_commit"),
  "selected_lock_receipt_sha256" => actual_selected_sha,
  "summary" => summary,
  "sources" => records,
  "validation" => {
    "registry_integrity_verified" => true,
    "archive_paths_verified" => true,
    "source_sha256_recorded" => true,
    "lifecycle_scripts_executed" => false,
    "dependency_resolution_performed" => false,
    "licenses_verified" => false,
    "native_sources_verified" => false,
    "generated_sources_verified" => false
  }
}
content = JSON.pretty_generate(receipt) + "\n"

if check
  raise Agentlab::Error, "missing source audit receipt #{output}" unless File.file?(output)
  raise Agentlab::Error, "source audit receipt is stale: #{output}" unless File.binread(output) == content

  puts "Verified #{records.length} unique source archives for #{summary.fetch('selected_package_records')} selected package records."
else
  Agentlab.atomic_write(output, content)
  puts "Wrote #{records.length} unique source records for #{summary.fetch('selected_package_records')} selected package records to #{output}."
end
