  directory = File.expand_path(root.fetch("path"), source_dir)
  stamp = stamp_path(build_dir, directory)
  graph_stamp = Pathname(stamp).relative_path_from(Pathname(build_dir)).to_s
  edge = logical_ninja_lines.find do |line|
    line.start_with?("build ") && line.include?(": bun_install ") && line.delete_prefix("build ").split(/\s+\|\s+/, 2).first == graph_stamp
  end
  raise Agentlab::Error, "missing npm install edge for #{directory}" unless edge

  outputs = edge.split(": bun_install ", 2).first.delete_prefix("build ").tr("|", " ").split
  latest_input = [File.mtime(File.join(directory, "package.json")), File.mtime(File.join(directory, "bun.lock"))].max
  output_mtime = [Time.now, latest_input + 1].max
  outputs.each do |graph_path|
    path = File.expand_path(graph_path, build_dir)
    unless path == stamp
      raise Agentlab::Error, "prevalidated npm install output is missing: #{path}" unless File.file?(path) || File.symlink?(path)
    end
    FileUtils.touch(path, mtime: output_mtime)
  end
end

graph_receipt = inspect_graph!(
  ninja_path,
  configure_path,
  source_dir,
  build_dir,
  cache_dir,
  webkit_root,
  proof_zig_root,
  seed_binary,
  npm_install_roots,
  closure.fetch("native_github_sources"),
  closure.fetch("node_headers")
)
graph_receipt["install_rule_bypass"] = install_bypass
install_targets = npm_install_roots.map do |root|
  stamp = stamp_path(build_dir, File.expand_path(root.fetch("path"), source_dir))
  Pathname(stamp).relative_path_from(Pathname(build_dir)).to_s
end
run!(environment, ["unshare", "--net", "--", "ninja", "-C", build_dir, *install_targets], chdir: source_dir, log: File.join(workdir, "install-bypass.log"))
npm_install_roots.each do |root|
  stamp = stamp_path(build_dir, File.expand_path(root.fetch("path"), source_dir))
  target = Pathname(stamp).relative_path_from(Pathname(build_dir)).to_s
  dry_run = capture!(environment, ["ninja", "-C", build_dir, "-n", target], chdir: source_dir)
  raise Agentlab::Error, "prevalidated npm install stamp is still dirty: #{stamp}" unless dry_run.include?("no work to do")
end

configure_receipt = {
  "schema" => "bun-first-source-build-configure-proof/v1",
  "package" => "bun",
  "release" => version,
  "profile" => "release-local",
  "source_closure_sha256" => closure_sha256,
  "source_commit" => source_commit,
  "npm_proof_sha256" => npm_receipt_sha256,
  "cargo_proof_sha256" => sha256(cargo_receipt_path),
  "seed" => {
    "archive_sha256" => seed_metadata.fetch("sha256"),
    "binary_sha256" => seed_metadata.fetch("binary_sha256"),
    "size_bytes" => seed_metadata.fetch("binary_size_bytes"),
    "bootstrap_only" => true
  },
  "zig" => {
    "source_commit" => zig_metadata.fetch("commit"),
    "source_sha256" => zig_metadata.fetch("sha256"),
    "patch_sha256" => zig_receipt.dig("patch", "sha256"),
    "executable_sha256" => zig_receipt.dig("output", "executable_sha256"),
    "receipt" => zig_receipt_path
  },
  "webkit" => {
    "commit" => webkit_metadata.fetch("commit"),
    "archive_sha256" => webkit_metadata.fetch("sha256"),
    "patch_sha256" => webkit_metadata.fetch("patch_sha256")
  },
  "source_patches" => {
    "lolhtml_sha256" => source_inputs.fetch("lolhtml").fetch("patch_sha256"),
    "npm_lock_sha256" => source_inputs.fetch("npm_lock").fetch("patch_sha256"),
    "zig_build_cwd_sha256" => build_graph_metadata.fetch("patch_sha256"),
    "fedora_shared_cxx_runtime_sha256" => build_graph_metadata.fetch("cxx_runtime_patch_sha256")
  },
  "offline_inputs" => {
    "native_archives" => closure.fetch("native_github_sources").length,
    "node_header_archives" => 1,
    "npm_install_roots" => npm_install_roots.length,
    "supplemental_npm_trees" => supplemental_npm_receipt.fetch("trees"),
    "cargo_vendor_tree_sha256" => cargo_receipt.dig("vendor", "tree_sha256")
  },
  "environment" => environment.slice("BUN_BUILD_PREFETCH_DIR", "BUN_WEBKIT_PATH", "BUN_ZIG_PATH", "CARGO_HOME", "CARGO_NET_OFFLINE", "CMAKE_BUILD_PARALLEL_LEVEL", "GIT_SHA", "HOME", "RUSTC", "RUSTUP_HOME"),
  "graph" => graph_receipt,
  "network_namespace" => true,
  "jobs" => jobs,
  "source_build_performed" => false
}
Agentlab.atomic_write(File.join(workdir, "configure-proof.json"), JSON.pretty_generate(configure_receipt) + "\n")

if configure_only
  puts "Verified the network-isolated Bun first-build graph without compiling."
  puts "Configure proof: #{File.join(workdir, 'configure-proof.json')}"
  exit
end

before_resources = resource_snapshot
if available_kib(before_resources) < 20 * 1024 * 1024
  raise Agentlab::Error, "less than 20 GiB memory is available before the Bun build"
end
if available_disk_kib(before_resources) < 100 * 1024 * 1024
  raise Agentlab::Error, "less than 100 GiB is available on /srv before the Bun build"
end

build_command = ["nice", "-n", "10", "unshare", "--net", "--", "ninja", "-C", build_dir, "-j", jobs.to_s]
run!(environment, build_command, chdir: source_dir, log: File.join(workdir, "build.log"))
after_resources = resource_snapshot
%w[oom oom_kill oom_group_kill].each do |event|
  before = before_resources.fetch("memory_events", {}).fetch(event, 0)
  after = after_resources.fetch("memory_events", {}).fetch(event, 0)
  raise Agentlab::Error, "cgroup #{event} counter increased during Bun build" if after > before
end

bun_profile = File.join(build_dir, "bun-profile")
bun = File.join(build_dir, "bun")
linker_map = File.join(build_dir, "bun-profile.linker-map")
[bun_profile, bun, linker_map].each { |path| raise Agentlab::Error, "missing first-build artifact #{path}" unless File.file?(path) && File.size(path).positive? }
raise Agentlab::Error, "stripped Bun is not smaller than bun-profile" unless File.size(bun) < File.size(bun_profile)
profile_file = capture!({}, ["file", bun_profile], chdir: build_dir).strip
bun_file = capture!({}, ["file", bun], chdir: build_dir).strip
profile_sections = capture!({}, ["readelf", "--sections", "--wide", bun_profile], chdir: build_dir)
bun_sections = capture!({}, ["readelf", "--sections", "--wide", bun], chdir: build_dir)
profile_debug_sections = profile_sections.scan(/\]\s+(\.debug_[^\s]+)/).flatten.uniq.sort
bun_debug_sections = bun_sections.scan(/\]\s+(\.debug_[^\s]+)/).flatten.uniq.sort
raise Agentlab::Error, "bun-profile does not retain debug sections" if profile_debug_sections.empty?
raise Agentlab::Error, "Bun output retains debug sections: #{bun_debug_sections.join(', ')}" unless bun_debug_sections.empty?

revision = capture!(environment, ["unshare", "--net", "--", bun_profile, "--revision"], chdir: build_dir).strip
built_version = capture!(environment, ["unshare", "--net", "--", bun, "--version"], chdir: build_dir).strip
smoke = capture!(environment, ["unshare", "--net", "--", bun, "-e", "console.log('agentlab-bun-first-build')"], chdir: build_dir).strip
raise Agentlab::Error, "unexpected source-built Bun version #{built_version.inspect}" unless built_version == version
raise Agentlab::Error, "source-built Bun smoke failed" unless smoke == "agentlab-bun-first-build"

node_identity = File.join(cache_dir, "nodejs-headers-#{closure.dig('node_headers', 'version')}", ".identity")
raise Agentlab::Error, "Node header identity was not materialized" unless File.file?(node_identity) && File.read(node_identity).strip == closure.dig("node_headers", "version")
%w[openssl uv uv.h].each do |entry|
  path = File.join(File.dirname(node_identity), "include", "node", entry)
  raise Agentlab::Error, "conflicting Node header path was not removed: #{path}" if File.exist?(path) || File.symlink?(path)
end

contamination = scan_seed_contamination!([source_dir, cache_dir, build_dir], seed_binary, seed_metadata.fetch("binary_sha256"), seed_metadata.fetch("binary_size_bytes"), workdir)
ldd_output = capture!({}, ["ldd", bun], chdir: build_dir)
raise Agentlab::Error, "source-built Bun has a runtime dependency on the seed" if ldd_output.include?(seed_binary) || ldd_output.include?("bun-seed")
raise Agentlab::Error, "source-built Bun does not use Fedora's shared libstdc++" unless ldd_output.include?("libstdc++.so.6")
raise Agentlab::Error, "source-built Bun does not use Fedora's shared libgcc" unless ldd_output.include?("libgcc_s.so.1")

objects = Dir.glob(File.join(build_dir, "**", "*.o"), File::FNM_DOTMATCH).select { |path| File.file?(path) }
archives = Dir.glob(File.join(build_dir, "**", "*.a"), File::FNM_DOTMATCH).select { |path| File.file?(path) }
response_files = Dir.glob(File.join(build_dir, "**", "*.rsp"), File::FNM_DOTMATCH).select { |path| File.file?(path) }

receipt = {
  "schema" => "bun-first-source-build-proof/v1",
  "package" => "bun",
  "release" => version,
  "profile" => "release-local",
  "proof_date" => Time.now.utc.strftime("%Y-%m-%d"),
  "source_closure" => {
    "path" => File.basename(closure_path),
    "sha256" => closure_sha256,
    "source_archive_sha256" => closure.dig("source_tree", "source_sha256"),
    "source_commit" => source_commit
  },
  "bootstrap_seed" => {
    "archive_sha256" => seed_metadata.fetch("sha256"),
    "binary_sha256" => seed_metadata.fetch("binary_sha256"),
    "size_bytes" => seed_metadata.fetch("binary_size_bytes"),
    "version" => version,
    "bootstrap_only" => true,
    "final_payload_allowed" => false,
    "final_runtime_dependency_allowed" => false
  },
  "inputs" => configure_receipt.slice("zig", "webkit", "source_patches", "offline_inputs").merge(
    "npm_proof" => {
      "path" => File.basename(npm_receipt_path),
      "sha256" => npm_receipt_sha256
    },
    "cargo_proof" => {
      "path" => File.basename(cargo_receipt_path),
      "sha256" => sha256(cargo_receipt_path)
    }
  ),
  "configure" => graph_receipt.merge("network_namespace" => true, "jobs" => jobs),
  "build" => {
    "network_namespace" => true,
    "nice_level" => 10,
    "jobs" => jobs,
    "nested_cmake_jobs" => jobs,
    "cargo_jobs" => jobs,
    "bun_profile" => file_receipt(bun_profile, workdir),
    "bun" => file_receipt(bun, workdir),
    "linker_map" => file_receipt(linker_map, workdir),
    "revision" => revision,
    "version" => built_version,
    "smoke_verified" => true,
    "stripped_output_verified" => true,
    "strip_verification" => {
      "bun_profile_file" => profile_file,
      "bun_file" => bun_file,
      "bun_profile_debug_sections" => profile_debug_sections,
      "bun_debug_sections" => bun_debug_sections,
      "size_reduced" => true
    },
    "fedora_shared_cxx_runtime_verified" => true,
    "shared_runtime_libraries" => %w[libgcc_s.so.1 libstdc++.so.6]
  },
  "retained_relink_evidence" => {
    "object_files" => objects.length,
    "static_archives" => archives.length,
    "response_files" => response_files.length,
    "compile_commands_retained" => File.file?(File.join(build_dir, "compile_commands.json")),
    "build_ninja_retained" => true,
    "linker_map_retained" => true,
    "complete_lgpl_relink_materials_verified" => false
  },
  "seed_contamination" => contamination.merge(
    "payload_absent_verified" => true,
    "runtime_dependency_absent_verified" => true,
    "ldd_sha256" => Digest::SHA256.hexdigest(ldd_output)
  ),
  "resources" => {
    "before" => before_resources,
    "after" => after_resources,
    "oom_counters_unchanged" => true
  },
  "validation" => {
    "bootstrap_seed_verified" => true,
    "seed_isolated_verified" => true,
    "source_build_verified" => true,
    "self_rebuild_performed" => false,
    "reproducibility_compared" => false,
    "complete_lgpl_relink_materials_verified" => false,
    "final_license_audit_verified" => false,
    "final_rpm_verified" => false
  },
  "scope" => "first network-isolated seed-driven Bun source build only; immediate source-built self-rebuild, reproducibility, complete LGPL relink materials, immutable hosting, final license review, and RPM remain blocked"
}
Agentlab.atomic_write(output, JSON.pretty_generate(receipt) + "\n")
puts "Verified Bun #{version}'s first network-isolated seed-driven source build."
puts "Proof receipt: #{output}"
