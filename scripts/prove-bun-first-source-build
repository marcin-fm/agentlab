npm_receipt_sha256 = Digest::SHA256.hexdigest(npm_receipt_bytes)
expected_npm_receipt_sha256 = metadata.fetch("stages").fetch("dependency_closure").fetch("npm_install_proof_receipt_sha256")
raise Agentlab::Error, "npm proof receipt checksum mismatch" unless npm_receipt_sha256 == expected_npm_receipt_sha256
npm_receipt = JSON.parse(npm_receipt_bytes)

