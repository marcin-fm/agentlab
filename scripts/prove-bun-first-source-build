#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "fileutils"
require "json"
require "open3"
require "optparse"
require "pathname"
require_relative "lib/agentlab"

File.umask(0o022)

package = Agentlab.package_named("bun")
version = package.upstream.fetch("current_version").to_s
source_commit = package.upstream.fetch("source_commit").to_s
raise Agentlab::Error, "invalid Bun source commit" unless source_commit.match?(/\A[0-9a-f]{40}\z/)
package_dir = package.directory
closure_path = File.join(package_dir, "bun-#{version}-release-local-source-closure.json")
npm_receipt_path = File.join(package_dir, "npm-offline-install-proof.json")
cargo_receipt_path = File.join(package_dir, "lolhtml-offline-build-proof.json")
zig_canonical_receipt_path = File.join(package_dir, "zig-bootstrap-proof.json")
source_archive = "/srv/tmp/agentlab-bun/bun-v#{version}.tar.gz"
seed_archive = "/srv/tmp/agentlab-bun/bun-seed-#{version}-linux-x64.zip"
source_cache = "/srv/tmp/agentlab-bun/release-local-sources-#{version}"
npm_proof = "/srv/tmp/agentlab-bun-npm-offline-proof"
cargo_vendor = "/srv/tmp/agentlab-bun-lolhtml-offline-proof/cargo-vendor"
zig_root = "/srv/tmp/agentlab-bun-zig-proof/bun-zig"
zig_receipt_path = "/srv/tmp/agentlab-bun-zig-proof/proof-receipt.json"
webkit_archive = "/srv/tmp/WebKit-5488984d20e0dbfe4be2c3ba8fb18eb81a5e0e8b.tar.gz"
workdir = "/srv/tmp/agentlab-bun-first-source-build-proof"
output = File.join(package_dir, "first-source-build-proof.json")
jobs = 4
configure_only = false
resume = false
force = false

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/prove-bun-first-source-build [options]"
  parser.on("--source-archive PATH", "Checked Bun release source archive") { |path| source_archive = path }
  parser.on("--seed-archive PATH", "Checked bootstrap-only Bun seed archive") { |path| seed_archive = path }
  parser.on("--source-cache PATH", "Checked native, Node, npm, and Cargo source cache") { |path| source_cache = path }
  parser.on("--npm-proof PATH", "Marked npm offline proof directory") { |path| npm_proof = path }
  parser.on("--cargo-vendor PATH", "Verified lol-html Cargo vendor tree") { |path| cargo_vendor = path }
  parser.on("--zig-root PATH", "Verified source-built Bun Zig root") { |path| zig_root = path }
  parser.on("--zig-receipt PATH", "Receipt for the supplied Zig root") { |path| zig_receipt_path = path }
  parser.on("--webkit-archive PATH", "Checked WebKit source archive") { |path| webkit_archive = path }
  parser.on("--workdir PATH", "Proof directory below /srv/tmp") { |path| workdir = path }
  parser.on("--output PATH", "Canonical package proof receipt") { |path| output = path }
  parser.on("--jobs COUNT", Integer, "Parallel jobs, maximum 4") { |count| jobs = count }
  parser.on("--configure-only", "Prepare and inspect the isolated Ninja graph without compiling") { configure_only = true }
  parser.on("--resume", "Reuse an existing marked, configured proof tree") { resume = true }
  parser.on("--force", "Replace an existing marked proof directory") { force = true }
end.parse!

raise Agentlab::Error, "--resume and --force are mutually exclusive" if resume && force
raise Agentlab::Error, "jobs must be between 1 and 4" unless jobs.between?(1, 4)

source_archive = File.expand_path(source_archive)
seed_archive = File.expand_path(seed_archive)
source_cache = File.expand_path(source_cache)
npm_proof = File.expand_path(npm_proof)
cargo_vendor = File.expand_path(cargo_vendor)
zig_root = File.expand_path(zig_root)
zig_receipt_path = File.expand_path(zig_receipt_path)
webkit_archive = File.expand_path(webkit_archive)
workdir = File.expand_path(workdir)
output = File.expand_path(output)

raise Agentlab::Error, "proof workdir must be below /srv/tmp" unless workdir.start_with?("/srv/tmp/")
[source_archive, seed_archive, source_cache, npm_proof, cargo_vendor, zig_root, zig_receipt_path, webkit_archive].each do |path|
  if force && (path == workdir || path.start_with?("#{workdir}/"))
    raise Agentlab::Error, "proof input must be outside the replaced workdir: #{path}"
  end
end

marker = File.join(workdir, ".agentlab-bun-first-source-build-proof")
marker_content = "agentlab bun first source build proof\n"
if Dir.exist?(workdir)
  stat = File.lstat(workdir)
  raise Agentlab::Error, "refusing symlinked proof directory #{workdir}" if stat.symlink?
  raise Agentlab::Error, "refusing proof directory owned by another user" unless stat.uid == Process.uid
  raise Agentlab::Error, "proof directory path changed during validation" unless File.realpath(workdir) == workdir
  raise Agentlab::Error, "refusing unmarked proof directory #{workdir}" unless File.file?(marker) && File.read(marker) == marker_content
  unless resume || force
    raise Agentlab::Error, "proof directory exists; pass --resume or --force"
  end
elsif resume
  raise Agentlab::Error, "cannot resume missing proof directory #{workdir}"
end

def run!(environment, argv, chdir:, log: nil)
  puts "$ #{Agentlab.command_string(argv)}"
  if log
    File.open(log, "ab") do |file|
      Open3.popen2e(environment, *argv, chdir: chdir) do |stdin, stream, wait|
        stdin.close
        stream.each do |line|
          $stdout.write(line)
          file.write(line)
        end
        raise Agentlab::Error, "command failed: #{Agentlab.command_string(argv)}" unless wait.value.success?
      end
    end
  elsif !system(environment, *argv, chdir: chdir)
    raise Agentlab::Error, "command failed: #{Agentlab.command_string(argv)}"
  end
end

def capture!(environment, argv, chdir:, success: [0])
  stdout, stderr, status = Open3.capture3(environment, *argv, chdir: chdir)
  unless success.include?(status.exitstatus)
    raise Agentlab::Error, "command failed: #{Agentlab.command_string(argv)}: #{stderr.strip}"
  end

  stdout
end

def sha256(path)
  Digest::SHA256.file(path).hexdigest
end

def verify_file!(path, expected_sha256, label)
  raise Agentlab::Error, "missing #{label}: #{path}" unless File.file?(path)
  actual = sha256(path)
  raise Agentlab::Error, "#{label} SHA-256 #{actual} does not match #{expected_sha256}" unless actual == expected_sha256
end

def safe_relative_path(path)
  pathname = Pathname(path)
  clean = pathname.cleanpath.to_s
  return nil if pathname.absolute? || clean == ".." || clean.start_with?("../")

  clean
end

def extract_single_root_tar!(archive, destination, expected_root, workdir)
  entries = capture!({}, ["tar", "--list", "--gzip", "--file", archive], chdir: workdir).lines.map(&:strip).reject(&:empty?)
  roots = entries.map do |entry|
    path = safe_relative_path(entry.delete_suffix("/"))
    raise Agentlab::Error, "unsafe archive path in #{archive}: #{entry}" unless path

    path.split("/", 2).first
  end.uniq
  raise Agentlab::Error, "archive root mismatch for #{archive}: #{roots.inspect}" unless roots == [expected_root]

  FileUtils.mkdir_p(destination)
  run!({}, ["tar", "--extract", "--gzip", "--file", archive, "--directory", destination, "--no-same-owner", "--no-same-permissions"], chdir: workdir)
end

def extract_bun_source!(archive, destination, workdir)
  entries = capture!({}, ["tar", "--list", "--gzip", "--file", archive], chdir: workdir).lines.map(&:strip).reject(&:empty?)
  roots = entries.map do |entry|
    path = safe_relative_path(entry.delete_suffix("/"))
    raise Agentlab::Error, "unsafe Bun source archive path: #{entry}" unless path

    path.split("/", 2).first
  end.uniq
  raise Agentlab::Error, "Bun source archive must contain one root" unless roots.length == 1

  FileUtils.mkdir_p(destination)
  run!({}, ["tar", "--extract", "--gzip", "--file", archive, "--directory", destination, "--strip-components=1", "--no-same-owner", "--no-same-permissions"], chdir: workdir)
end

def extract_zip_member!(archive, member, output, workdir)
  File.open(output, "wb") do |file|
    Open3.popen3("unzip", "-p", archive, member, chdir: workdir) do |stdin, stdout, stderr, wait|
      stdin.close
      IO.copy_stream(stdout, file)
      error = stderr.read
      raise Agentlab::Error, "cannot extract #{member}: #{error.strip}" unless wait.value.success?
    end
  end
end

def tree_receipt(root)
  entries = []
  Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).sort.each do |path|
    relative = path.delete_prefix("#{root}/")
    next if relative.empty? || [".", ".."].include?(File.basename(path))

    stat = File.lstat(path)
    if stat.symlink?
      target = File.readlink(path)
      raise Agentlab::Error, "absolute symlink in proof tree: #{relative}" if Pathname(target).absolute?
      entries << ["link", relative, target]
    elsif stat.file?
      entries << ["file", relative, format("%04o", stat.mode & 0o7777), stat.size, sha256(path)]
    elsif stat.directory?
      entries << ["directory", relative, format("%04o", stat.mode & 0o7777)]
    else
      raise Agentlab::Error, "unsupported proof-tree entry: #{relative}"
    end
  end
  serialized = entries.map { |entry| JSON.generate(entry) }.join("\n") + "\n"
  {
    "entries" => entries.length,
    "files" => entries.count { |entry| entry.fetch(0) == "file" },
    "directories" => entries.count { |entry| entry.fetch(0) == "directory" },
    "symlinks" => entries.count { |entry| entry.fetch(0) == "link" },
    "file_bytes" => entries.sum { |entry| entry.fetch(0) == "file" ? entry.fetch(3) : 0 },
    "sha256" => Digest::SHA256.hexdigest(serialized)
  }
end

def vendor_tree_digest(root)
  digest = Digest::SHA256.new
  Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).sort.each do |path|
    next unless File.file?(path) && !File.symlink?(path)
    next if [".", ".."].include?(File.basename(path))

    digest.update(path.delete_prefix("#{root}/"))
    digest.update("\0")
    digest.update(sha256(path))
    digest.update("\0")
  end
  digest.hexdigest
end

def assert_seed_absent!(root, seed_sha256, seed_size)
  Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).sort.each do |path|
    next if [".", ".."].include?(File.basename(path))

    if File.symlink?(path)
      target = File.readlink(path)
      raise Agentlab::Error, "seed path leaked into symlink #{path}" if target.include?("bun-seed")
    elsif File.file?(path) && File.size(path) == seed_size && sha256(path) == seed_sha256
      raise Agentlab::Error, "seed binary copied into proof tree: #{path}"
    end
  end
end

def copy_tree!(source, destination)
  raise Agentlab::Error, "missing source tree #{source}" unless Dir.exist?(source)
  raise Agentlab::Error, "destination already exists #{destination}" if File.exist?(destination) || File.symlink?(destination)

  FileUtils.mkdir_p(File.dirname(destination))
  FileUtils.cp_r(source, destination, preserve: true, dereference_root: false)
end

def path_within?(path, root)
  expanded_path = File.expand_path(path)
  expanded_root = File.expand_path(root)
  expanded_path == expanded_root || expanded_path.start_with?("#{expanded_root}/")
end

def supplemental_npm_trees(npm_source_dir, install_roots)
  trees = {}
  install_roots.each do |root|
    install_root = File.expand_path(root.fetch("path"), npm_source_dir)
    node_modules = File.join(install_root, "node_modules")
    root.fetch("required_artifacts_verified").each do |artifact|
      artifact_path = File.join(node_modules, artifact)
      raise Agentlab::Error, "reusable npm artifact missing: #{root.fetch('path')}:#{artifact}" unless File.exist?(artifact_path) || File.symlink?(artifact_path)

      resolved = File.realpath(artifact_path)
      next if path_within?(resolved, node_modules)
      raise Agentlab::Error, "npm artifact resolves outside the checked proof source: #{artifact_path}" unless path_within?(resolved, npm_source_dir)

      external_node_modules = nil
      Pathname(File.dirname(artifact_path)).ascend do |path|
        break unless path_within?(path.to_s, npm_source_dir)
        next unless path.basename.to_s == "node_modules"

        resolved_node_modules = Pathname(File.realpath(path.to_s))
        next if path_within?(resolved_node_modules.to_s, node_modules)

        external_node_modules = resolved_node_modules
        break
      end
      next unless external_node_modules
      raise Agentlab::Error, "supplemental npm tree resolves outside the checked proof source: #{artifact_path}" unless path_within?(external_node_modules.to_s, npm_source_dir)

      relative = external_node_modules.relative_path_from(Pathname(npm_source_dir)).to_s
      trees[relative] ||= tree_receipt(external_node_modules.to_s)
    end
  end
  trees.sort.to_h
end

def file_receipt(path, base)
  {
    "path" => path.delete_prefix("#{base}/"),
    "size_bytes" => File.size(path),
    "sha256" => sha256(path)
  }
end

def resource_snapshot
  meminfo = File.readlines("/proc/meminfo", chomp: true).to_h do |line|
    key, value = line.split(":", 2)
    [key, value.to_s.strip]
  end
  cgroup_relative = File.readlines("/proc/self/cgroup", chomp: true).find { |line| line.start_with?("0::") }&.split("::", 2)&.last || "/"
  cgroup = File.join("/sys/fs/cgroup", cgroup_relative.delete_prefix("/"))
  events_path = File.join(cgroup, "memory.events")
  events = if File.file?(events_path)
             File.readlines(events_path, chomp: true).to_h { |line| key, value = line.split; [key, value.to_i] }
           else
             {}
           end
  {
    "mem_available" => meminfo["MemAvailable"],
    "swap_free" => meminfo["SwapFree"],
    "memory_pressure" => File.file?("/proc/pressure/memory") ? File.read("/proc/pressure/memory").strip : nil,
    "cgroup" => cgroup,
    "memory_current" => File.file?(File.join(cgroup, "memory.current")) ? File.read(File.join(cgroup, "memory.current")).strip : nil,
    "memory_max" => File.file?(File.join(cgroup, "memory.max")) ? File.read(File.join(cgroup, "memory.max")).strip : nil,
    "memory_events" => events,
    "disk" => capture!({}, ["df", "-Pk", "/srv"], chdir: "/srv").lines.last.to_s.strip
  }
end

def available_kib(snapshot)
  snapshot.fetch("mem_available").to_s.split.first.to_i
end

def available_disk_kib(snapshot)
  snapshot.fetch("disk").split.fetch(3).to_i
end

def stamp_path(build_dir, package_dir)
  normalized = File.expand_path(package_dir)
  File.join(build_dir, "stamps", "install_#{normalized.gsub(/[^A-Za-z0-9]+/, '_')}.stamp")
end

def replace_bun_install_rule!(ninja_path, seed_binary, receipt_path)
  original_command = "  command = cd \$dir && #{seed_binary} install --frozen-lockfile && touch \$stamp"
  replacement_command = "  command = /usr/bin/test -f \$stamp"
  original_description = "  description = install \$dir"
  replacement_description = "  description = verify prevalidated install \$dir"
  ninja = File.read(ninja_path)

  if ninja.include?(original_command)
    raise Agentlab::Error, "unexpected number of generated bun_install commands" unless ninja.scan(Regexp.new(Regexp.escape(original_command))).length == 1
    raise Agentlab::Error, "unexpected number of generated bun_install descriptions" unless ninja.scan(Regexp.new(Regexp.escape(original_description))).length == 1

    original_sha256 = Digest::SHA256.hexdigest(ninja)
    ninja = ninja.sub(original_command, replacement_command).sub(original_description, replacement_description)
    Agentlab.atomic_write(ninja_path, ninja)
    receipt = {
      "schema" => "bun-prevalidated-install-rule-bypass/v1",
      "original_build_ninja_sha256" => original_sha256,
      "patched_build_ninja_sha256" => sha256(ninja_path),
      "original_command" => original_command.strip,
      "replacement_command" => replacement_command.strip,
      "scope" => "generated Ninja bun_install rule only; three prevalidated materialized node_modules trees"
    }
    Agentlab.atomic_write(receipt_path, JSON.pretty_generate(receipt) + "\n")
    return receipt
  end

  unless ninja.include?(replacement_command) && File.file?(receipt_path)
    raise Agentlab::Error, "generated Ninja graph has neither the expected install rule nor its checked bypass"
  end

  receipt = JSON.parse(File.read(receipt_path))
  unless receipt.fetch("replacement_command") == replacement_command.strip &&
         receipt.fetch("patched_build_ninja_sha256") == sha256(ninja_path)
    raise Agentlab::Error, "checked npm install-rule bypass receipt does not match build.ninja"
  end
  receipt
end

def inspect_graph!(ninja_path, configure_path, source_dir, build_dir, cache_dir, webkit_dir, zig_dir, seed_binary, install_roots, native_sources, node_headers)
  raise Agentlab::Error, "missing generated Ninja graph #{ninja_path}" unless File.file?(ninja_path)
  raise Agentlab::Error, "missing configure record #{configure_path}" unless File.file?(configure_path)
  ninja = File.read(ninja_path)
  logical_ninja = ninja.gsub(/\$\n[ \t]*/, " ")
  logical_lines = logical_ninja.lines
  configure = JSON.parse(File.read(configure_path))
  unless configure == {
    "buildType" => "Release",
    "webkit" => "local",
    "lto" => false,
    "buildDir" => build_dir,
    "cacheDir" => cache_dir
  }
    raise Agentlab::Error, "configure.json does not record the exact release-local proof configuration"
  end

  install_edges = logical_lines.grep(/: bun_install(?:\s|$)/)
  raise Agentlab::Error, "expected three bun_install edges, found #{install_edges.length}" unless install_edges.length == 3
  raise Agentlab::Error, "generated graph still contains a live Bun package-manager install" if ninja.include?(" install --frozen-lockfile")
  raise Agentlab::Error, "generated graph lacks the checked prevalidated-install rule" unless ninja.include?("command = /usr/bin/test -f $stamp")

  seed_rules = []
  current_rule = nil
  ninja.lines.each do |line|
    current_rule = line.split.fetch(1) if line.start_with?("rule ")
    next unless line.start_with?("  command = ") && line.include?(seed_binary)

    raise Agentlab::Error, "bootstrap seed command is not attached to a named Ninja rule" unless current_rule
    seed_rules << current_rule
  end
  expected_seed_rules = %w[codegen dep_build dep_cargo dep_cargo_cross dep_codegen dep_configure dep_fetch dep_fetch_prebuilt dep_prebuild dep_subst link regen smoke_test zig_build zig_check zig_fetch]
  raise Agentlab::Error, "bootstrap seed Ninja rule scope changed: #{seed_rules.sort.join(', ')}" unless seed_rules.sort == expected_seed_rules.sort
  raise Agentlab::Error, "bootstrap seed appears in a Ninja build edge" if logical_lines.any? { |line| line.start_with?("build ") && line.include?(seed_binary) }
  raise Agentlab::Error, "generated graph activates the cross-target rustup Cargo rule" if logical_lines.any? { |line| line.match?(/: dep_cargo_cross(?:\s|$)/) }
  expected_stamps = install_roots.map { |root| stamp_path(build_dir, File.join(source_dir, root.fetch("path"))) }.sort
  unless expected_stamps.all? { |stamp| File.file?(stamp) }
    raise Agentlab::Error, "one or more prevalidated npm install stamps are missing"
  end
  expected_stamps.each do |stamp|
    raise Agentlab::Error, "Ninja graph does not contain install stamp #{stamp}" unless ninja.include?(stamp)
  end

  native_edges = logical_lines.grep(/\.ref(?:\s+\|[^:]*)?\s*:\s*dep_fetch(?:\s|$)/)
  raise Agentlab::Error, "expected 19 native dep_fetch edges, found #{native_edges.length}" unless native_edges.length == native_sources.length && native_sources.length == 19
  native_sources.each do |record|
    raise Agentlab::Error, "Ninja graph omits native source #{record.fetch('name')}" unless ninja.include?("name = #{record.fetch('name')}")
    raise Agentlab::Error, "Ninja graph omits native commit #{record.fetch('commit')}" unless ninja.include?("commit = #{record.fetch('commit')}")
  end
  raise Agentlab::Error, "Ninja graph does not use the controlled native cache" unless ninja.include?(File.join(cache_dir, "tarballs"))

  node_identity = File.join(cache_dir, "nodejs-headers-#{node_headers.fetch('version')}", ".identity")
  node_identity_graph_path = Pathname(node_identity).relative_path_from(Pathname(build_dir)).to_s
  node_edges = logical_lines.grep(/: dep_fetch_prebuilt(?:\s|$)/).select { |line| line.include?(node_identity_graph_path) }
  raise Agentlab::Error, "expected one controlled Node-header fetch edge" unless node_edges.length == 1
  raise Agentlab::Error, "Ninja graph has an unexpected prebuilt URL" unless logical_lines.grep(/^\s*url = /).map { |line| line.split("=", 2).last.strip }.uniq == [node_headers.fetch("url")]

  raise Agentlab::Error, "Ninja graph contains a Zig fetch edge" if logical_lines.any? { |line| line.match?(/^build .*: zig_fetch(?:\s|$)/) }
  raise Agentlab::Error, "Ninja graph does not bind to the verified Zig root" unless ninja.include?(File.join(zig_dir, "zig"))
  zig_cwd = "--cwd=#{source_dir}"
  raise Agentlab::Error, "Ninja graph does not bind both Zig rules to the Bun source root" unless ninja.scan(zig_cwd).length == 2
  raise Agentlab::Error, "Ninja graph still requests static GNU C++ runtimes" if ninja.include?("-static-libstdc++") || ninja.include?("-static-libgcc")
  raise Agentlab::Error, "Ninja graph does not link Fedora's shared C++ runtime" unless ninja.include?("-lstdc++ -lgcc_s")

  unless ninja.include?(webkit_dir) && ninja.include?(File.join(build_dir, "deps", "WebKit")) && logical_lines.any? { |line| line.match?(/: dep_configure(?:\s|$)/) && line.include?("WebKit") }
    raise Agentlab::Error, "Ninja graph does not configure the supplied local WebKit source"
  end
  if ninja.include?("github.com/oven-sh/WebKit/releases/download")
    raise Agentlab::Error, "Ninja graph contains a prebuilt WebKit download"
  end

  lolhtml_edges = logical_lines.grep(/: dep_cargo(?:\s|$)/).select { |line| line.include?("lolhtml") }
  raise Agentlab::Error, "expected one lol-html Cargo edge" unless lolhtml_edges.length == 1
  lolhtml_index = logical_lines.index(lolhtml_edges.first)
  lolhtml_context = logical_lines[lolhtml_index, 6].join
  %w[--locked --release -Cpanic=abort -Cdebuginfo=0 -Cforce-unwind-tables=no -Copt-level=s].each do |token|
    raise Agentlab::Error, "lol-html Ninja edge omits #{token}" unless lolhtml_context.include?(token)
  end
  raise Agentlab::Error, "lol-html Ninja edge still uses -Zbuild-std" if lolhtml_context.include?("-Zbuild-std")

  {
    "profile" => "release-local",
    "configure_json_sha256" => sha256(configure_path),
    "build_ninja_sha256" => sha256(ninja_path),
    "install_edges" => install_edges.length,
    "prevalidated_install_stamps" => expected_stamps.map { |path| path.delete_prefix("#{build_dir}/") },
    "native_fetch_edges" => native_edges.length,
    "node_header_fetch_edges" => node_edges.length,
    "prepared_inputs_revalidated" => true,
    "bootstrap_seed_rule_scope_verified" => true,
    "bootstrap_seed_rules" => seed_rules.sort,
    "local_webkit_verified" => true,
    "zig_fetch_absent" => true,
    "zig_source_cwd_verified" => true,
    "fedora_shared_cxx_runtime_verified" => true,
    "stable_lolhtml_cargo_verified" => true,
    "unexpected_urls_absent" => true
  }
end

def scan_seed_contamination!(roots, seed_path, seed_sha256, seed_size, workdir)
  allowed = Dir.glob(File.join(workdir, "build", "**", "{build.ninja,configure.json}")) + [
    File.join(workdir, "configure.log"),
    File.join(workdir, "build.log"),
    File.join(workdir, "configure-proof.json")
  ].select { |path| File.exist?(path) }.map { |path| File.realpath(path) }

  hash_matches = []
  roots.each do |root|
    Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).sort.each do |path|
      next unless File.file?(path) && !File.symlink?(path)
      next if allowed.include?(File.realpath(path))
      next unless File.size(path) == seed_size

      hash_matches << path if sha256(path) == seed_sha256
    end
  end
  raise Agentlab::Error, "bootstrap seed binary copied into build tree: #{hash_matches.join(', ')}" unless hash_matches.empty?

  patterns = [seed_path, "bun-seed", seed_sha256]
  path_matches = []
  patterns.each do |pattern|
    argv = ["rg", "-a", "-l", "--fixed-strings", "--glob", "!build.ninja", "--glob", "!configure.json", "--glob", "!*.log", "--glob", "!configure-proof.json", pattern, *roots]
    path_matches.concat(capture!({}, argv, chdir: workdir, success: [0, 1]).lines.map(&:strip).reject(&:empty?))
  end
  path_matches.uniq!
  raise Agentlab::Error, "bootstrap seed identity leaked into source/cache/build artifacts: #{path_matches.join(', ')}" unless path_matches.empty?

  {
    "roots" => roots.map { |root| root.delete_prefix("#{workdir}/") },
    "allowed_control_metadata" => allowed.map { |path| path.delete_prefix("#{workdir}/") },
    "same_size_files_hashed" => roots.sum do |root|
      Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).count { |path| File.file?(path) && !File.symlink?(path) && File.size(path) == seed_size }
    end,
    "seed_hash_matches" => 0,
    "seed_identity_text_matches" => 0
  }
end

metadata = package.data.fetch("build_plan")
source_inputs = metadata.fetch("source_inputs")
seed_metadata = source_inputs.fetch("bootstrap_seed")
zig_metadata = source_inputs.fetch("zig")
webkit_metadata = source_inputs.fetch("webkit")
build_graph_metadata = source_inputs.fetch("build_graph")
raise Agentlab::Error, "Bun seed is not bootstrap-only" unless seed_metadata.fetch("bootstrap_only") == true
raise Agentlab::Error, "Bun seed is allowed in the final payload" unless seed_metadata.fetch("final_payload_allowed") == false
raise Agentlab::Error, "Bun seed is allowed as a final runtime dependency" unless seed_metadata.fetch("final_runtime_dependency_allowed") == false

closure_bytes = File.binread(closure_path)
