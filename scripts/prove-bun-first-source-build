    FileUtils.cp(archive, cached, preserve: true)
    verify_file!(cached, record.fetch("sha256"), "cached native archive #{record.fetch('name')}")
    prefetched = File.join(by_url, Digest::SHA256.hexdigest(record.fetch("url"))[0, 32])
    FileUtils.cp(archive, prefetched, preserve: true)
    verify_file!(prefetched, record.fetch("sha256"), "prefetched native archive #{record.fetch('name')}")
