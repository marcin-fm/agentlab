raise Agentlab::Error, "missing checked source cache #{source_cache}" unless Dir.exist?(source_cache)
raise Agentlab::Error, "missing marked npm proof #{npm_proof}" unless File.read(File.join(npm_proof, ".agentlab-bun-npm-offline-proof")) == "agentlab bun npm offline proof\n"
raise Agentlab::Error, "missing Cargo vendor tree #{cargo_vendor}" unless Dir.exist?(cargo_vendor)
