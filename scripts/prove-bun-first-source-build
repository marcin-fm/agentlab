       zig_receipt.dig("source", "commit") == zig_metadata.fetch("commit") &&
       zig_receipt.dig("source", "sha256") == zig_metadata.fetch("sha256") &&
       zig_receipt.dig("patch", "path") == zig_metadata.fetch("patch") &&
       zig_receipt.dig("patch", "sha256") == zig_canonical_receipt.dig("patch", "sha256") &&
       zig_receipt.dig("output", "version") == zig_metadata.fetch("version_metadata") &&
       zig_receipt.dig("output", "bun_layout_verified") == true &&
       zig_receipt.dig("output", "source_execution_verified") == true &&
       zig_receipt.dig("output", "external_zig_binary_used") == false
  raise Agentlab::Error, "supplied Zig proof does not match the pinned Bun source-bootstrap identity"
end
verify_file!(File.join(zig_root, "zig"), zig_receipt.dig("output", "executable_sha256"), "source-built Zig executable")
raise Agentlab::Error, "source-built Zig standard library is missing" unless File.file?(File.join(zig_root, "lib", "std", "std.zig"))

