#!/usr/bin/env ruby
# frozen_string_literal: true

require "base64"
require "digest"
require "fileutils"
require "find"
require "json"
require "optparse"
require "pathname"
require "tmpdir"
require "uri"
require_relative "lib/agentlab"

package = Agentlab.package_named("mermaid-cli")
dependencies = Agentlab.load_yaml(File.join(package.directory, "dependencies.yml"))
version = package.upstream.fetch("current_version")
source_path = nil
workdir = "/srv/tmp/agentlab-mermaid-cli/closure-build"
output_dir = "/srv/tmp/agentlab-mermaid-cli/closure-output"
force = false

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/build-mermaid-cli-closure [options]"
  parser.on("--source PATH", "Use an existing Mermaid CLI release archive") { |path| source_path = path }
  parser.on("--workdir PATH", "Working directory below /srv/tmp") { |path| workdir = path }
  parser.on("--output-dir PATH", "Output directory below /srv/tmp") { |path| output_dir = path }
  parser.on("--force", "Replace marked work and output directories") { force = true }
end.parse!

def require_tmp_path(path, label)
  expanded = File.expand_path(path)
  raise Agentlab::Error, "#{label} must be below /srv/tmp" unless expanded.start_with?("/srv/tmp/")

  expanded
end

def prepare_directory(path, marker_name, force)
  marker = File.join(path, marker_name)
  if Dir.exist?(path)
    raise Agentlab::Error, "#{path} exists; pass --force to replace it" unless force
    raise Agentlab::Error, "refusing to replace unmarked directory #{path}" unless File.file?(marker)
    FileUtils.rm_rf(path)
  end
  FileUtils.mkdir_p(path)
  File.write(marker, "agentlab mermaid-cli closure\n")
end

def run!(environment, argv, chdir:)
  puts "$ #{Agentlab.command_string(argv)}"
  return if system(environment, *argv, chdir: chdir)

  raise Agentlab::Error, "command failed: #{Agentlab.command_string(argv)}"
end

def safe_archive_name(name, version, sha256)
  normalized = name.delete_prefix("@").tr("/", "--")
  "#{normalized}-#{version}--sha256-#{sha256}.tgz"
end

def verify_integrity!(bytes, integrity, name)
  algorithm, encoded = integrity.to_s.split("-", 2)
  digest = case algorithm
           when "sha512" then Digest::SHA512.digest(bytes)
           when "sha1" then Digest::SHA1.digest(bytes)
           else
             raise Agentlab::Error, "#{name}: unsupported registry integrity algorithm #{algorithm.inspect}"
           end
  raise Agentlab::Error, "#{name}: malformed registry integrity" unless encoded

  actual = Base64.strict_encode64(digest)
  raise Agentlab::Error, "#{name}: registry integrity mismatch" unless actual == encoded
end

def verified_download(record, label)
  url = record.fetch("source_url")
  sha256 = record.fetch("sha256")
  uri = URI(url)
  raise Agentlab::Error, "#{label}: source URL must use HTTPS" unless uri.is_a?(URI::HTTPS)
  raise Agentlab::Error, "#{label}: invalid SHA-256" unless sha256.match?(/\A[0-9a-f]{64}\z/)

  bytes = Agentlab.download(url)
  actual = Digest::SHA256.hexdigest(bytes)
  raise Agentlab::Error, "#{label}: SHA-256 #{actual} does not match #{sha256}" unless actual == sha256

  bytes
end

def forbidden_payload?(path, header)
  forbidden_suffixes = %w[.node .so .dylib .dll .exe .a .o .obj .lib .wasm]
  magic = {
    "\x7FELF".b => "ELF",
    "MZ".b => "PE",
    "\x00asm".b => "WASM",
    "!<arch>\n".b => "static archive"
  }
  suffix = forbidden_suffixes.find { |candidate| path.end_with?(candidate) }
  identified = magic.find { |signature, _label| header.start_with?(signature) }
  [suffix, identified&.last]
end

def executable_source?(path, header)
  source_suffixes = %w[.js .mjs .cjs .ts .tsx .jsx .sh .py .rb .pl .css .html .json .md]
  basename = File.basename(path)
  documentation = basename.match?(/\A(?:licen[cs]e|copying|notice|copyright|readme)(?:[._-].*)?\z/i)
  source_suffixes.any? { |suffix| path.end_with?(suffix) } || documentation || header.start_with?("#!")
end

def forbidden_tree_entries(root)
  findings = []
  expanded_root = File.expand_path(root)

  Find.find(expanded_root) do |entry|
    stat = File.lstat(entry)
    relative = entry.delete_prefix("#{expanded_root}/")
    next if relative.empty?

    if stat.symlink?
      target = File.expand_path(File.readlink(entry), File.dirname(entry))
      findings << "#{entry}: symlink escapes source root" unless target.start_with?("#{expanded_root}/")
      next
    end
    next if stat.directory?
    unless stat.file?
      findings << "#{entry}: special file type #{stat.ftype}"
      next
    end

    header = File.binread(entry, 8) || "".b
    suffix, format = forbidden_payload?(relative, header)
    findings << "#{entry}: forbidden suffix #{suffix}" if suffix
    findings << "#{entry}: forbidden #{format} payload" if format
    if stat.executable? && !executable_source?(relative, header)
      findings << "#{entry}: unreviewed executable source payload"
    end
  rescue EOFError
    next
  end
  findings
end

def forbidden_tarball_entries(archive_path, label, scan_parent)
  findings = []
  listing, listing_error, listing_status = Agentlab.capture(["tar", "-tzf", archive_path])
  raise Agentlab::Error, "#{label}: cannot list source archive: #{listing_error}" unless listing_status.success?
  listing.each_line do |entry|
    path = entry.strip
    clean = Pathname(path).cleanpath.to_s
    if Pathname(path).absolute? || clean == ".." || clean.start_with?("../")
      findings << "#{label}: archive path escapes source root: #{path}"
    end
  end

  verbose, verbose_error, verbose_status = Agentlab.capture(["tar", "-tvzf", archive_path])
  raise Agentlab::Error, "#{label}: cannot inspect source archive: #{verbose_error}" unless verbose_status.success?
  verbose.each_line do |entry|
    findings << "#{label}: source archive contains a special file: #{entry.strip}" if entry.match?(/\A[bcps]/)
  end

  Dir.mktmpdir("npm-scan-", scan_parent) do |scan_root|
    extracted = system(
      "tar", "-xzf", archive_path, "-C", scan_root,
      "--no-same-owner", "--no-same-permissions", "--delay-directory-restore"
    )
    raise Agentlab::Error, "#{label}: cannot extract source archive for inspection" unless extracted

    findings.concat(forbidden_tree_entries(scan_root).map { |finding| "#{label}: #{finding}" })
  end
  findings
end

def package_license_files(package_root)
  files = []
  root = File.realpath(package_root)
  Find.find(root) do |entry|
    stat = File.lstat(entry)
    relative = Pathname(entry).relative_path_from(Pathname(root)).to_s
    next if relative == "."

    if stat.directory?
      Find.prune if File.basename(entry) == "node_modules"
      next
    end
    next unless stat.file?

    basename = File.basename(entry)
    files << [relative, entry] if basename.match?(/\A(?:licen[cs]e|copying|notice|copyright)(?:[._-].*)?\z/i)
  end
  files.sort_by(&:first)
end

def package_root_for(source_root, package_path)
  source = File.realpath(source_root)
  candidate = File.expand_path(package_path, source)
  unless candidate.start_with?("#{source}/")
    raise Agentlab::Error, "package path escapes source root: #{package_path}"
  end

  resolved = File.realpath(candidate)
  unless resolved.start_with?("#{source}/")
    raise Agentlab::Error, "package path resolves outside source root: #{package_path}"
  end

  resolved
end

def supplemental_notice_content(record, manifest_entries)
  id = record.fetch("id")
  packages = record.fetch("packages")
  unless packages.is_a?(Array) && !packages.empty?
    raise Agentlab::Error, "#{id}: packages must be a nonempty array"
  end
  packages.each do |target|
    name = target.fetch("npm_name")
    version = target.fetch("version").to_s
    unless manifest_entries.any? { |entry| entry["npm_name"] == name && entry["version"] == version }
      raise Agentlab::Error, "#{id}: supplemental notice targets absent package #{name}@#{version}"
    end
  end

  bytes = verified_download(record, id)
  if record["evidence_url"] || record["evidence_sha256"]
    unless record["evidence_url"] && record["evidence_sha256"]
      raise Agentlab::Error, "#{id}: evidence URL and SHA-256 must be recorded together"
    end
    verified_download(
      { "source_url" => record.fetch("evidence_url"), "sha256" => record.fetch("evidence_sha256") },
      "#{id} evidence"
    )
  end

  if record["start_line"] || record["end_line"]
    start_line = Integer(record.fetch("start_line"))
    end_line = Integer(record.fetch("end_line"))
    raise Agentlab::Error, "#{id}: invalid line range" unless start_line.positive? && end_line >= start_line

    lines = bytes.lines
    raise Agentlab::Error, "#{id}: line range exceeds source" if end_line > lines.length
    bytes = lines[(start_line - 1)...end_line].join
  end

  [id, packages, bytes]
end

workdir = require_tmp_path(workdir, "workdir")
output_dir = require_tmp_path(output_dir, "output directory")
source_path = File.expand_path(source_path) if source_path
if force && source_path && (source_path.start_with?("#{workdir}/") || source_path.start_with?("#{output_dir}/"))
  raise Agentlab::Error, "source archive must be outside replaced directories"
end

prepare_directory(workdir, ".agentlab-mermaid-cli-closure", force)
prepare_directory(output_dir, ".agentlab-mermaid-cli-closure-output", force)

source_path ||= File.join(workdir, "mermaid-cli-#{version}.tar.gz")
unless File.file?(source_path)
  File.binwrite(source_path, Agentlab.download(Agentlab.source_url(package, version)))
end
actual_source_sha = Digest::SHA256.file(source_path).hexdigest
unless actual_source_sha == package.upstream.fetch("source_sha256")
  raise Agentlab::Error, "source SHA-256 #{actual_source_sha} does not match package metadata"
end

source_parent = File.join(workdir, "source")
FileUtils.mkdir_p(source_parent)
run!({}, ["tar", "-xf", source_path, "-C", source_parent], chdir: Agentlab::ROOT)
source_roots = Dir.glob(File.join(source_parent, "mermaid-cli-*")).select { |path| File.directory?(path) }
raise Agentlab::Error, "expected one extracted Mermaid CLI source directory" unless source_roots.length == 1

source_root = source_roots.fetch(0)
package_json_path = File.join(source_root, "package.json")
package_json = JSON.parse(File.read(package_json_path))
original_lock_path = File.join(source_root, "package-lock.json")
raise Agentlab::Error, "published release is missing package-lock.json" unless File.file?(original_lock_path)

original_lock_bytes = File.binread(original_lock_path)
original_lock = JSON.parse(original_lock_bytes)
declared_package_manager = package_json.fetch("packageManager")
puppeteer_version = dependencies.dig("runtime_adjustments", "puppeteer", "version").to_s
raise Agentlab::Error, "missing exact Puppeteer runtime version" unless puppeteer_version.match?(/\A\d+\.\d+\.\d+\z/)

package_json.fetch("dependencies")["puppeteer"] = puppeteer_version
package_json.delete("devDependencies")
File.write(package_json_path, JSON.pretty_generate(package_json) + "\n")

environment = {
  "HOME" => File.join(workdir, "home"),
  "npm_config_cache" => File.join(workdir, "npm-cache"),
  "PUPPETEER_SKIP_DOWNLOAD" => "true"
}
FileUtils.mkdir_p(environment.values_at("HOME", "npm_config_cache"))
npm_stdout, npm_stderr, npm_status = Agentlab.capture(["npm", "--version"], chdir: source_root)
raise Agentlab::Error, "cannot determine npm version: #{npm_stderr}" unless npm_status.success?

npm_version = npm_stdout.strip
expected_npm_version = dependencies.dig("lockfile", "generator_npm_version").to_s
unless npm_version == expected_npm_version
  raise Agentlab::Error, "npm version #{npm_version} does not match audited generator #{expected_npm_version}"
end
run!(environment, ["npm", "install", "--package-lock-only", "--omit=dev", "--ignore-scripts"], chdir: source_root)
run!(environment, ["npm", "ci", "--omit=dev", "--ignore-scripts"], chdir: source_root)

runtime_lock_path = File.join(source_root, "package-lock.json")
runtime_lock_bytes = File.binread(runtime_lock_path)
runtime_lock = JSON.parse(runtime_lock_bytes)
published_lock_sha256 = Digest::SHA256.hexdigest(original_lock_bytes)
runtime_lock_sha256 = Digest::SHA256.hexdigest(runtime_lock_bytes)
unless published_lock_sha256 == dependencies.dig("lockfile", "published_sha256")
  raise Agentlab::Error, "published lock SHA-256 does not match audited metadata"
end
unless runtime_lock_sha256 == dependencies.dig("lockfile", "runtime_sha256")
  raise Agentlab::Error, "runtime lock SHA-256 does not match audited metadata"
end
original_packages = original_lock.fetch("packages")
runtime_lock.fetch("packages").each do |path, entry|
  next if path.empty?

  original = original_packages[path]
  raise Agentlab::Error, "runtime lock added an unreviewed package path #{path}" unless original
  %w[version resolved integrity].each do |field|
    next if entry[field] == original[field]

    raise Agentlab::Error, "runtime lock changed #{path} #{field} from the published lockfile"
  end
end

node_modules = File.join(source_root, "node_modules")
raise Agentlab::Error, "npm did not materialize node_modules" unless Dir.exist?(node_modules)
raise Agentlab::Error, "Puppeteer runtime is missing" unless File.file?(File.join(node_modules, "puppeteer", "package.json"))

native_findings = forbidden_tree_entries(node_modules)
unless native_findings.empty?
  raise Agentlab::Error, "forbidden native payloads found:\n#{native_findings.join("\n")}"
end

lock = JSON.parse(File.read(File.join(node_modules, ".package-lock.json")))
lock_packages = lock.fetch("packages")
license_overrides = dependencies.fetch("license_overrides", {})
source_dir = File.join(workdir, "npm-sources")
scan_dir = File.join(workdir, "npm-scan")
FileUtils.mkdir_p(source_dir)
FileUtils.mkdir_p(scan_dir)
manifest_entries = []
source_archives = {}

lock_packages.keys.sort.each do |package_path|
  next if package_path.empty?

  entry = lock_packages.fetch(package_path)
  installed_path = File.join(source_root, package_path)
  package_manifest_path = File.join(installed_path, "package.json")
  raise Agentlab::Error, "missing installed manifest for #{package_path}" unless File.file?(package_manifest_path)

  installed = JSON.parse(File.read(package_manifest_path))
  name = installed.fetch("name")
  package_version = installed.fetch("version")
  resolved = entry.fetch("resolved")
  integrity = entry.fetch("integrity")
  uri = URI(resolved)
  raise Agentlab::Error, "#{name}: source URL must use HTTPS" unless uri.is_a?(URI::HTTPS)

  bytes = Agentlab.download(resolved)
  verify_integrity!(bytes, integrity, "#{name}@#{package_version}")
  sha256 = Digest::SHA256.hexdigest(bytes)
  sha512_integrity = "sha512-#{Base64.strict_encode64(Digest::SHA512.digest(bytes))}"
  archive_name = safe_archive_name(name, package_version, sha256)
  existing_archive = source_archives[archive_name]
  if existing_archive
    unless existing_archive.fetch("sha256") == sha256 && existing_archive.fetch("bytes") == bytes.bytesize
      raise Agentlab::Error, "source archive collision for #{archive_name}"
    end
    existing_archive.fetch("package_paths") << package_path
  else
    archive_path = File.join(source_dir, archive_name)
    File.binwrite(archive_path, bytes)
    archive_findings = forbidden_tarball_entries(archive_path, "#{name}@#{package_version}", scan_dir)
    unless archive_findings.empty?
      raise Agentlab::Error, "forbidden source archive payloads found:\n#{archive_findings.join("\n")}"
    end
    source_archives[archive_name] = {
      "sha256" => sha256,
      "bytes" => bytes.bytesize,
      "package_paths" => [package_path]
    }
  end

  license_override = license_overrides["#{name}@#{package_version}"]
  license = license_override&.fetch("spdx", nil) || entry["license"] || installed["license"]
  license = license.join(" OR ") if license.is_a?(Array)
  unless license.is_a?(String) && !license.strip.empty?
    raise Agentlab::Error, "#{name}@#{package_version}: missing license metadata"
  end

  manifest_entries << {
    "npm_name" => name,
    "version" => package_version,
    "package_path" => package_path,
    "origin" => "registry",
    "role" => "runtime",
    "included_in_binary" => true,
    "source_url" => resolved,
    "integrity" => sha512_integrity,
    "lock_integrity" => integrity,
    "sha256" => sha256,
    "license" => license,
    "source_verified" => true,
    "archive" => File.join("npm-sources", archive_name)
  }
end

manifest = {
  "schema" => 1,
  "package" => "mermaid-cli",
  "version" => version,
  "runtime_adjustments" => { "puppeteer" => puppeteer_version },
  "lockfile" => {
    "declared_package_manager" => declared_package_manager,
    "generator_npm_version" => npm_version,
    "published_sha256" => published_lock_sha256,
    "runtime_sha256" => runtime_lock_sha256
  },
  "source_archives" => source_archives.transform_values { |entry| entry.reject { |key, _| key == "bytes" } },
  "preferred_sources" => dependencies.fetch("preferred_sources", []),
  "supplemental_notices" => dependencies.fetch("supplemental_notices", []),
  "packages" => manifest_entries
}
manifest_path = File.join(output_dir, "mermaid-cli-#{version}-closure.json")
File.write(manifest_path, JSON.pretty_generate(manifest) + "\n")

license_path = File.join(output_dir, "mermaid-cli-#{version}-bundled-licenses.txt")
license_lines = manifest_entries.map { |entry| "#{entry.fetch('npm_name')} #{entry.fetch('version')}: #{entry.fetch('license')}" }.uniq.sort
File.write(license_path, license_lines.join("\n") + "\n")

notice_path = File.join(output_dir, "mermaid-cli-#{version}-third-party-notices.txt")
notice_sections = manifest_entries.group_by { |entry| [entry.fetch("npm_name"), entry.fetch("version")] }.sort.map do |(name, package_version), entries|
  license_files = entries.flat_map do |entry|
    package_root = package_root_for(source_root, entry.fetch("package_path"))
    package_license_files(package_root).map do |relative, license_file|
      [entry.fetch("package_path"), relative, File.binread(license_file)]
    end
  end
  license_files.uniq! { |package_path, relative, bytes| [package_path, relative, Digest::SHA256.hexdigest(bytes)] }
  body = if license_files.empty?
           "No package-local license text was published; declared SPDX: #{entries.first.fetch('license')}\n".b
         else
           license_files.sort_by { |package_path, relative, _bytes| [package_path, relative] }.map do |package_path, relative, bytes|
             "--- #{package_path}/#{relative} ---\n".b + bytes
           end.join("\n".b)
         end
  "===== #{name} #{package_version} =====\n".b + body.rstrip + "\n".b
end

supplemental_records = dependencies.fetch("supplemental_notices", [])
supplemental_ids = supplemental_records.map { |record| record.fetch("id") }
raise Agentlab::Error, "supplemental notice IDs must be unique" unless supplemental_ids.uniq.length == supplemental_ids.length
supplemental_sections = supplemental_records.sort_by { |record| record.fetch("id") }.map do |record|
  id, targets, bytes = supplemental_notice_content(record, manifest_entries)
  header = [
    "===== Supplemental: #{id} =====",
    "Packages: #{targets.map { |target| "#{target.fetch('npm_name')}@#{target.fetch('version')}" }.join(', ')}",
    "Source URL: #{record.fetch('source_url')}",
    "Source SHA-256: #{record.fetch('sha256')}",
    ("Attribution: #{record.fetch('attribution')}" if record["attribution"]),
    ("Evidence URL: #{record.fetch('evidence_url')}" if record["evidence_url"]),
    ("Applies to: #{record.fetch('applies_to')}" if record["applies_to"]),
    "--- #{record.fetch('filename')} ---"
  ].compact.join("\n")
  "#{header}\n".b + bytes.rstrip + "\n".b
end
File.binwrite(notice_path, (notice_sections + supplemental_sections).join("\n".b) + "\n".b)

preferred_sources = dependencies.fetch("preferred_sources", [])
preferred_ids = preferred_sources.map { |record| record.fetch("id") }
raise Agentlab::Error, "preferred source IDs must be unique" unless preferred_ids.uniq.length == preferred_ids.length
preferred_dir = File.join(workdir, "preferred-sources")
FileUtils.mkdir_p(preferred_dir)
preferred_sources.each do |record|
  id = record.fetch("id")
  packages = record.fetch("packages")
  unless packages.is_a?(Array) && !packages.empty?
    raise Agentlab::Error, "#{id}: packages must be a nonempty array"
  end
  packages.each do |identifier|
    name, package_version = identifier.rpartition("@").values_at(0, 2)
    unless manifest_entries.any? { |entry| entry["npm_name"] == name && entry["version"] == package_version }
      raise Agentlab::Error, "#{id}: preferred source targets absent package #{identifier}"
    end
  end
  bytes = verified_download(record, id)
  File.binwrite(File.join(preferred_dir, record.fetch("filename")), bytes)

  next unless record["active_runtime_assets"]

  record.fetch("active_runtime_assets").each do |asset, expected_sha256|
    archive_member = "fontawesome-free-7.2.0-web/webfonts/#{asset}"
    archive_bytes, archive_error, archive_status = Agentlab.capture(
      ["unzip", "-p", File.join(preferred_dir, record.fetch("filename")), archive_member]
    )
    raise Agentlab::Error, "#{id}: cannot extract #{asset}: #{archive_error}" unless archive_status.success?
    actual_sha256 = Digest::SHA256.hexdigest(archive_bytes)
    raise Agentlab::Error, "#{id}: #{asset} SHA-256 mismatch" unless actual_sha256 == expected_sha256

    installed_font = File.join(node_modules, "@fortawesome", "fontawesome-free", "webfonts", asset)
    raise Agentlab::Error, "#{id}: installed runtime font is missing: #{asset}" unless File.file?(installed_font)
    unless Digest::SHA256.file(installed_font).hexdigest == expected_sha256
      raise Agentlab::Error, "#{id}: installed runtime font differs from official release: #{asset}"
    end
  end
end

native_manifest = {
  "schema" => 1,
  "package" => "mermaid-cli",
  "version" => version,
  "checked_paths" => manifest_entries.length,
  "native_payloads" => [],
  "browser_downloads" => false,
  "lifecycle_scripts_executed" => false
}
native_path = File.join(output_dir, "mermaid-cli-#{version}-native.json")
File.write(native_path, JSON.pretty_generate(native_manifest) + "\n")

FileUtils.rm_f(File.join(node_modules, ".package-lock.json"))
archive_stage = File.join(workdir, "archive")
FileUtils.mkdir_p(archive_stage)
FileUtils.cp_r(node_modules, File.join(archive_stage, "node_modules"), preserve: true)
FileUtils.cp_r(source_dir, File.join(archive_stage, "npm-sources"), preserve: true)
File.binwrite(File.join(archive_stage, "runtime-package-lock.json"), runtime_lock_bytes)

archive_path = File.join(output_dir, "mermaid-cli-#{version}-node-closure.tar.zst")
run!({}, [
  "tar", "--sort=name", "--mtime=@0", "--owner=0", "--group=0", "--numeric-owner",
  "--pax-option=delete=atime,delete=ctime", "--zstd", "-cf", archive_path,
  "-C", archive_stage, "node_modules", "npm-sources", "runtime-package-lock.json"
], chdir: Agentlab::ROOT)

archive_listing, archive_listing_error, archive_listing_status = Agentlab.capture(["tar", "-tf", archive_path])
raise Agentlab::Error, "cannot inspect generated closure archive: #{archive_listing_error}" unless archive_listing_status.success?
archive_listing.each_line do |entry|
  clean = Pathname(entry.strip).cleanpath.to_s
  if Pathname(entry.strip).absolute? || clean == ".." || clean.start_with?("../")
    raise Agentlab::Error, "generated closure archive contains escaping path #{entry.strip}"
  end
end

receipt = {
  "schema" => 1,
  "package" => "mermaid-cli",
  "version" => version,
  "source_sha256" => actual_source_sha,
  "package_count" => manifest_entries.length,
  "source_archive_count" => source_archives.length,
  "declared_package_manager" => declared_package_manager,
  "generator_npm_version" => npm_version,
  "published_lock_sha256" => published_lock_sha256,
  "runtime_lock_sha256" => runtime_lock_sha256,
  "archive_sha256" => Digest::SHA256.file(archive_path).hexdigest,
  "manifest_sha256" => Digest::SHA256.file(manifest_path).hexdigest,
  "license_inventory_sha256" => Digest::SHA256.file(license_path).hexdigest,
  "notice_sha256" => Digest::SHA256.file(notice_path).hexdigest,
  "native_manifest_sha256" => Digest::SHA256.file(native_path).hexdigest,
  "supplemental_notice_count" => supplemental_records.length,
  "preferred_source_count" => preferred_sources.length,
  "source_tarballs_scanned" => true,
  "materialized_tree_scanned" => true,
  "archive_paths_scanned" => true,
  "native_payloads_absent" => true,
  "browser_downloads" => false,
  "lifecycle_scripts_executed" => false
}
receipt_path = File.join(output_dir, "mermaid-cli-#{version}-closure-receipt.json")
File.write(receipt_path, JSON.pretty_generate(receipt) + "\n")

generated_files = {
  "production_archive" => archive_path,
  "closure_manifest" => manifest_path,
  "bundled_licenses" => license_path,
  "native_manifest" => native_path,
  "third_party_notices" => notice_path,
  "closure_receipt" => receipt_path
}
expected_files = dependencies.fetch("source_closure_files")
expected_hashes = dependencies.fetch("source_closure_sha256")
generated_files.each do |key, path|
  expected_name = expected_files.fetch(key)
  unless File.basename(path) == expected_name
    raise Agentlab::Error, "#{key} filename #{File.basename(path)} does not match audited filename #{expected_name}"
  end

  expected_sha256 = expected_hashes.fetch(key)
  actual_sha256 = Digest::SHA256.file(path).hexdigest
  unless actual_sha256 == expected_sha256
    raise Agentlab::Error, "#{expected_name} SHA-256 #{actual_sha256} does not match audited SHA-256 #{expected_sha256}"
  end
end

puts "Built Mermaid CLI closure with #{manifest_entries.length} package paths."
puts "Verified all six generated files against the audited source contract."
puts "Archive: #{archive_path}"
puts "Manifest: #{manifest_path}"
puts "Notices: #{notice_path}"
puts "Receipt: #{receipt_path}"
