#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "optparse"
require "rbconfig"
require_relative "lib/agentlab"

begin
apply = false
build_current = false
build_timeout = nil
include_blocked = false
proof_build = false
selected_chroots = []
selected_name = nil
config_path = Agentlab::DEFAULT_CONFIG

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/update-and-build [--apply] [--build-current] [--proof-build] [--timeout SECONDS] [--chroot NAME] [--include-blocked] [--package NAME]"
  parser.on("--apply", "Write updates and build changed enabled packages") { apply = true }
  parser.on("--build-current", "Build one already-pushed SCM package definition") { build_current = true }
  parser.on("--proof-build", "Allow --build-current for one blocked package without enabling it") { proof_build = true }
  parser.on("--timeout SECONDS", Integer, "Override the COPR build timeout") { |seconds| build_timeout = seconds }
  parser.on("--chroot NAME", "Override a current build target; may be repeated") { |chroot| selected_chroots << chroot }
  parser.on("--include-blocked", "Check and update blocked drafts, but never build them") { include_blocked = true }
  parser.on("--package NAME", "Process only one package") { |name| selected_name = name }
  parser.on("--config PATH", "Use another COPR config file") { |path| config_path = path }
end.parse!

raise Agentlab::Error, "--build-current requires --package NAME" if build_current && selected_name.nil?
raise Agentlab::Error, "--proof-build requires --build-current" if proof_build && !build_current
raise Agentlab::Error, "--timeout requires --build-current" if build_timeout && !build_current
raise Agentlab::Error, "--chroot requires --build-current" if selected_chroots.any? && !build_current
raise Agentlab::Error, "--timeout must be a positive number of seconds" if build_timeout && !build_timeout.positive?

config = Agentlab.config(config_path)
selected_chroots.uniq!
unknown_chroots = selected_chroots - config.fetch("chroots")
unless unknown_chroots.empty?
  raise Agentlab::Error, "unknown configured chroot(s): #{unknown_chroots.join(', ')}"
end
packages = selected_name ? [Agentlab.package_named(selected_name)] : Agentlab.packages
packages.select! { |package| package.enabled? || include_blocked || proof_build }

if packages.empty?
  puts "No enabled packages selected. Use --include-blocked to check blocked drafts."
  exit 0
end

updates = if build_current
            []
          else
            packages.filter_map do |package|
              provider = package.upstream.fetch("provider")
              version = Agentlab.latest_upstream_version(package)
              current = package.upstream.fetch("current_version")

              if Gem::Version.new(version) <= Gem::Version.new(current)
                label = provider == "static" ? "static release metadata" : "latest stable #{version}"
                puts "#{package.name}: current #{current}, #{label}"
                next
              end

              url = Agentlab.source_url(package, version)
              source = Agentlab.download(url)
              sha256 = Digest::SHA256.hexdigest(source)
              puts "#{package.name}: #{current} -> #{version}"
              puts "  source: #{url}"
              puts "  sha256: #{sha256}"
              { package: package, version: version, sha256: sha256 }
            end
end

if updates.empty? && !build_current
  puts "No released updates found."
  exit 0
end

unless apply
  puts "Dry run: no files changed and no builds submitted."
  puts "Use --apply to request the current pushed SCM build." if build_current
  exit 0
end

project = "#{config.fetch('owner')}/#{config.fetch('project')}"
agentlab_project = project == "marcin/agentlab"
if build_current && updates.any?
  raise Agentlab::Error,
        "--build-current requires already-current package files; apply the update, commit, and push it first"
end

builds = if build_current
           proof_build ? packages : packages.select(&:enabled?)
         elsif agentlab_project
           []
         else
           updates.map { |update| update.fetch(:package) }.select(&:enabled?)
         end
Agentlab.verify_copr_owner!(config.fetch("owner")) if builds.any?

updates.each do |update|
  package = update.fetch(:package)
  state = package.enabled? ? "enabled package" : "blocked draft"
  Agentlab.update_package_files(
    package,
    version: update.fetch(:version),
    sha256: update.fetch(:sha256),
    changelog_message: "Update the #{state} to released version #{update.fetch(:version)}."
  )
end

Agentlab.run!([RbConfig.ruby, File.join(Agentlab::ROOT, "scripts", "check-packages")])

if builds.any?
  builds.each do |package|
    chroots = selected_chroots.empty? ? package.chroots(config.fetch("chroots")) : selected_chroots
    chroot_args = chroots.flat_map { |chroot| ["--chroot", chroot] }
    if agentlab_project
      package_path = package.directory.delete_prefix("#{Agentlab::ROOT}/")
      status_stdout, status_stderr, status = Agentlab.capture(
        ["git", "status", "--porcelain", "--", package_path, ".copr/Makefile"]
      )
      raise Agentlab::Error, status_stderr.strip unless status.success?
      unless status_stdout.empty?
        raise Agentlab::Error, "SCM build inputs have uncommitted changes: #{package_path} or .copr/Makefile"
      end

      local_stdout, local_stderr, local_status = Agentlab.capture(["git", "rev-parse", "HEAD"])
      raise Agentlab::Error, local_stderr.strip unless local_status.success?

      branch = config.fetch("branch")
      remote_stdout, remote_stderr, remote_status = Agentlab.capture(
        ["git", "ls-remote", "origin", "refs/heads/#{branch}"]
      )
      raise Agentlab::Error, remote_stderr.strip unless remote_status.success?

      remote_head = remote_stdout.split.first.to_s
      unless local_stdout.strip == remote_head
        raise Agentlab::Error, "local HEAD does not match pushed origin/#{branch}"
      end

      timeout_label = build_timeout ? " with timeout #{build_timeout}s" : ""
      puts "$ COPR package build #{project}/#{package.name} in #{chroots.join(', ')}#{timeout_label}"
      result = Agentlab.copr_package_build(
        owner: config.fetch("owner"),
        project: config.fetch("project"),
        package_name: package.name,
        chroots: chroots,
        timeout: build_timeout
      )
      puts "Submitted COPR build #{result.fetch('id')}."
    else
      command = Agentlab.copr_command("build", project, "--nowait", *chroot_args)
      command.concat(["--timeout", build_timeout.to_s]) if build_timeout
      command << package.spec_path
      Agentlab.run!(command)
    end
  end
end

if agentlab_project && updates.any?
  puts "Updated #{updates.length} package(s); no agentlab builds were submitted."
  puts "Commit and push the changes, then run --apply --build-current --package NAME for each enabled package."
else
  puts builds.empty? ? "Updated blocked drafts; no builds were submitted." : "Submitted #{builds.length} COPR build(s)."
end
rescue Agentlab::Error, KeyError => e
  warn "error: #{e.message}"
  exit 1
end
