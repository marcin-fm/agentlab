CHROMIUM_PARENT_LICENSE = {
  "repository" => "https://chromium.googlesource.com/chromium/src",
  "commit" => "605c904774a4e2204ef7ca2dbc93ac16f526c085",
  "path" => "LICENSE",
  "url" => "https://chromium.googlesource.com/chromium/src/+/605c904774a4e2204ef7ca2dbc93ac16f526c085/LICENSE",
  "sha256" => "368cca1106be99d39ecd32a38d8305585d802a475effb66380b91ffc9bcf709b",
  "expression" => "BSD-3-Clause"
}.freeze

def tree_manifest(root)
  records = []
  Find.find(root) do |entry|
    next if entry == root

    if File.basename(entry) == ".git"
      Find.prune if File.directory?(entry)
      next
    end

    relative = entry.delete_prefix("#{root}/")
    stat = File.lstat(entry)
    if stat.file?
      mode = stat.executable? ? "100755" : "100644"
      records << [relative, mode, Digest::SHA256.file(entry).hexdigest]
    elsif stat.symlink?
      records << [relative, "120000", Digest::SHA256.hexdigest(File.readlink(entry))]
    elsif !stat.directory?
      raise Agentlab::Error, "unsupported source-tree entry #{relative}"
    end
  end
  records.sort
end

def license_candidate?(path)
  basename = File.basename(path)
  basename.match?(LICENSE_BASENAME) || path.split("/").include?("LICENSES")
end

def owner_path(path, component_paths)
  component_paths.find do |component|
    component == "." || path == component || path.start_with?("#{component}/")
  end
end

def license_syntax_record(raw, allow_slash: false)
  record = {
    "raw_license" => raw,
    "syntax_class" => "missing",
    "normalized_expression" => nil,
    "proposed_expression" => nil,
    "normalization_status" => "missing",
    "normalization_reason" => "no license declaration is present",
    "normalization_basis" => nil,
    "semantic_review_status" => "pending"
  }
  return record unless raw

  if raw == "BSD"
    record.merge(
      "syntax_class" => "legacy-bsd-label",
      "normalization_status" => "unresolved",
      "normalization_reason" => "BSD does not identify a unique SPDX license"
    )
  elsif raw.include?(",")
    record.merge(
      "syntax_class" => "ambiguous-comma-list",
      "normalization_status" => "ambiguous",
      "normalization_reason" => "comma separation does not establish AND or OR semantics"
    )
  elsif allow_slash && raw.include?("/")
    operands = raw.split("/").map(&:strip)
    proposed = if operands.length > 1 && operands.all? { |operand| operand.match?(/\A[A-Za-z0-9][A-Za-z0-9.+-]*\z/) }
                 operands.join(" OR ")
               end
    if raw == "MIT/Apache-2.0"
      record.merge(
        "syntax_class" => "legacy-slash-alternative",
        "normalized_expression" => proposed,
        "normalization_status" => "mechanically-normalized",
        "normalization_reason" => "Fedora cargo2rpm converts legacy Cargo slash alternatives to OR; semantic text and Fedora allowability review remain separate",
        "normalization_basis" => "Fedora cargo2rpm license.py legacy slash-alternative conversion"
      )
    else
      record.merge(
        "syntax_class" => "legacy-slash-alternative",
        "proposed_expression" => proposed,
        "normalization_status" => proposed ? "proposed" : "unresolved",
        "normalization_reason" => "slash alternatives require explicit semantic review before conversion to OR"
      )
    end
  elsif raw.match?(/\b(?:AND|OR|WITH)\b|[()]/)
    record.merge(
      "syntax_class" => "spdx-expression-syntax",
      "normalized_expression" => raw,
      "normalization_status" => "syntax-only",
      "normalization_reason" => "expression-shaped declaration is not yet semantically or Fedora reviewed"
    )
  elsif raw.match?(/\A[A-Za-z0-9][A-Za-z0-9.+-]*\z/)
    record.merge(
      "syntax_class" => "spdx-identifier-syntax",
      "normalized_expression" => raw,
      "normalization_status" => "syntax-only",
      "normalization_reason" => "identifier-shaped declaration is not yet semantically or Fedora reviewed"
    )
  else
    record.merge(
      "syntax_class" => "unclassified",
      "normalization_status" => "unresolved",
      "normalization_reason" => "declaration syntax is not recognized"
    )
  end
end

def readme_chromium_metadata(path, source_dir)
  content = File.read(path, encoding: "UTF-8", invalid: :replace, undef: :replace)
  fields = {}
  content.each_line do |line|
    key, value = line.split(":", 2)
    next unless value

    normalized = key.strip.downcase.gsub(/[^a-z0-9]+/, "_").delete_suffix("_")
    next unless %w[name url version revision license license_file shipped security_critical].include?(normalized)

    fields[normalized] = value.strip
  end
  if fields["license_file"]
    declared_records = fields.fetch("license_file").split(/\s*,\s*/).map do |license_file|
      declared = if license_file.start_with?("//")
                   File.expand_path(license_file.delete_prefix("//"), source_dir)
                 else
                   File.expand_path(license_file, File.dirname(path))
                 end
      within_source = declared.start_with?("#{source_dir}/")
      verified = within_source && File.file?(declared)
      relative = within_source ? declared.delete_prefix("#{source_dir}/") : license_file
      unmaterialized = UNMATERIALIZED_DEPS_DECLARATIONS.find do |candidate|
        candidate.fetch("declared_license_path") == relative
      end
      if unmaterialized && fields["shipped"] != unmaterialized.fetch("expected_shipped")
        raise Agentlab::Error, "unmaterialized DEPS declaration shipping metadata changed for #{relative}"
      end
      {
        "path" => relative,
        "verified" => verified,
        "source_path_present" => within_source && File.exist?(File.dirname(declared)),
        "declared_text_scope" => if verified
                                   "materialized-source"
                                 elsif unmaterialized
                                   "unmaterialized-deps-source"
                                 else
                                   "unresolved"
                                 end,
        "semantic_review_verified" => false,
        "sha256" => verified ? Digest::SHA256.file(declared).hexdigest : nil
      }
    end
    fields["license_file_records"] = declared_records
    fields["license_file_verified"] = declared_records.all? { |record| record.fetch("verified") }
  end
  relative = path.delete_prefix("#{source_dir}/")
  fields.merge!(license_syntax_record(fields["license"]))
  if (normalization = README_LICENSE_NORMALIZATIONS[relative])
    fields.merge!(normalization)
    fields["normalization_reason"] = "exact declaration-specific evidence supplies a proposed SPDX expression; semantic text and Fedora allowability review remain pending"
  end
  fields
end

def scoped_parent_license_evidence(source_dir, component_records)
  components = {
    "tools/clang" => "tools/clang/v8_handle_migrate/tests/with-prototypes-original.cc",
    "tools/win" => "tools/win/sizeviewer/sizeviewer.py"
  }.map do |component_path, header_path|
    component = component_records.fetch(component_path)
    local_texts_present = component.fetch("license_files").any?
    raise Agentlab::Error, "unexpected component-local text for #{component_path}" if local_texts_present
    absolute_header_path = File.join(source_dir, header_path)
    header = File.readlines(absolute_header_path).first(4).join
    unless header.include?("The Chromium Authors") &&
           header.include?("Use of this source code is governed by a BSD-style license") &&
           header.include?("found in the LICENSE file")
      raise Agentlab::Error, "Chromium parent-license header evidence changed for #{header_path}"
    end

    {
      "path" => component_path,
      "source_commit" => component.fetch("commit"),
      "source_archive_url" => component.fetch("archive_url"),
      "component_local_texts_present" => local_texts_present,
      "parent_license" => CHROMIUM_PARENT_LICENSE,
      "chromium_header_evidence" => {
        "path" => header_path,
        "sha256" => Digest::SHA256.file(absolute_header_path).hexdigest
      },
      "applies_to_chromium_authored_files_only" => true,
      "whole_component_license_verified" => false,
      "embedded_third_party_reviewed" => false
    }
  end

  win = components.find { |component| component.fetch("path") == "tools/win" }
  readme_path = File.join(source_dir, "tools/win/README.md")
  unless File.read(readme_path).include?("Code in this directory and subdirectories is not shipped with Chrome.")
    raise Agentlab::Error, "tools/win shipping-scope declaration changed"
  end
  embedded = {
    "declaration_path" => "tools/win/sizeviewer/README.chromium",
    "declaration_sha256" => "ff117457ee3fb3c3015a1e8aa73849eb52314ba525196651029d5a75242b1c64",
    "assets" => [
      ["tools/win/sizeviewer/codemirror.js", "MIT", "6ec18dff438553ebebd9f33b86c387d16783ca6b64576810daafc123e60bd1fd"],
      ["tools/win/sizeviewer/clike.js", "MIT", "76cd8a83c47592f454350df6bea616330d925acff9544fade8d97792384086ab"],
      ["tools/win/sizeviewer/favicon.png", nil, "c4be8cf22cedfe22ca5a0691640c47ae5308aba65eb9949c246b53bcc86070bc"]
    ].map do |path, expression, sha256|
      absolute = File.join(source_dir, path)
      raise Agentlab::Error, "embedded asset hash changed for #{path}" unless Digest::SHA256.file(absolute).hexdigest == sha256

      {
        "path" => path,
        "sha256" => sha256,
        "proposed_expression" => expression,
        "semantic_review_status" => "pending"
      }
    end
  }
  declaration_path = File.join(source_dir, embedded.fetch("declaration_path"))
  unless Digest::SHA256.file(declaration_path).hexdigest == embedded.fetch("declaration_sha256")
    raise Agentlab::Error, "tools/win embedded-asset declaration hash changed"
  end
  win["directory_declares_not_shipped"] = true
  win["embedded_third_party_assets"] = embedded
  components
end

def cargo_package_metadata(path)
  content = File.read(path, encoding: "UTF-8", invalid: :replace, undef: :replace)
  package = content[/^\[package\]\s*$\n(.*?)(?=^\[|\z)/m, 1]
  raise Agentlab::Error, "missing [package] section in #{path}" unless package

  values = {}
  %w[name version license license-file].each do |key|
    value = package[/^#{Regexp.escape(key)}\s*=\s*["']([^"']+)["']\s*$/, 1]
    values[key.tr("-", "_")] = value if value
  end
  values["placeholder"] = content.match?(/^is_placeholder\s*=\s*true\s*$/)
  values
end

begin
package = Agentlab.package_named("rust-v8")
version = package.upstream.fetch("current_version").to_s
source_receipt_path = File.join(package.directory, "rust-v8-#{version}-source-closure.json")
source_dir = nil
output = File.join(package.directory, "rust-v8-#{version}-license-audit.json")
check = false

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/audit-rust-v8-licenses --source-dir PATH [options]"
  parser.on("--source-dir PATH", "Reconstructed exact Rusty V8 source tree") { |path| source_dir = path }
  parser.on("--output PATH", "Canonical license-audit receipt") { |path| output = path }
  parser.on("--check", "Verify that the checked receipt is current") { check = true }
end.parse!

raise Agentlab::Error, "--source-dir is required" unless source_dir
source_dir = File.realpath(source_dir)
source_receipt = JSON.parse(File.read(source_receipt_path))
expected_tree_sha256 = source_receipt.dig("reconstruction", "tree_sha256")
actual_tree_sha256 = Digest::SHA256.hexdigest(JSON.generate(tree_manifest(source_dir)))
unless actual_tree_sha256 == expected_tree_sha256
  raise Agentlab::Error, "source tree does not match the checked recursive-source receipt"
end

deps_content = File.read(File.join(source_dir, "v8", "DEPS"))
unmaterialized_deps_declarations = UNMATERIALIZED_DEPS_DECLARATIONS.map do |declaration|
  deps_path = declaration.fetch("source_path").delete_prefix("v8/")
  needle = "  '#{deps_path}':\n" \
           "    Var('chromium_url') + '#{declaration.fetch('repository_suffix')}' + '@' + " \
           "'#{declaration.fetch('commit')}',"
  raise Agentlab::Error, "V8 DEPS pin changed for #{deps_path}" unless deps_content.include?(needle)
  if File.exist?(File.join(source_dir, declaration.fetch("source_path")))
    raise Agentlab::Error, "expected unmaterialized V8 DEPS source is present: #{declaration.fetch('source_path')}"
  end

  declaration.reject { |key, _value| %w[repository_suffix expected_shipped].include?(key) }.merge(
    "readme_shipped" => declaration.fetch("expected_shipped"),
    "source_materialized" => false,
    "declared_text_resolvable" => false
  )
end

component_paths = source_receipt.fetch("components").map { |component| component.fetch("path") }
owner_order = component_paths.sort_by { |path| path == "." ? 0 : -path.length }
component_records = source_receipt.fetch("components").to_h do |component|
  [component.fetch("path"), {
      "path" => component.fetch("path"),
      "url" => component.fetch("url"),
      "archive_url" => component.dig("archive", "url"),
      "commit" => component.fetch("commit"),
    "license_files" => [],
    "readme_chromium" => []
  }]
end

all_license_files = []
readme_records = []
Find.find(source_dir) do |entry|
  next unless File.file?(entry)

  relative = entry.delete_prefix("#{source_dir}/")
  owner = owner_path(relative, owner_order)
  raise Agentlab::Error, "cannot assign source owner for #{relative}" unless owner

  if license_candidate?(relative)
    record = {
      "path" => relative,
      "bytes" => File.size(entry),
      "sha256" => Digest::SHA256.file(entry).hexdigest
    }
    component_records.fetch(owner).fetch("license_files") << record
    all_license_files << record
  end

  next unless File.basename(relative) == "README.chromium"

  record = { "path" => relative }.merge(readme_chromium_metadata(entry, source_dir))
  component_records.fetch(owner).fetch("readme_chromium") << record
  readme_records << record
end

component_records.each_value do |component|
  component.fetch("license_files").sort_by! { |record| record.fetch("path") }
  component.fetch("readme_chromium").sort_by! { |record| record.fetch("path") }
  component["license_file_count"] = component.fetch("license_files").length
  component["readme_chromium_count"] = component.fetch("readme_chromium").length
  component["declared_license_candidates"] = component.fetch("readme_chromium")
                                                       .filter_map { |record| record["license"] }
                                                       .uniq.sort
end

vendor_root = File.join(source_dir, "third_party", "rust", "chromium_crates_io", "vendor")
  vendor_packages = Dir.glob(File.join(vendor_root, "*", "Cargo.toml")).sort.map do |manifest_path|
  crate_root = File.dirname(manifest_path)
  relative_root = crate_root.delete_prefix("#{source_dir}/")
  metadata = cargo_package_metadata(manifest_path)
  license_files = all_license_files.select do |record|
    record.fetch("path").start_with?("#{relative_root}/")
  end.sort_by { |record| record.fetch("path") }
  manifest_license_path = if metadata["license_file"]
                            File.expand_path(metadata.fetch("license_file"), crate_root)
                          end
  manifest_license_file_verified = manifest_license_path &&
                                    manifest_license_path.start_with?("#{crate_root}/") &&
                                    File.file?(manifest_license_path)
  if metadata["license"] == "MIT/Apache-2.0"
    license_basenames = license_files.map { |record| File.basename(record.fetch("path")).upcase }
    unless license_basenames.include?("LICENSE-MIT") && license_basenames.include?("LICENSE-APACHE")
      raise Agentlab::Error, "legacy Cargo slash normalization lacks MIT and Apache texts for #{relative_root}"
    end
  end
  {
    "path" => relative_root,
    "name" => metadata["name"],
    "version" => metadata["version"],
    "manifest_license" => metadata["license"],
    "manifest_license_file" => metadata["license_file"],
    "manifest_license_file_path" => manifest_license_path&.delete_prefix("#{source_dir}/"),
    "manifest_license_file_verified" => manifest_license_file_verified == true,
    "placeholder" => metadata.fetch("placeholder"),
    "license_files" => license_files,
    "license_file_count" => license_files.length
  }.merge(license_syntax_record(metadata["license"], allow_slash: true))
end

declared_candidates = component_records.values.flat_map do |component|
  component.fetch("declared_license_candidates")
end
declared_candidates.concat(vendor_packages.filter_map { |record| record["manifest_license"] })
vendored_source_packages = vendor_packages.reject { |record| record.fetch("placeholder") }
readme_license_file_records = readme_records.select { |record| record["license_file"] }
readme_declared_license_paths = readme_license_file_records.flat_map { |record| record.fetch("license_file_records") }
vendor_license_file_records = vendored_source_packages.select { |record| record["manifest_license_file"] }

receipt = {
  "schema" => "rust-v8-license-audit/v1",
  "package" => package.name,
  "release" => version,
  "source_closure" => {
    "path" => File.basename(source_receipt_path),
    "sha256" => Digest::SHA256.file(source_receipt_path).hexdigest,
    "tree_sha256" => expected_tree_sha256
  },
  "components" => component_paths.map { |path| component_records.fetch(path) },
  "scoped_parent_license_evidence" => scoped_parent_license_evidence(source_dir, component_records),
  "unmaterialized_deps_declarations" => unmaterialized_deps_declarations,
  "vendored_rust" => {
    "root" => "third_party/rust/chromium_crates_io/vendor",
    "packages" => vendor_packages
  },
  "declared_license_candidates" => declared_candidates.uniq.sort,
  "summary" => {
    "components" => component_records.length,
    "components_with_license_files" => component_records.values.count { |record| record.fetch("license_file_count").positive? },
    "components_without_license_files" => component_records.values.count { |record| record.fetch("license_file_count").zero? },
    "license_candidate_files" => all_license_files.length,
    "readme_chromium_records" => readme_records.length,
    "readme_chromium_with_license" => readme_records.count { |record| record.key?("license") },
    "readme_chromium_without_license" => readme_records.count { |record| record["raw_license"].nil? },
    "readme_chromium_ambiguous_comma_licenses" => readme_records.count { |record| record["syntax_class"] == "ambiguous-comma-list" },
    "readme_chromium_legacy_bsd_licenses" => readme_records.count { |record| record["syntax_class"] == "legacy-bsd-label" },
    "readme_chromium_proposed_normalizations" => readme_records.count { |record| record["normalization_status"].to_s.start_with?("proposed", "external-proposed") },
    "readme_chromium_with_declared_license_file" => readme_license_file_records.length,
    "readme_chromium_with_verified_declared_license_file" => readme_license_file_records.count { |record| record["license_file_verified"] == true },
    "readme_chromium_declared_license_paths" => readme_declared_license_paths.length,
    "readme_chromium_verified_declared_license_paths" => readme_declared_license_paths.count { |record| record.fetch("verified") },
    "readme_chromium_unmaterialized_declared_license_paths" => readme_declared_license_paths.count { |record| record["declared_text_scope"] == "unmaterialized-deps-source" },
    "readme_chromium_semantically_verified_declared_license_paths" => readme_declared_license_paths.count { |record| record["semantic_review_verified"] == true },
    "vendored_rust_packages" => vendor_packages.length,
    "vendored_rust_source_packages" => vendored_source_packages.length,
    "vendored_rust_placeholders" => vendor_packages.count { |record| record.fetch("placeholder") },
    "vendored_rust_source_packages_with_manifest_license" => vendored_source_packages.count { |record| record["manifest_license"] },
    "vendored_rust_source_packages_with_manifest_license_file" => vendored_source_packages.count { |record| record["manifest_license_file"] },
    "vendored_rust_source_packages_with_verified_manifest_license_file" => vendor_license_file_records.count { |record| record["manifest_license_file_verified"] == true },
    "vendored_rust_source_packages_with_candidate_texts" => vendored_source_packages.count { |record| record.fetch("license_file_count").positive? },
    "vendored_rust_legacy_slash_license_expressions" => vendored_source_packages.count { |record| record["syntax_class"] == "legacy-slash-alternative" },
    "vendored_rust_mechanically_normalized_license_expressions" => vendored_source_packages.count { |record| record["normalization_status"] == "mechanically-normalized" }
  },
  "validation" => {
    "source_closure_verified" => true,
    "source_tree_verified" => true,
    "all_source_components_inventoried" => true,
    "candidate_license_files_hashed" => true,
    "readme_chromium_metadata_inventoried" => true,
    "declared_license_file_paths_inventoried" => true,
    "declared_license_syntax_classified" => true,
    "known_license_normalization_evidence_recorded" => true,
    "scoped_parent_license_evidence_recorded" => true,
    "unmaterialized_deps_declarations_classified" => true,
    "vendored_rust_manifests_inventoried" => true,
    "vendored_rust_placeholders_classified" => true,
    "vendored_rust_source_package_declarations_complete" => vendored_source_packages.all? { |record| record["manifest_license"] || record["manifest_license_file"] },
    "vendored_rust_source_package_candidate_texts_present" => vendored_source_packages.all? { |record| record.fetch("license_file_count").positive? },
    "license_expressions_normalized" => false,
    "declared_license_text_semantic_review_complete" => false,
    "required_license_texts_verified" => false,
    "fedora_allowed_spdx_verified" => false,
    "source_package_license_complete" => false,
    "final_static_archive_license_complete" => false
  },
  "scope" => "candidate legal-text and declaration inventory for every exact Git component, including mechanical Cargo slash normalization, declaration-specific proposed expressions, scoped Chromium parent-text evidence, and embedded metadata that names intentionally unmaterialized DEPS test/tool sources; aggregate SPDX normalization, semantic text review, required-text decisions, Fedora allowability, system-library treatment, and final static-link accounting remain unresolved"
}
content = JSON.pretty_generate(receipt) + "\n"

if check
  raise Agentlab::Error, "missing checked license-audit receipt #{output}" unless File.file?(output)
  raise Agentlab::Error, "Rusty V8 license-audit receipt is stale: #{output}" unless File.binread(output) == content
  puts "Verified #{all_license_files.length} candidate license files and #{vendor_packages.length} vendored Rust packages."
else
  Agentlab.atomic_write(output, content)
  puts "Wrote #{all_license_files.length} candidate license files and #{vendor_packages.length} vendored Rust packages to #{output}."
end
rescue Agentlab::Error, JSON::ParserError, KeyError, SystemCallError => e
  warn "error: #{e.message}"
  exit 1
end
