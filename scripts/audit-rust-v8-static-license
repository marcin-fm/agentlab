LICENSE_TEXTS = [
  ["LICENSE", "rusty-v8-MIT.txt", ["MIT"], "complete-text"],
  ["v8/LICENSE", "v8-BSD-3-Clause.txt", ["BSD-3-Clause"], "complete-text"],
  ["third_party/abseil-cpp/LICENSE", "abseil-Apache-2.0.txt", ["Apache-2.0"], "complete-text"],
  ["third_party/abseil-cpp/absl/time/internal/cctz/src/tzfile.h", "cctz-tzfile-public-domain.h", ["LicenseRef-Fedora-Public-Domain"], "file-level-notice"],
  ["third_party/highway/src/LICENSE", "highway-LICENSE.txt", ["Apache-2.0"], "component-text"],
  ["third_party/icu/LICENSE", "icu-LICENSE.txt", ["Unicode-3.0", "Unicode-DFS-2016", "BSD-2-Clause", "BSD-3-Clause", "NAIST-2003", "LicenseRef-Fedora-Public-Domain"], "complete-text-and-notices"],
  ["third_party/simdutf/LICENSE", "simdutf-MIT.txt", ["MIT"], "complete-text"],
