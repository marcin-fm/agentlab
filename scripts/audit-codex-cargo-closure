#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "fileutils"
require "json"
require "open3"
require "optparse"
require "pathname"
require "rubygems/package"
require "set"
require "tmpdir"
require "zlib"
require_relative "lib/agentlab"

def normalize_git_url(value)
  value
    .delete_prefix("git+")
    .split("#", 2).first
    .split("?", 2).first
    .delete_suffix(".git")
end

def source_origin(source)
  case source
  when nil then "path"
  when /\Aregistry\+/ then "registry"
  when /\Agit\+/ then "git"
  else "other"
  end
end

def capture_command(environment, command, description, stdin_data: nil)
  stdout, stderr, status = Open3.capture3(environment, *command, stdin_data:)
  return stdout if status.success?

  detail = stderr.lines.last(20).join
  raise Agentlab::Error, "#{description} failed:\n#{detail}"
end

def parse_lock_packages(content)
  content.scan(/^\[\[package\]\]\n(.*?)(?=^\[\[package\]\]|\z)/m).map do |body|
    body = body.first
    name = body.match(/^name = "([^"]+)"$/)&.captures&.first
    version = body.match(/^version = "([^"]+)"$/)&.captures&.first
    raise Agentlab::Error, "malformed Cargo.lock package record" unless name && version

    record = {
      "name" => name,
      "version" => version,
      "source" => body.match(/^source = "([^"]+)"$/)&.captures&.first,
      "checksum" => body.match(/^checksum = "([^"]+)"$/)&.captures&.first
    }.compact
    dependencies = body[/^dependencies = \[\n(.*?)^\]$/m, 1].to_s.scan(/^ "([^"]+)",$/).flatten
    record["dependencies"] = dependencies unless dependencies.empty?
    record
  end
end

def normalize_workspace_lock(content, version)
  changed_packages = []
  normalized = content.split(/(?=^\[\[package\]\]$)/).map do |block|
    next block unless block.start_with?("[[package]]\n")

    record = parse_lock_packages(block).first
    next block unless record && !record.key?("source") && record.fetch("version") == "0.0.0"

    changed_packages << record.fetch("name")
    block.sub(/^version = "0\.0\.0"$/, "version = \"#{version}\"")
  end.join

  [normalized, changed_packages.sort]
end

def git_location_matches?(source, location)
  source_url, source_commit = source.delete_prefix("git+").split("#", 2)
  location_url, location_commit = location.split("#", 2)
  source_url == location_url && source_commit&.start_with?(location_commit.to_s)
end

def resolve_tree_package(display, lock_by_name_version, source_dir)
  display = display.gsub(" (proc-macro)", "")
  match = display.match(/\A([^ ]+) v([^ ]+)(?: \((.+)\))?\z/)
  raise Agentlab::Error, "cannot parse Cargo tree package: #{display}" unless match

  name, version, location = match.captures
  candidates = lock_by_name_version.fetch([name, version], [])
  candidates = if location.nil?
                 candidates.select { |record| record.fetch("source", "").start_with?("registry+") }
               elsif location.match?(%r{\Ahttps?://})
                 candidates.select do |record|
                   source = record["source"]
                   source&.start_with?("git+") && git_location_matches?(source, location)
                 end
               else
                 source_prefix = "#{source_dir}/"
                 expanded_location = File.expand_path(location)
                 candidates.select do |record|
                   !record.key?("source") &&
                     (expanded_location == source_dir || expanded_location.start_with?(source_prefix))
                 end
               end

  unless candidates.one?
    raise Agentlab::Error,
          "expected one Cargo.lock record for #{display}, found #{candidates.length}"
  end

  [candidates.first, location]
end

def parse_tree(output, lock_by_name_version, source_dir)
  stack = []
  selected = {}

  output.each_line do |raw_line|
    line = raw_line.strip.delete_suffix(" (*)")
    next if line.empty?

    match = line.match(/\A(\d+)(.+)\z/)
    raise Agentlab::Error, "cannot parse Cargo tree depth: #{line}" unless match

    depth = Integer(match[1], 10)
    display, features_text = match[2].split("|", 2)
    raise Agentlab::Error, "Cargo tree format is missing features: #{line}" unless features_text

    lock_record, location = resolve_tree_package(display, lock_by_name_version, source_dir)
    package_id = [
      lock_record.fetch("name"),
      lock_record.fetch("version"),
      lock_record["source"]
    ]
    stack[depth] = package_id
    stack.slice!(depth + 1, stack.length) if stack.length > depth + 1
    dependency_path = stack.first(depth + 1).map(&:dup)
    features = features_text.split(",").reject(&:empty?).sort
    previous = selected[package_id]

    if previous.nil? || dependency_path.length < previous.fetch("dependency_path").length
      selected[package_id] = {
        "lock_record" => lock_record,
        "location" => location,
        "features" => features,
        "dependency_path" => dependency_path
      }
    elsif previous.fetch("features") != features
      previous["features"] = (previous.fetch("features") + features).uniq.sort
    end
  end

  selected
end

def parse_license_tree(output, lock_by_name_version, source_dir)
  stack = []
  selected = {}

  output.each_line do |raw_line|
    line = raw_line.strip.delete_suffix(" (*)")
    next if line.empty?

    match = line.match(/\A(\d+)(.+)\z/)
    raise Agentlab::Error, "cannot parse Cargo license tree depth: #{line}" unless match

    depth = Integer(match[1], 10)
    display, license = match[2].split("|", 2)
    raise Agentlab::Error, "Cargo license tree format is missing license metadata: #{line}" unless license

    license = license.strip
    raise Agentlab::Error, "Cargo package lacks license metadata: #{display}" if license.empty?

    lock_record, location = resolve_tree_package(display, lock_by_name_version, source_dir)
    package_id = [
      lock_record.fetch("name"),
      lock_record.fetch("version"),
      lock_record["source"]
    ]
    stack[depth] = package_id
    stack.slice!(depth + 1, stack.length) if stack.length > depth + 1
    dependency_path = stack.first(depth + 1).map(&:dup)
    previous = selected[package_id]

    if previous && previous.fetch("license") != license
      raise Agentlab::Error, "Cargo reported conflicting licenses for #{display}"
    end
    if previous.nil? || dependency_path.length < previous.fetch("dependency_path").length
      selected[package_id] = {
        "lock_record" => lock_record,
        "location" => location,
        "license" => license,
        "dependency_path" => dependency_path
      }
    end
  end

  selected
end

def normalize_cargo_license_expression(expression)
  expression.strip.gsub(/\s*\/\s*/, " OR ")
end

def aggregate_license_expression(expressions)
  expressions.uniq.sort.map do |expression|
    expression.match?(/\b(?:AND|OR)\b/) ? "(#{expression})" : expression
  end.join(" AND ")
end

def resolve_lock_dependency(reference, lock_by_name)
  match = reference.match(/\A([^ ]+)(?: ([^ ]+)(?: \((.+)\))?)?\z/)
  raise Agentlab::Error, "cannot parse Cargo.lock dependency reference: #{reference}" unless match

  name, version, source = match.captures
  candidates = lock_by_name.fetch(name, [])
  candidates = candidates.select { |record| record.fetch("version") == version } if version
  candidates = candidates.select { |record| record["source"] == source } if source
  unless candidates.one?
    raise Agentlab::Error, "expected one Cargo.lock dependency for #{reference}, found #{candidates.length}"
  end

  candidates.first
end

def identity_record(package_id)
  {
    "name" => package_id[0],
    "version" => package_id[1],
    "source" => package_id[2]
  }.compact
end

def resolver_fixed_point(selected_tree, lock_records, workspace_packages)
  lock_by_id = lock_records.to_h do |record|
    [record.values_at("name", "version", "source"), record]
  end
  lock_by_name = lock_records.group_by { |record| record.fetch("name") }
  paths = selected_tree.to_h do |package_id, tree_record|
    [package_id, tree_record.fetch("dependency_path").map(&:dup)]
  end
  references = {}
  pending = paths.keys.dup

  until pending.empty?
    pending.sort_by! { |package_id| [paths.fetch(package_id).length, JSON.generate(package_id)] }
    package_id = pending.shift
    package = lock_by_id.fetch(package_id)
    dependency_references = package.fetch("dependencies", [])
    # External package lock records omit dev dependencies; workspace records do not.
    if package["source"].nil?
      metadata = workspace_packages.fetch(package_id) do
        raise Agentlab::Error, "workspace metadata is missing #{package.fetch('name')} #{package.fetch('version')}"
      end
      nondevelopment_names = metadata.fetch("dependencies").reject do |dependency|
        dependency["kind"] == "dev"
      end.map { |dependency| dependency.fetch("name") }.to_set
      resolved_by_name = dependency_references.group_by do |reference|
        resolve_lock_dependency(reference, lock_by_name).fetch("name")
      end
      nondevelopment_names.each do |name|
        matches = resolved_by_name.fetch(name, [])
        unless matches.one?
          raise Agentlab::Error,
                "expected one non-development lock dependency #{name} for #{package.fetch('name')}, found #{matches.length}"
        end
      end
      dependency_references = dependency_references.select do |reference|
        dependency = resolve_lock_dependency(reference, lock_by_name)
        nondevelopment_names.include?(dependency.fetch("name"))
      end
    end

    dependency_references.sort.each do |reference|
      dependency = resolve_lock_dependency(reference, lock_by_name)
      dependency_id = dependency.values_at("name", "version", "source")
      candidate_path = paths.fetch(package_id) + [dependency_id]
      previous_path = paths[dependency_id]
      if previous_path
        previous_key = [previous_path.length, JSON.generate(previous_path)]
        candidate_key = [candidate_path.length, JSON.generate(candidate_path)]
        next if (previous_key <=> candidate_key) <= 0
      end

      paths[dependency_id] = candidate_path
      references[dependency_id] = {
        "required_by" => identity_record(package_id),
        "lock_reference" => reference
      }
      pending << dependency_id
    end
  end

  {
    "paths" => paths,
    "references" => references
  }
end

def stable_command(command, workspace_manifest)
  command.map { |argument| argument == workspace_manifest ? "codex-rs/Cargo.toml" : argument }
end

def safe_archive_path(path)
  pathname = Pathname(path)
  clean = pathname.cleanpath.to_s
  return nil if pathname.absolute? || clean == ".." || clean.start_with?("../")

  clean
end

def tar_header_path(header)
  name = header.name.to_s.split("\0", 2).first
  prefix = header.prefix.to_s.split("\0", 2).first
  prefix.to_s.empty? ? name : "#{prefix}/#{name}"
end

def parse_pax_headers(data)
  offset = 0
  headers = {}
  while offset < data.bytesize
    space = data.index(" ", offset)
    raise Agentlab::Error, "invalid PAX header length" unless space

    length = data.byteslice(offset, space - offset).to_i
    raise Agentlab::Error, "invalid PAX header record" unless length.positive? && offset + length <= data.bytesize

    key, value = data.byteslice(space + 1, length - (space - offset) - 1).delete_suffix("\n").split("=", 2)
    raise Agentlab::Error, "invalid PAX header value" unless key && value

    headers[key] = value
    offset += length
  end
  headers
end

def cargo_package_metadata(manifest, name, version)
  package = manifest[/^\[package\]\s*$\n(.*?)(?=^\[|\z)/m, 1]
  actual_name = package&.match(/^name\s*=\s*"([^"]+)"/)&.captures&.first
  actual_version = package&.match(/^version\s*=\s*"([^"]+)"/)&.captures&.first
  unless actual_name == name && actual_version == version
    raise Agentlab::Error, "Cargo.toml identity mismatch: expected #{name} #{version}"
  end

  license = package.match(/^license\s*=\s*"([^"]+)"$/)&.captures&.first
  license_file = package.match(/^license-file\s*=\s*"([^"]+)"$/)&.captures&.first
  raise Agentlab::Error, "Cargo.toml records both license and license-file: #{name} #{version}" if license && license_file

  if license
    { "expression" => license }
  elsif license_file
    { "file" => license_file }
  else
    {}
  end
end

def cargo_metadata_license(package)
  license = package["license"]
  license_file = package["license_file"]
  raise Agentlab::Error, "Cargo metadata records both license and license_file: #{package.fetch('name')} #{package.fetch('version')}" if license && license_file

  if license
    { "expression" => license }
  elsif license_file
    { "file" => license_file }
  else
    {}
  end
end

def cargo_archive_manifest!(archive, name, version)
  expected_root = "#{name}-#{version}"
  paths = Set.new
  roots = Set.new
  manifest = nil
  long_name = nil
  local_pax = {}
  global_pax = {}

  Zlib::GzipReader.open(archive) do |gzip|
    Gem::Package::TarReader.new(gzip) do |tar|
      tar.each do |entry|
        case entry.header.typeflag
        when "L"
          long_name = entry.read.delete_suffix("\0")
          next
        when "K"
          entry.read
          next
        when "x"
          local_pax = parse_pax_headers(entry.read)
          next
        when "g"
          global_pax.merge!(parse_pax_headers(entry.read))
          next
        end

        entry_name = local_pax["path"] || global_pax["path"] || long_name || tar_header_path(entry.header)
        path = safe_archive_path(entry_name)
        raise Agentlab::Error, "archive path escapes root: #{entry_name}" unless path
        raise Agentlab::Error, "archive contains duplicate path: #{path}" unless paths.add?(path)

        root = path.split("/", 2).first
        roots << root unless root.empty? || root == "."
        unless entry.directory? || entry.file?
          raise Agentlab::Error, "archive contains unsafe entry type #{entry.header.typeflag.inspect}: #{path}"
        end
        manifest = entry.read if entry.file? && path == "#{expected_root}/Cargo.toml"
        long_name = nil
        local_pax = {}
      end
    end
  end
  raise Agentlab::Error, "archive root mismatch for #{archive}" unless roots == Set[expected_root]
  raise Agentlab::Error, "Cargo.toml is absent from #{archive}" unless manifest

  cargo_package_metadata(manifest, name, version)
rescue Zlib::GzipFile::Error, Gem::Package::TarInvalidError => e
  raise Agentlab::Error, "cannot inspect #{archive}: #{e.message}"
end

def registry_archive_record!(cargo_home, package)
  archives = Dir.glob(File.join(cargo_home, "registry", "cache", "*", "#{package.fetch('name')}-#{package.fetch('version')}.crate")).select do |path|
    File.file?(path)
  end
  unless archives.one?
    raise Agentlab::Error,
          "expected one cached crate for #{package.fetch('name')} #{package.fetch('version')}, found #{archives.length}"
  end

  archive = archives.first
  unless Digest::SHA256.file(archive).hexdigest == package.fetch("checksum")
    raise Agentlab::Error, "Cargo checksum mismatch: #{package.fetch('name')} #{package.fetch('version')}"
  end

  {
    "package" => package,
    "archive" => archive,
    "license" => cargo_archive_manifest!(archive, package.fetch("name"), package.fetch("version"))
  }
end

def extract_cargo_archive!(archive, destination, expected_root)
  paths = Set.new
  roots = Set.new
  long_name = nil
  local_pax = {}
  global_pax = {}

  Zlib::GzipReader.open(archive) do |gzip|
    Gem::Package::TarReader.new(gzip) do |tar|
      tar.each do |entry|
        case entry.header.typeflag
        when "L"
          long_name = entry.read.delete_suffix("\0")
          next
        when "K"
          entry.read
          next
        when "x"
          local_pax = parse_pax_headers(entry.read)
          next
        when "g"
          global_pax.merge!(parse_pax_headers(entry.read))
          next
        end

        entry_name = local_pax["path"] || global_pax["path"] || long_name || tar_header_path(entry.header)
        path = safe_archive_path(entry_name)
        raise Agentlab::Error, "archive path escapes root: #{entry_name}" unless path
        raise Agentlab::Error, "archive contains duplicate path: #{path}" unless paths.add?(path)

        root = path.split("/", 2).first
        roots << root unless root.empty? || root == "."
        raise Agentlab::Error, "unexpected archive root #{root.inspect}, expected #{expected_root}" unless root == expected_root

        target = File.join(destination, path)
        if entry.directory?
          FileUtils.mkdir_p(target)
        elsif entry.file?
          FileUtils.mkdir_p(File.dirname(target))
          File.open(target, "wb", entry.header.mode & 0o777) { |file| IO.copy_stream(entry, file) }
        else
          raise Agentlab::Error, "archive contains unsafe entry type #{entry.header.typeflag.inspect}: #{path}"
        end
        long_name = nil
        local_pax = {}
      end
    end
  end
  raise Agentlab::Error, "archive root mismatch for #{archive}" unless roots == Set[expected_root]
rescue Zlib::GzipFile::Error, Gem::Package::TarInvalidError => e
  raise Agentlab::Error, "cannot extract #{archive}: #{e.message}"
end

def regular_files(root)
  Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).select do |path|
    File.file?(path) && !File.symlink?(path) && ![".", ".."].include?(File.basename(path))
  end.sort
end

def write_cargo_checksum!(root, package_checksum)
  files = regular_files(root).to_h do |path|
    [path.delete_prefix("#{root}/"), Digest::SHA256.file(path).hexdigest]
  end
  File.write(
    File.join(root, ".cargo-checksum.json"),
    JSON.generate("files" => files, "package" => package_checksum) + "\n"
  )
end

def verify_cargo_checksum!(root, package_checksum)
  checksum_path = File.join(root, ".cargo-checksum.json")
  raise Agentlab::Error, "missing Cargo checksum metadata in #{root}" unless File.file?(checksum_path)

  checksum = JSON.parse(File.read(checksum_path))
  raise Agentlab::Error, "Cargo package checksum mismatch in #{root}" unless checksum["package"] == package_checksum

  files = regular_files(root).reject { |path| path == checksum_path }.to_h do |path|
    [path.delete_prefix("#{root}/"), Digest::SHA256.file(path).hexdigest]
  end
  raise Agentlab::Error, "Cargo file checksums mismatch in #{root}" unless checksum.fetch("files") == files
end

def vendor_tree_receipt(root)
  digest = Digest::SHA256.new
  files = 0
  directories = 0
  bytes = 0
  paths = Dir.glob(File.join(root, "**", "*"), File::FNM_DOTMATCH).reject do |path|
    [".", ".."].include?(File.basename(path))
  end.sort

  paths.each do |path|
    stat = File.lstat(path)
    relative = path.delete_prefix("#{root}/")
    mode = stat.mode & 0o777
    if stat.directory?
      directories += 1
      digest.update(["directory", relative, format("%04o", mode)].join("\0") + "\0")
    elsif stat.file?
      files += 1
      bytes += stat.size
      digest.update(["file", relative, format("%04o", mode), stat.size, Digest::SHA256.file(path).hexdigest].join("\0") + "\0")
    else
      raise Agentlab::Error, "unsupported vendor-tree entry: #{relative}"
    end
  end

  {
    "sha256" => digest.hexdigest,
    "files" => files,
    "directories" => directories,
    "file_bytes" => bytes
  }
end

def deterministic_tar_gz!(source_parent, root_name, output, workdir)
  tar_path = File.join(workdir, "#{root_name}.tar")
  capture_command(
    {},
    ["tar", "--sort=name", "--mtime=@0", "--owner=0", "--group=0", "--numeric-owner", "--format=gnu", "-cf", tar_path, "-C", source_parent, root_name],
    "deterministic Cargo vendor archive"
  )
  Zlib::GzipWriter.open(output) do |gzip|
    gzip.mtime = 0
    File.open(tar_path, "rb") { |tar| IO.copy_stream(tar, gzip) }
  end
ensure
  FileUtils.rm_f(tar_path) if tar_path
end

def manifest_identity_content(content)
  package = content[/^\[package\]\s*$\n(.*?)(?=^\[|\z)/m, 1]
  name = package&.match(/^name\s*=\s*"([^"]+)"/)&.captures&.first
  version = package&.match(/^version\s*=\s*"([^"]+)"/)&.captures&.first
  name && version ? [name, version] : nil
end

def manifest_identity(path)
  manifest_identity_content(File.read(path))
end

def git_package_manifest_at_commit(checkout, commit, package)
  identity = package.values_at("name", "version")
  manifest_paths = capture_command(
    {},
    ["git", "-C", checkout, "ls-tree", "-r", "--name-only", commit],
    "Git commit manifest listing"
  ).lines(chomp: true).select { |path| File.basename(path) == "Cargo.toml" }
  matches = manifest_paths.filter_map do |path|
    content = capture_command(
      {},
      ["git", "-C", checkout, "show", "#{commit}:#{path}"],
      "Git commit manifest read"
    )
    [path, content] if manifest_identity_content(content) == identity
  end
  raise Agentlab::Error, "expected one Git commit manifest for #{identity.join(' ')}, found #{matches.length}" unless matches.one?

  matches.first
end

def package_manifest_path(checkout, package)
  identity = package.values_at("name", "version")
  matches = Dir.glob(File.join(checkout, "**", "Cargo.toml")).select { |path| manifest_identity(path) == identity }
  raise Agentlab::Error, "expected one Git manifest for #{identity.join(' ')}, found #{matches.length}" unless matches.one?

  matches.first
end

def selected_git_dependency(content, dependency_name, git_url, selected_packages)
  package_name = content.match(/^package\s*=\s*"([^"]+)"$/)&.captures&.first || dependency_name
  matches = selected_packages.select do |package|
    package.fetch("name") == package_name && normalize_git_url(package.fetch("source")) == normalize_git_url(git_url)
  end
  raise Agentlab::Error, "expected one selected Git dependency for #{package_name} from #{git_url}, found #{matches.length}" unless matches.one?

  matches.first
end

def add_missing_git_dependency_versions(content, selected_packages)
  content.gsub(/(^\[(?:target\..+\.)?dependencies\.([^\]]+)\]\n)(.*?)(?=^\[|\z)/m) do
    header = Regexp.last_match(1)
    dependency_name = Regexp.last_match(2).delete_prefix('"').delete_suffix('"')
    body = Regexp.last_match(3)
    git_url = body.match(/^git\s*=\s*"([^"]+)"$/)&.captures&.first
    next "#{header}#{body}" unless git_url && !body.match?(/^version\s*=/)

    selected = selected_git_dependency(body, dependency_name, git_url, selected_packages)
    "#{header}version = #{selected.fetch('version').dump}\n#{body}"
  end
end

def selected_dependency_source_restorations(original_manifest, repository, commit, selected_packages)
  restorations = []
  original_manifest.scan(/^\[(?<prefix>(?:target\..+\.)?dependencies)\.(?<key>[^\]]+)\]\n(?<body>.*?)(?=^\[|\z)/m) do
    prefix = Regexp.last_match[:prefix]
    key = Regexp.last_match[:key]
    body = Regexp.last_match[:body]
    git_url = body.match(/^git\s*=\s*"([^"]+)"$/)&.captures&.first
    next unless git_url

    dependency_name = key.delete_prefix('"').delete_suffix('"')
    selected = selected_git_dependency(body, dependency_name, git_url, selected_packages)
    restorations << ["#{prefix}.#{key}", git_url, selected.fetch("source").split("#", 2).last]
  end

  dependencies = original_manifest[/^\[dependencies\]\n(.*?)(?=^\[|\z)/m, 1]
  dependencies.to_s.each_line do |line|
    match = line.match(/^([A-Za-z0-9_-]+)\s*=\s*\{(.*)\}\s*$/)
    next unless match

    dependency_name, fields = match.captures
    git_url = fields.match(/\bgit\s*=\s*"([^"]+)"/)&.captures&.first
    path = fields.match(/\bpath\s*=\s*"([^"]+)"/)&.captures&.first
    next unless git_url || path

    package_name = fields.match(/\bpackage\s*=\s*"([^"]+)"/)&.captures&.first || dependency_name
    version = fields.match(/\bversion\s*=\s*"([^"]+)"/)&.captures&.first
    matches = selected_packages.select do |package|
      package.fetch("name") == package_name &&
        (!version || package.fetch("version") == version) &&
        normalize_git_url(package.fetch("source")) == normalize_git_url(git_url || repository)
    end
    raise Agentlab::Error, "expected one selected dependency source for #{package_name}, found #{matches.length}" unless matches.one?

    source_url = git_url || repository
    source_commit = git_url ? matches.first.fetch("source").split("#", 2).last : commit
    restorations << ["dependencies.#{dependency_name}", source_url, source_commit]
  end
  restorations
end

def restore_selected_dependency_sources!(manifest_path, original_manifest, repository, commit, selected_packages)
  content = File.read(manifest_path)
  selected_dependency_source_restorations(original_manifest, repository, commit, selected_packages).each do |section, git_url, source_commit|
    pattern = /(^\[#{Regexp.escape(section)}\]\n)/
    raise Agentlab::Error, "normalized Cargo manifest is missing dependency section #{section}" unless content.match?(pattern)
    raise Agentlab::Error, "normalized Cargo manifest already records a Git source for #{section}" if content[/^\[#{Regexp.escape(section)}\]\n(.*?)(?=^\[|\z)/m, 1].to_s.match?(/^git\s*=/)

    content.sub!(pattern, "\\1git = #{git_url.dump}\nrev = #{source_commit.dump}\n")
  end
  File.write(manifest_path, content)
end

def git_resolves_commit?(path, commit)
  stdout, = Open3.capture3("git", "-C", path, "rev-parse", "#{commit}^{commit}")
  stdout.strip == commit
end

def git_fetch_head_matches?(path, repository, commit)
  fetch_head = File.join(path, "FETCH_HEAD")
  return false unless File.file?(fetch_head)

  File.foreach(fetch_head).any? do |line|
    fetched_commit, description = line.chomp.split("\t", 2)
    fetched_repository = description&.split(" of ", 2)&.last
    fetched_commit == commit && fetched_repository &&
      normalize_git_url(fetched_repository) == normalize_git_url(repository)
  end
end

def verify_git_source!(cargo_home, repository, commit, packages)
  git_root = File.join(cargo_home, "git")
  database_matches = Dir.glob(File.join(git_root, "db", "*")).select do |path|
    File.directory?(path) && git_resolves_commit?(path, commit) &&
      git_fetch_head_matches?(path, repository, commit)
  end
  raise Agentlab::Error, "expected one Git cache for #{repository} at #{commit}, found #{database_matches.length}" unless database_matches.one?

  checkout_matches = Dir.glob(File.join(git_root, "checkouts", "*", "*")).select do |path|
    next false unless File.directory?(path)

    capture_command({}, ["git", "-C", path, "remote", "get-url", "origin"], "Git checkout URL query").strip == "file://#{database_matches.first}" &&
      git_resolves_commit?(path, commit) && capture_command({}, ["git", "-C", path, "rev-parse", "HEAD"], "Git checkout commit query").strip == commit
  end
  raise Agentlab::Error, "expected one Git checkout for #{repository} at #{commit}, found #{checkout_matches.length}" unless checkout_matches.one?
  tracked_changes = capture_command(
    {},
    ["git", "-C", checkout_matches.first, "status", "--short", "--untracked-files=no"],
    "Git checkout tracked-state query"
  )
  raise Agentlab::Error, "Git checkout has tracked changes for #{repository} at #{commit}" unless tracked_changes.empty?

  identities = Dir.glob(File.join(checkout_matches.first, "**", "Cargo.toml")).filter_map { |path| manifest_identity(path) }
  packages.each do |package|
    identity = [package.fetch("name"), package.fetch("version")]
    unless identities.count(identity) == 1
      raise Agentlab::Error, "Git checkout identity mismatch for #{repository}: #{identity.join(' ')}"
    end
  end
  checkout_matches.first
end

def cargo_vendor_manifest(packages)
  manifest = packages.select { |package| %w[registry git].include?(package.fetch("origin")) }.map do |package|
    if package.fetch("origin") == "git"
      "#{package.fetch('name')} v#{package.fetch('version')} (#{package.fetch('source').delete_prefix('git+')})"
    else
      "#{package.fetch('name')} v#{package.fetch('version')}"
    end
  end.sort
  raise Agentlab::Error, "vendor plan has duplicate source entries" unless manifest.uniq.length == manifest.length

  manifest
end

def verify_selected_sources!(receipt, source_lock, cargo_home)
  packages = receipt.fetch("packages")
  counts = receipt.fetch("counts")
  raise Agentlab::Error, "receipt selected package count mismatch" unless packages.length == counts.fetch("selected_packages")
  raise Agentlab::Error, "receipt has duplicate selected packages" unless packages.map { |package| package.values_at("name", "version", "source") }.uniq.length == packages.length

  lock_records = parse_lock_packages(source_lock)
  selected_registry = packages.select { |package| package.fetch("origin") == "registry" }
  registry_plan = []
  selected_registry.each do |package|
    lock_matches = lock_records.select do |record|
      record.values_at("name", "version", "source", "checksum") == package.values_at("name", "version", "source", "checksum")
    end
    raise Agentlab::Error, "lock/receipt mismatch for #{package.fetch('name')} #{package.fetch('version')}" unless lock_matches.one?

    registry_plan << registry_archive_record!(cargo_home, package)
  end

  selected_git = packages.select { |package| package.fetch("origin") == "git" }.group_by do |package|
    normalize_git_url(package.fetch("source"))
  end
  selected_git.values.flatten.each do |package|
    matches = lock_records.select { |record| record.values_at("name", "version", "source") == package.values_at("name", "version", "source") }
    raise Agentlab::Error, "lock/receipt mismatch for Git package #{package.fetch('name')} #{package.fetch('version')}" unless matches.one?
  end
  expected_git = receipt.fetch("git_sources").select { |source| source.fetch("selected") }.to_h do |source|
    [normalize_git_url(source.fetch("repository")), source]
  end
  unless selected_git.keys.sort == expected_git.keys.sort
    raise Agentlab::Error, "selected Git sources do not match the receipt Git-source plan"
  end
  git_plan = []
  selected_git.each do |repository, git_packages|
    expected = expected_git.fetch(repository)
    expected_packages = expected.fetch("packages").map { |package| package.values_at("name", "version") }.sort
    actual_packages = git_packages.map { |package| package.values_at("name", "version") }.sort
    raise Agentlab::Error, "selected Git package set mismatch for #{repository}" unless actual_packages == expected_packages
    commits = git_packages.map { |package| package.fetch("source").split("#", 2)[1] }.uniq
    raise Agentlab::Error, "selected Git commit mismatch for #{repository}" unless commits == [expected.fetch("commit")]

    checkout = verify_git_source!(cargo_home, repository, expected.fetch("commit"), git_packages)
    git_plan << {
      "repository" => expected.fetch("repository"),
      "commit" => expected.fetch("commit"),
      "packages" => git_packages,
      "checkout" => checkout
    }
  end

  extras = lock_records.reject do |record|
    packages.any? { |package| package.values_at("name", "version", "source") == record.values_at("name", "version", "source") }
  end.group_by { |record| source_origin(record["source"]) }.transform_values(&:length)
  vendor_manifest = cargo_vendor_manifest(packages)

  provides_status = "not checked (cargo2rpm unavailable)"
  if Agentlab.command_available?("cargo2rpm")
    provides = capture_command({}, ["cargo2rpm", "-p", "/dev/stdin", "parse-vendor-manifest"], "Cargo vendor manifest parse", stdin_data: vendor_manifest.join("\n") + "\n").lines(chomp: true)
    raise Agentlab::Error, "cargo2rpm bundled Provides are not unique" unless provides.uniq.length == provides.length && provides.length == vendor_manifest.length

    provides_status = "#{provides.length} unique (cargo2rpm)"
  end

  puts "Verified selected Cargo sources: #{selected_registry.length} registry archives, #{selected_git.values.sum(&:length)} Git packages from #{selected_git.length} repositories"
  puts "Full lock extras (not selected): #{extras.fetch('registry', 0)} registry, #{extras.fetch('git', 0)} Git, #{extras.fetch('path', 0)} path"
  puts "Vendor plan: #{vendor_manifest.length} entries, SHA-256 #{Digest::SHA256.hexdigest(vendor_manifest.join("\n") + "\n")}; bundled Provides #{provides_status}"
  {
    "registry" => registry_plan,
    "git" => git_plan.sort_by { |record| normalize_git_url(record.fetch("repository")) },
    "manifest" => vendor_manifest
  }
end

def verify_resolver_sources!(supplement, selected_receipt, source_lock, cargo_home)
  packages = supplement.fetch("packages")
  counts = supplement.fetch("counts")
  unless packages.length == counts.fetch("resolver_only_packages")
    raise Agentlab::Error, "resolver supplement package count mismatch"
  end
  identities = packages.map { |package| package.values_at("name", "version", "source") }
  raise Agentlab::Error, "resolver supplement has duplicate packages" unless identities.uniq.length == identities.length

  selected_identities = selected_receipt.fetch("packages").map do |package|
    package.values_at("name", "version", "source")
  end
  overlap = identities & selected_identities
  raise Agentlab::Error, "resolver supplement overlaps the authoritative selected closure" unless overlap.empty?
  unless packages.all? { |package| package.fetch("origin") == "registry" }
    raise Agentlab::Error, "current resolver supplement must contain only registry packages"
  end

  lock_records = parse_lock_packages(source_lock)
  registry_plan = packages.map do |package|
    lock_matches = lock_records.select do |record|
      record.values_at("name", "version", "source", "checksum") == package.values_at("name", "version", "source", "checksum")
    end
    unless lock_matches.one?
      raise Agentlab::Error, "lock/resolver mismatch for #{package.fetch('name')} #{package.fetch('version')}"
    end

    archive_record = registry_archive_record!(cargo_home, package)
    unless archive_record.fetch("license") == package.fetch("license") && !package.fetch("license").empty?
      raise Agentlab::Error, "resolver license metadata mismatch for #{package.fetch('name')} #{package.fetch('version')}"
    end
    archive_record
  end
  manifest = cargo_vendor_manifest(packages)
  puts "Verified resolver-only Cargo sources: #{registry_plan.length} registry archives"
  {
    "registry" => registry_plan,
    "git" => [],
    "manifest" => manifest
  }
end

def materialize_git_packages!(git_plan, cargo_home, vendor_root, workdir)
  selected_packages = git_plan.flat_map { |source| source.fetch("packages") }
  git_plan.each_with_index do |git_source, source_index|
    source_workdir = File.join(workdir, format("git-source-%02d", source_index))
    target_dir = File.join(source_workdir, "target")
    checkout_copy = File.join(source_workdir, "checkout")
    FileUtils.mkdir_p(source_workdir)
    FileUtils.cp_r(git_source.fetch("checkout"), checkout_copy, preserve: true)
    manifest_path = File.join(checkout_copy, "Cargo.toml")
    environment = { "CARGO_HOME" => cargo_home }

    git_source.fetch("packages").each do |package|
      root_name = "#{package.fetch('name')}-#{package.fetch('version')}"
      target = File.join(vendor_root, root_name)
      raise Agentlab::Error, "duplicate Cargo vendor directory: #{target}" if File.exist?(target)

      original_manifest_path = package_manifest_path(git_source.fetch("checkout"), package)
      relative_manifest_path = original_manifest_path.delete_prefix("#{git_source.fetch('checkout')}/")
      package_manifest_copy = File.join(checkout_copy, relative_manifest_path)
      original_manifest = File.read(original_manifest_path)
      File.write(package_manifest_copy, add_missing_git_dependency_versions(original_manifest, selected_packages))

      capture_command(
        environment,
        [
          "cargo", "package",
          "--manifest-path", manifest_path,
          "--package", package.fetch("name"),
          "--target-dir", target_dir,
          "--allow-dirty",
          "--no-verify",
          "--exclude-lockfile",
          "--offline"
        ],
        "Cargo Git package normalization for #{package.fetch('name')} #{package.fetch('version')}"
      )
      archive = File.join(target_dir, "package", "#{root_name}.crate")
      raise Agentlab::Error, "missing Cargo-normalized Git package archive: #{archive}" unless File.file?(archive)

      cargo_archive_manifest!(archive, package.fetch("name"), package.fetch("version"))
      extract_cargo_archive!(archive, vendor_root, root_name)
      FileUtils.rm_f(File.join(target, ".cargo_vcs_info.json"))
      File.write(File.join(target, "Cargo.toml.orig"), original_manifest)
      restore_selected_dependency_sources!(
        File.join(target, "Cargo.toml"),
        original_manifest,
        git_source.fetch("repository"),
        git_source.fetch("commit"),
        selected_packages
      )
      write_cargo_checksum!(target, nil)
      verify_cargo_checksum!(target, nil)
    end
  end
end

def cargo_vendor_config(receipt, vendor_root_name)
  git_sources = receipt.fetch("packages").select { |package| package.fetch("origin") == "git" }.group_by do |package|
    package.fetch("source").split("#", 2).first
  end
  source_blocks = git_sources.sort.map do |source, packages|
    commits = packages.map { |package| package.fetch("source").split("#", 2).last }.uniq
    raise Agentlab::Error, "Git source has multiple commits: #{source}" unless commits.one?

    url = source.delete_prefix("git+").split("?", 2).first
    <<~TOML
      [source.#{source.dump}]
      git = #{url.dump}
      rev = #{commits.first.dump}
      replace-with = "vendored-sources"

    TOML
  end
  <<~TOML
    # Selected Linux build-closure evidence only. Cargo directory-source
    # resolution also requests inactive-target dependencies absent by design.
    [net]
    offline = true

    [source.crates-io]
    replace-with = "vendored-sources"

    #{source_blocks.join}
    [source.vendored-sources]
    directory = #{vendor_root_name.dump}
  TOML
end

def cargo_resolver_vendor_config(receipt, vendor_root_name)
  git_sources = receipt.fetch("packages").select { |package| package.fetch("origin") == "git" }.group_by do |package|
    package.fetch("source").split("#", 2).first
  end
  source_blocks = git_sources.sort.map do |source, packages|
    commits = packages.map { |package| package.fetch("source").split("#", 2).last }.uniq
    raise Agentlab::Error, "Git source has multiple commits: #{source}" unless commits.one?

    url = source.delete_prefix("git+").split("?", 2).first
    <<~TOML
      [source.#{source.dump}]
      git = #{url.dump}
      rev = #{commits.first.dump}
      replace-with = "vendored-sources"

    TOML
  end
  <<~TOML
    # Authoritative selected Linux sources plus a separately recorded
    # resolver-only all-target normal/build supplement.
    [source.crates-io]
    replace-with = "vendored-sources"

    #{source_blocks.join}
    [source.vendored-sources]
    directory = #{vendor_root_name.dump}
  TOML
end

def materialize_vendor!(receipt, closure_receipt_path, normalized_lock, cargo_home, output_root, external_receipt, check, work_dir_root)
  raise Agentlab::Error, "missing tool: tar" unless Agentlab.command_available?("tar")

  output_root = File.expand_path(output_root)
  output_root_created = !File.exist?(output_root)
  FileUtils.mkdir_p(output_root)
  vendor_root_name = "codex-cli-#{receipt.dig('release', 'version')}-selected-cargo-vendor"
  vendor_root = File.join(output_root, vendor_root_name)
  archive_path = File.join(output_root, "#{vendor_root_name}.tar.gz")
  manifest_path = File.join(output_root, "#{vendor_root_name}.txt")
  config_path = File.join(output_root, "#{vendor_root_name}.config.toml")
  receipt_path = File.join(output_root, "#{vendor_root_name}-receipt.json")
  [vendor_root, archive_path, manifest_path, config_path, receipt_path].each do |path|
    raise Agentlab::Error, "refusing to replace existing vendor output: #{path}" if File.exist?(path)
  end

  begin
    source_plan = verify_selected_sources!(receipt, normalized_lock, cargo_home)
    FileUtils.mkdir_p(vendor_root)
    source_plan.fetch("registry").each do |record|
      package = record.fetch("package")
      root_name = "#{package.fetch('name')}-#{package.fetch('version')}"
      target_root = File.join(vendor_root, root_name)
      raise Agentlab::Error, "duplicate Cargo vendor directory: #{target_root}" if File.exist?(target_root)

      extract_cargo_archive!(record.fetch("archive"), vendor_root, root_name)
      write_cargo_checksum!(target_root, package.fetch("checksum"))
      verify_cargo_checksum!(target_root, package.fetch("checksum"))
    end

    Dir.mktmpdir("agentlab-codex-vendor-", work_dir_root) do |workdir|
      materialize_git_packages!(source_plan.fetch("git"), cargo_home, vendor_root, workdir)
      expected_directories = receipt.fetch("packages").select do |package|
        %w[registry git].include?(package.fetch("origin"))
      end.map { |package| "#{package.fetch('name')}-#{package.fetch('version')}" }.sort
      actual_directories = Dir.children(vendor_root).select { |entry| File.directory?(File.join(vendor_root, entry)) }.sort
      raise Agentlab::Error, "materialized Cargo vendor directory set differs from the receipt" unless actual_directories == expected_directories

      manifest = source_plan.fetch("manifest").join("\n") + "\n"
      config = cargo_vendor_config(receipt, vendor_root_name)
      File.write(manifest_path, manifest)
      File.write(config_path, config)
      tree = vendor_tree_receipt(vendor_root)
      deterministic_tar_gz!(output_root, vendor_root_name, archive_path, workdir)
      cargo_version = capture_command({ "CARGO_HOME" => cargo_home }, ["cargo", "--version"], "Cargo version query").strip
      vendor_receipt = {
        "schema" => "agentlab-codex-selected-cargo-vendor/v1",
        "release" => receipt.fetch("release").slice("version", "source_tag", "source_commit", "source_sha256", "normalized_cargo_lock_sha256"),
        "selection" => receipt.fetch("selection"),
        "closure_receipt" => {
          "name" => File.basename(closure_receipt_path),
          "sha256" => Digest::SHA256.file(closure_receipt_path).hexdigest
        },
        "counts" => {
          "vendor_directories" => expected_directories.length,
          "registry_packages" => source_plan.fetch("registry").length,
          "git_packages" => source_plan.fetch("git").sum { |source| source.fetch("packages").length },
          "git_repositories" => source_plan.fetch("git").length
        },
        "generator" => {
          "script" => "scripts/audit-codex-cargo-closure",
          "cargo_version" => cargo_version,
          "registry_materialization" => "checked archive extraction with generated Cargo checksums",
          "git_materialization" => "Cargo package-normalized selected Git packages with restored pinned selected-source dependencies",
          "selected_sources_exactly_materialized" => true,
          "transient_dependency_directories_archived" => false
        },
        "resolution" => {
          "standalone_offline_directory_source_verified" => false,
          "blocker" => "Cargo resolves inactive-target dependency metadata from selected package manifests and requests sources outside the checked Linux closure, including chrono's js-sys dependency; adding them would broaden the authoritative source and license scope.",
          "required_action" => "Keep the package build fail-closed pending a reviewed resolver-complete source model."
        },
        "vendor_tree" => tree.merge("root" => vendor_root_name),
        "vendor_manifest" => {
          "name" => File.basename(manifest_path),
          "entries" => source_plan.fetch("manifest").length,
          "sha256" => Digest::SHA256.file(manifest_path).hexdigest
        },
        "cargo_config" => {
          "name" => File.basename(config_path),
          "purpose" => "prospective source replacement for selected evidence; not a standalone-resolvable Cargo source",
          "sha256" => Digest::SHA256.file(config_path).hexdigest
        },
        "archive" => {
          "name" => File.basename(archive_path),
          "size_bytes" => File.size(archive_path),
          "sha256" => Digest::SHA256.file(archive_path).hexdigest
        },
        "scope" => "deterministic evidence for the exact selected Linux Cargo source closure; not a standalone offline Cargo directory source, build proof, license closure, or publication artifact"
      }
      rendered = JSON.pretty_generate(vendor_receipt) + "\n"
      Agentlab.atomic_write(receipt_path, rendered)
      if external_receipt
        if check
          raise Agentlab::Error, "missing vendor receipt: #{external_receipt}" unless File.file?(external_receipt)
          raise Agentlab::Error, "Codex Cargo vendor receipt is stale" unless File.read(external_receipt) == rendered
        else
          FileUtils.mkdir_p(File.dirname(external_receipt))
          Agentlab.atomic_write(external_receipt, rendered)
        end
      end

      puts "Materialized #{expected_directories.length} selected Cargo sources: tree #{tree.fetch('sha256')}, archive #{vendor_receipt.dig('archive', 'sha256')}"
    end
  rescue StandardError
    FileUtils.rm_rf(vendor_root)
    [archive_path, manifest_path, config_path, receipt_path].each { |path| FileUtils.rm_f(path) }
    Dir.rmdir(output_root) if output_root_created && Dir.exist?(output_root) && Dir.empty?(output_root)
    raise
  end
end

def stable_resolution_command(command, workspace_manifest, config_path)
  command.map do |argument|
    if argument == workspace_manifest
      "codex-rs/Cargo.toml"
    elsif argument == config_path
      File.basename(config_path)
    else
      argument
    end
  end
end

def verify_resolver_vendor_resolution!(
  source_dir,
  normalized_lock,
  target,
  selected_receipt,
  resolver_supplement,
  config_path,
  vendor_root,
  workdir
)
  resolution_source = File.join(workdir, "resolution-source")
  resolution_cargo_home = File.join(workdir, "resolution-cargo-home")
  FileUtils.cp_r(source_dir, resolution_source, preserve: true)
  FileUtils.mkdir_p(resolution_cargo_home)
  workspace_manifest = File.join(resolution_source, "codex-rs", "Cargo.toml")
  File.write(File.join(resolution_source, "codex-rs", "Cargo.lock"), normalized_lock)
  proof_config_path = File.join(workdir, File.basename(config_path))
  portable_directory = "directory = #{File.basename(vendor_root).dump}"
  proof_config = File.read(config_path)
  unless proof_config.scan(portable_directory).length == 1
    raise Agentlab::Error, "resolver Cargo configuration directory is not an exact portable path"
  end
  File.write(proof_config_path, proof_config.sub(portable_directory, "directory = #{vendor_root.dump}"))
  environment = {
    "CARGO_HOME" => resolution_cargo_home,
    "RUSTC_BOOTSTRAP" => "1"
  }
  command_base = [
    "cargo", "tree",
    "--manifest-path", workspace_manifest,
    "--locked",
    "--package", "codex-cli",
    "-Z", "avoid-dev-deps",
    "--prefix", "depth",
    "--format", "{p}|{f}",
    "--edges", "normal,build",
    "--offline",
    "--config", proof_config_path
  ]
  selected_command = command_base + ["--target", target]
  all_targets_command = command_base + ["--target", "all"]
  selected_output = capture_command(environment, selected_command, "combined vendor selected-target Cargo resolution")
  all_targets_output = capture_command(environment, all_targets_command, "combined vendor all-target Cargo resolution")

  lock_by_name_version = parse_lock_packages(normalized_lock).group_by do |record|
    [record.fetch("name"), record.fetch("version")]
  end
  selected_tree = parse_tree(selected_output, lock_by_name_version, resolution_source)
  all_targets_tree = parse_tree(all_targets_output, lock_by_name_version, resolution_source)
  expected_selected = selected_receipt.fetch("packages").map do |package|
    package.values_at("name", "version", "source")
  end.to_set
  active_resolver_packages = resolver_supplement.fetch("packages").select do |package|
    package.fetch("active_in_all_target_graph")
  end
  expected_all_targets = (selected_receipt.fetch("packages") + active_resolver_packages).map do |package|
    package.values_at("name", "version", "source")
  end.to_set
  unless selected_tree.keys.to_set == expected_selected
    raise Agentlab::Error, "combined vendor selected-target resolution differs from the authoritative closure"
  end
  unless all_targets_tree.keys.to_set == expected_all_targets
    raise Agentlab::Error, "combined vendor all-target resolution differs from the resolver fixed point"
  end

  {
    "selected_target" => {
      "verified" => true,
      "packages" => selected_tree.length,
      "command" => stable_resolution_command(selected_command, workspace_manifest, proof_config_path)
    },
    "all_targets" => {
      "verified" => true,
      "packages" => all_targets_tree.length,
      "command" => stable_resolution_command(all_targets_command, workspace_manifest, proof_config_path)
    },
    "empty_cargo_home" => true,
    "portable_directory_path_rewritten_for_proof" => true,
    "fedora_avoid_dev_deps" => true
  }
end

def materialize_resolver_vendor!(
  receipt,
  resolver_supplement,
  closure_receipt_path,
  resolver_supplement_path,
  source_dir,
  normalized_lock,
  cargo_home,
  output_root,
  external_receipt,
  check,
  work_dir_root
)
  raise Agentlab::Error, "missing tool: tar" unless Agentlab.command_available?("tar")

  output_root = File.expand_path(output_root)
  output_root_created = !File.exist?(output_root)
  FileUtils.mkdir_p(output_root)
  vendor_root_name = "codex-cli-#{receipt.dig('release', 'version')}-resolver-cargo-vendor"
  vendor_root = File.join(output_root, vendor_root_name)
  archive_path = File.join(output_root, "#{vendor_root_name}.tar.gz")
  manifest_path = File.join(output_root, "#{vendor_root_name}.txt")
  config_path = File.join(output_root, "#{vendor_root_name}.config.toml")
  receipt_path = File.join(output_root, "#{vendor_root_name}-receipt.json")
  [vendor_root, archive_path, manifest_path, config_path, receipt_path].each do |path|
    raise Agentlab::Error, "refusing to replace existing vendor output: #{path}" if File.exist?(path)
  end

  begin
    selected_plan = verify_selected_sources!(receipt, normalized_lock, cargo_home)
    resolver_plan = verify_resolver_sources!(resolver_supplement, receipt, normalized_lock, cargo_home)
    combined_packages = receipt.fetch("packages") + resolver_supplement.fetch("packages")
    expected_directories = combined_packages.select do |package|
      %w[registry git].include?(package.fetch("origin"))
    end.map { |package| "#{package.fetch('name')}-#{package.fetch('version')}" }.sort
    unless expected_directories.uniq.length == expected_directories.length
      raise Agentlab::Error, "combined Cargo vendor plan has colliding package directories"
    end

    FileUtils.mkdir_p(vendor_root)
    (selected_plan.fetch("registry") + resolver_plan.fetch("registry")).each do |record|
      package = record.fetch("package")
      root_name = "#{package.fetch('name')}-#{package.fetch('version')}"
      target_root = File.join(vendor_root, root_name)
      raise Agentlab::Error, "duplicate Cargo vendor directory: #{target_root}" if File.exist?(target_root)

      extract_cargo_archive!(record.fetch("archive"), vendor_root, root_name)
      write_cargo_checksum!(target_root, package.fetch("checksum"))
      verify_cargo_checksum!(target_root, package.fetch("checksum"))
    end

    Dir.mktmpdir("agentlab-codex-resolver-vendor-", work_dir_root) do |workdir|
      materialize_git_packages!(selected_plan.fetch("git"), cargo_home, vendor_root, workdir)
      actual_directories = Dir.children(vendor_root).select do |entry|
        File.directory?(File.join(vendor_root, entry))
      end.sort
      unless actual_directories == expected_directories
        raise Agentlab::Error, "combined Cargo vendor directory set differs from the selected closure plus resolver supplement"
      end

      manifest = cargo_vendor_manifest(combined_packages).join("\n") + "\n"
      config = cargo_resolver_vendor_config(receipt, vendor_root_name)
      File.write(manifest_path, manifest)
      File.write(config_path, config)
      resolution = verify_resolver_vendor_resolution!(
        source_dir,
        normalized_lock,
        receipt.dig("selection", "target_triple"),
        receipt,
        resolver_supplement,
        config_path,
        vendor_root,
        workdir
      )
      tree = vendor_tree_receipt(vendor_root)
      deterministic_tar_gz!(output_root, vendor_root_name, archive_path, workdir)
      selected_external = receipt.fetch("packages").count { |package| %w[registry git].include?(package.fetch("origin")) }
      resolver_external = resolver_supplement.fetch("packages").count do |package|
        %w[registry git].include?(package.fetch("origin"))
      end
      vendor_receipt = {
        "schema" => "agentlab-codex-resolver-cargo-vendor/v2",
        "release" => receipt.fetch("release").slice("version", "source_tag", "source_commit", "source_sha256", "normalized_cargo_lock_sha256"),
        "selection" => receipt.fetch("selection"),
        "closure_receipt" => {
          "name" => File.basename(closure_receipt_path),
          "sha256" => Digest::SHA256.file(closure_receipt_path).hexdigest
        },
        "resolver_supplement" => {
          "name" => File.basename(resolver_supplement_path),
          "sha256" => Digest::SHA256.file(resolver_supplement_path).hexdigest
        },
        "counts" => {
          "vendor_directories" => expected_directories.length,
          "selected_vendor_directories" => selected_external,
          "resolver_only_vendor_directories" => resolver_external,
          "registry_packages" => selected_plan.fetch("registry").length + resolver_plan.fetch("registry").length,
          "git_packages" => selected_plan.fetch("git").sum { |source| source.fetch("packages").length },
          "git_repositories" => selected_plan.fetch("git").length
        },
        "generator" => {
          "script" => "scripts/audit-codex-cargo-closure",
          "registry_materialization" => "checked archive extraction with generated Cargo checksums",
          "git_materialization" => "Cargo package-normalized selected Git packages with restored pinned selected-source dependencies",
          "resolver_strategy" => "non-development workspace-manifest and external lock dependency fixed point, with Cargo all-target resolution as the active-target witness",
          "transient_dependency_directories_archived" => false,
          "exact_cargo_version_is_normative" => false
        },
        "resolution" => {
          "standalone_offline_directory_source_verified" => true,
          "proof" => resolution,
          "authoritative_linux_closure_unchanged" => true,
          "resolver_only_sources_linked_on_authoritative_target" => false
        },
        "vendor_tree" => tree.merge("root" => vendor_root_name),
        "vendor_manifest" => {
          "name" => File.basename(manifest_path),
          "entries" => expected_directories.length,
          "sha256" => Digest::SHA256.file(manifest_path).hexdigest
        },
        "cargo_config" => {
          "name" => File.basename(config_path),
          "purpose" => "offline source replacement for the authoritative Linux closure plus the separate resolver-only supplement",
          "sha256" => Digest::SHA256.file(config_path).hexdigest
        },
        "archive" => {
          "name" => File.basename(archive_path),
          "root" => vendor_root_name,
          "transport_identity_required" => false,
          "tree_identity_required" => true
        },
        "scope" => "resolver-complete Cargo directory-source contract for repository-backed SRPM generation; not a Codex build proof or selected linked-license closure"
      }
      rendered = JSON.pretty_generate(vendor_receipt) + "\n"
      Agentlab.atomic_write(receipt_path, rendered)
      if external_receipt
        if check
          raise Agentlab::Error, "missing resolver vendor receipt: #{external_receipt}" unless File.file?(external_receipt)
          raise Agentlab::Error, "Codex resolver Cargo vendor receipt is stale" unless File.read(external_receipt) == rendered
        else
          FileUtils.mkdir_p(File.dirname(external_receipt))
          Agentlab.atomic_write(external_receipt, rendered)
        end
      end

      puts "Materialized #{expected_directories.length} resolver-complete Cargo sources: tree #{tree.fetch('sha256')}"
    end
  rescue StandardError
    FileUtils.rm_rf(vendor_root)
    [archive_path, manifest_path, config_path, receipt_path].each { |path| FileUtils.rm_f(path) }
    Dir.rmdir(output_root) if output_root_created && Dir.exist?(output_root) && Dir.empty?(output_root)
    raise
  end
end

package = Agentlab.package_named("codex-cli")
dependencies = Agentlab.load_yaml(File.join(package.directory, "dependencies.yml"))
version = package.upstream.fetch("current_version").to_s
target = dependencies.fetch("target_triple")
source_dir = nil
cargo_home = nil
work_dir_root = ENV.fetch("TMPDIR", Dir.tmpdir)
output = File.join(package.directory, "codex-cli-#{version}-selected-cargo-closure.json")
resolver_output = File.join(package.directory, "codex-cli-#{version}-cargo-resolver-supplement.json")
license_output = File.join(package.directory, "codex-cli-#{version}-selected-cargo-license-audit.json")
check = false
bootstrap_online = false
verify_sources = false
cargo_home_explicit = false
materialize_vendor = nil
vendor_receipt = nil
materialize_resolver_vendor = nil
resolver_vendor_receipt = nil

OptionParser.new do |parser|
  parser.banner = "Usage: scripts/audit-codex-cargo-closure --source-dir PATH [options]"
  parser.on("--source-dir PATH", "Extracted Codex release source") { |path| source_dir = path }
  parser.on("--cargo-home PATH", "Cargo cache containing registry and Git sources") { |path| cargo_home = path; cargo_home_explicit = true }
  parser.on("--work-dir-root PATH", "Parent directory for the isolated source copy") { |path| work_dir_root = path }
  parser.on("--output PATH", "Receipt path") { |path| output = path }
  parser.on("--resolver-output PATH", "Resolver-only supplement receipt path") { |path| resolver_output = path }
  parser.on("--license-output PATH", "Selected-aware Cargo license audit path") { |path| license_output = path }
  parser.on("--online", "Allow the first selected-tree pass to populate the Cargo cache") { bootstrap_online = true }
  parser.on("--check", "Verify that the existing receipt is current") { check = true }
  parser.on("--verify-sources", "Read-only verify selected and resolver-only cached sources") { verify_sources = true }
  parser.on("--materialize-vendor PATH", "Create the deterministic selected-only Cargo vendor artifacts under PATH") { |path| materialize_vendor = path }
  parser.on("--vendor-receipt PATH", "Write or check the deterministic vendor receipt at PATH") { |path| vendor_receipt = path }
  parser.on("--materialize-resolver-vendor PATH", "Create the deterministic resolver-complete Cargo vendor artifacts under PATH") do |path|
    materialize_resolver_vendor = path
  end
  parser.on("--resolver-vendor-receipt PATH", "Write or check the deterministic resolver-complete vendor receipt at PATH") do |path|
    resolver_vendor_receipt = path
  end
end.parse!

raise Agentlab::Error, "--source-dir is required" unless source_dir
if materialize_vendor && check && !vendor_receipt
  raise Agentlab::Error, "--check with --materialize-vendor requires --vendor-receipt"
end
if materialize_resolver_vendor && check && !resolver_vendor_receipt
  raise Agentlab::Error, "--check with --materialize-resolver-vendor requires --resolver-vendor-receipt"
end
if materialize_vendor && materialize_resolver_vendor
  raise Agentlab::Error, "selected-only and resolver-complete vendor materialization must run separately"
end

source_dir = File.realpath(source_dir)
cargo_home = File.realpath(cargo_home) if cargo_home
effective_cargo_home = File.expand_path(cargo_home || ENV.fetch("CARGO_HOME", File.join(Dir.home, ".cargo")))
work_dir_root = File.realpath(work_dir_root)
source_lock_path = File.join(source_dir, "codex-rs", "Cargo.lock")
source_manifest = File.join(source_dir, "codex-rs", "Cargo.toml")
raise Agentlab::Error, "missing Codex workspace manifest: #{source_manifest}" unless File.file?(source_manifest)
raise Agentlab::Error, "missing Codex lockfile: #{source_lock_path}" unless File.file?(source_lock_path)

source_lock = File.read(source_lock_path)
normalized_lock, normalized_local_packages = normalize_workspace_lock(source_lock, version)
source_lock_sha256 = Digest::SHA256.hexdigest(source_lock)
normalized_lock_sha256 = Digest::SHA256.hexdigest(normalized_lock)
environment = {}
environment["CARGO_HOME"] = cargo_home if cargo_home

if verify_sources || materialize_vendor || materialize_resolver_vendor
  raise Agentlab::Error, "source verification and vendoring require explicit --cargo-home" unless cargo_home_explicit
  raise Agentlab::Error, "missing receipt: #{output}" unless File.file?(output)
  needs_resolver_supplement = verify_sources || materialize_resolver_vendor
  if needs_resolver_supplement && !File.file?(resolver_output)
    raise Agentlab::Error, "missing resolver supplement: #{resolver_output}"
  end
  raise Agentlab::Error, "--vendor-receipt requires --materialize-vendor" if vendor_receipt && !materialize_vendor
  if resolver_vendor_receipt && !materialize_resolver_vendor
    raise Agentlab::Error, "--resolver-vendor-receipt requires --materialize-resolver-vendor"
  end

  receipt = JSON.parse(File.read(output))
  resolver_supplement = JSON.parse(File.read(resolver_output)) if needs_resolver_supplement
  release = receipt.fetch("release")
  raise Agentlab::Error, "receipt source Cargo.lock hash mismatch" unless release.fetch("source_cargo_lock_sha256") == source_lock_sha256
  raise Agentlab::Error, "receipt normalized Cargo.lock hash mismatch" unless release.fetch("normalized_cargo_lock_sha256") == normalized_lock_sha256
  if resolver_supplement && resolver_supplement.dig("authoritative_closure", "sha256") != Digest::SHA256.file(output).hexdigest
    raise Agentlab::Error, "resolver supplement authoritative closure hash mismatch"
  end
  if materialize_vendor
    materialize_vendor!(receipt, output, normalized_lock, cargo_home, materialize_vendor, vendor_receipt, check, work_dir_root)
  elsif materialize_resolver_vendor
    materialize_resolver_vendor!(
      receipt,
      resolver_supplement,
      output,
      resolver_output,
      source_dir,
      normalized_lock,
      cargo_home,
      materialize_resolver_vendor,
      resolver_vendor_receipt,
      check,
      work_dir_root
    )
  else
    verify_selected_sources!(receipt, normalized_lock, cargo_home)
    verify_resolver_sources!(resolver_supplement, receipt, normalized_lock, cargo_home)
  end
  exit 0
end

raise Agentlab::Error, "--vendor-receipt requires --materialize-vendor" if vendor_receipt
if resolver_vendor_receipt
  raise Agentlab::Error, "--resolver-vendor-receipt requires --materialize-resolver-vendor"
end

receipt = nil
resolver_supplement = nil
license_audit = nil
Dir.mktmpdir("agentlab-codex-closure-", work_dir_root) do |temporary_directory|
  metadata_source_dir = File.join(temporary_directory, "source")
  FileUtils.cp_r(source_dir, metadata_source_dir, preserve: true)
  workspace_manifest = File.join(metadata_source_dir, "codex-rs", "Cargo.toml")
  lock_path = File.join(metadata_source_dir, "codex-rs", "Cargo.lock")
  File.write(lock_path, normalized_lock)

  tree_base = [
    "cargo", "tree",
    "--manifest-path", workspace_manifest,
    "--locked",
    "--target", target,
    "--package", "codex-cli",
    "--prefix", "depth",
    "--format", "{p}|{f}"
  ]
  selected_tree_command = tree_base + ["--edges", "normal,build"]
  resolver_tree_command = tree_base.dup
  resolver_tree_command[resolver_tree_command.index(target)] = "all"
  resolver_tree_command += ["-Z", "avoid-dev-deps", "--edges", "normal,build"]
  resolver_environment = environment.merge("RUSTC_BOOTSTRAP" => "1")
  if bootstrap_online
    capture_command(environment, selected_tree_command, "Cargo selected-tree cache bootstrap")
    capture_command(resolver_environment, resolver_tree_command, "Cargo resolver-tree cache bootstrap")
  end

  selected_tree_command += ["--offline"]
  resolver_tree_command += ["--offline"]
  runtime_tree_command = tree_base + ["--edges", "normal", "--offline"]
  selected_license_tree_command = tree_base.dup
  selected_license_tree_command[selected_license_tree_command.index("{p}|{f}")] = "{p}|{l}"
  selected_license_tree_command += ["--edges", "normal,build", "--offline"]
  linked_linux_tree_command = tree_base + ["-Z", "avoid-dev-deps", "--edges", "no-build,no-dev,no-proc-macro", "--offline"]
  fedora_license_tree_command = linked_linux_tree_command.dup
  fedora_license_tree_command[fedora_license_tree_command.index(target)] = "all"
  selected_tree_output = capture_command(environment, selected_tree_command, "Cargo selected tree")
  resolver_tree_output = capture_command(resolver_environment, resolver_tree_command, "Cargo resolver tree")
  runtime_tree_output = capture_command(environment, runtime_tree_command, "Cargo runtime tree")
  selected_license_tree_output = capture_command(environment, selected_license_tree_command, "Cargo selected license metadata tree")
  linked_linux_tree_output = capture_command(resolver_environment, linked_linux_tree_command, "Cargo linked Linux license tree")
  fedora_license_tree_output = capture_command(resolver_environment, fedora_license_tree_command, "Cargo Fedora all-target license tree")

  normalized_lock_records = parse_lock_packages(normalized_lock)
  lock_by_name_version = normalized_lock_records.group_by do |record|
    [record.fetch("name"), record.fetch("version")]
  end
  workspace_metadata_command = [
    "cargo", "metadata",
    "--manifest-path", workspace_manifest,
    "--locked",
    "--format-version", "1",
    "--no-deps",
    "--offline"
  ]
  workspace_metadata = JSON.parse(
    capture_command(environment, workspace_metadata_command, "Cargo workspace dependency metadata")
  )
  workspace_packages = workspace_metadata.fetch("packages").to_h do |workspace_package|
    package_id = [workspace_package.fetch("name"), workspace_package.fetch("version"), workspace_package["source"]]
    [package_id, workspace_package]
  end
  selected_tree = parse_tree(selected_tree_output, lock_by_name_version, metadata_source_dir)
  resolver_tree = parse_tree(resolver_tree_output, lock_by_name_version, metadata_source_dir)
  runtime_tree = parse_tree(runtime_tree_output, lock_by_name_version, metadata_source_dir)
  selected_license_tree = parse_license_tree(selected_license_tree_output, lock_by_name_version, metadata_source_dir)
  linked_linux_tree = parse_tree(linked_linux_tree_output, lock_by_name_version, metadata_source_dir)
  fedora_license_tree = parse_tree(fedora_license_tree_output, lock_by_name_version, metadata_source_dir)
  unless selected_license_tree.keys.sort_by { |package_id| JSON.generate(package_id) } == selected_tree.keys.sort_by { |package_id| JSON.generate(package_id) }
    raise Agentlab::Error, "selected Cargo license metadata tree differs from the authoritative closure"
  end
  missing_runtime_packages = runtime_tree.keys - selected_tree.keys
  unless missing_runtime_packages.empty?
    raise Agentlab::Error, "runtime tree is not a subset of the selected tree"
  end
  missing_selected_packages = selected_tree.keys - resolver_tree.keys
  unless missing_selected_packages.empty?
    raise Agentlab::Error, "selected tree is not a subset of the all-target resolver tree"
  end
  missing_linked_linux_packages = linked_linux_tree.keys - selected_tree.keys
  unless missing_linked_linux_packages.empty?
    raise Agentlab::Error, "linked Linux license tree is not a subset of the authoritative closure"
  end
  missing_linked_all_target_packages = linked_linux_tree.keys - fedora_license_tree.keys
  unless missing_linked_all_target_packages.empty?
    raise Agentlab::Error, "linked Linux license tree is not a subset of Fedora's all-target license tree"
  end

  root_records = selected_tree.values.select do |record|
    package_record = record.fetch("lock_record")
    package_record.fetch("name") == "codex-cli" &&
      record.fetch("location") == File.join(metadata_source_dir, "codex-rs", "cli")
  end
  raise Agentlab::Error, "expected one codex-cli tree root, found #{root_records.length}" unless root_records.one?

  selected_records = selected_tree.map do |package_id, tree_record|
    package_record = tree_record.fetch("lock_record")
    source = package_record["source"]
    location = tree_record["location"]
    record = {
      "name" => package_record.fetch("name"),
      "version" => package_record.fetch("version"),
      "origin" => source_origin(source),
      "source" => source,
      "checksum" => package_record["checksum"],
      "role" => runtime_tree.key?(package_id) ? "runtime" : "build",
      "features" => tree_record.fetch("features"),
      "dependency_path" => tree_record.fetch("dependency_path").map(&:first)
    }.compact

    if source.nil?
      source_prefix = "#{metadata_source_dir}/"
      unless location&.start_with?(source_prefix)
        raise Agentlab::Error, "path package is outside the release source: #{location}"
      end
      record["manifest_path"] = "#{location.delete_prefix(source_prefix)}/Cargo.toml"
      record["workspace_path_package"] = true
    else
      record["workspace_path_package"] = false
    end
    record
  end.sort_by { |record| [record.fetch("name"), record.fetch("version"), record.fetch("source", "")] }

  fixed_point = resolver_fixed_point(selected_tree, normalized_lock_records, workspace_packages)
  resolver_records = (fixed_point.fetch("paths").keys - selected_tree.keys).map do |package_id|
    package_record = normalized_lock_records.find do |record|
      record.values_at("name", "version", "source") == package_id
    end
    raise Agentlab::Error, "resolver fixed point package is absent from Cargo.lock: #{package_id.inspect}" unless package_record

    source = package_record["source"]
    unless source_origin(source) == "registry"
      raise Agentlab::Error,
            "current resolver-only fixed point contains unsupported #{source_origin(source)} source: #{package_record.fetch('name')} #{package_record.fetch('version')}"
    end

    active_tree_record = resolver_tree[package_id]
    record = {
      "name" => package_record.fetch("name"),
      "version" => package_record.fetch("version"),
      "origin" => "registry",
      "source" => source,
      "checksum" => package_record.fetch("checksum"),
      "license" => registry_archive_record!(effective_cargo_home, package_record).fetch("license"),
      "active_in_all_target_graph" => !active_tree_record.nil?,
      "dependency_path" => fixed_point.fetch("paths").fetch(package_id).map { |dependency_id| identity_record(dependency_id) },
      "inclusion" => fixed_point.fetch("references").fetch(package_id)
    }
    record["features"] = active_tree_record.fetch("features") if active_tree_record
    if record.fetch("license").empty?
      raise Agentlab::Error, "resolver-only package lacks Cargo license metadata: #{record.fetch('name')} #{record.fetch('version')}"
    end
    record
  end.sort_by { |record| [record.fetch("name"), record.fetch("version"), record.fetch("source")] }

  expected_git_sources = dependencies.fetch("workspace_lock_git_sources")
  expected_by_repository = expected_git_sources.to_h do |record|
    [normalize_git_url(record.fetch("repository")), record]
  end
  selected_git_packages = selected_records.select { |record| record.fetch("origin") == "git" }
  selected_git_groups = selected_git_packages.group_by do |record|
    normalize_git_url(record.fetch("source"))
  end
  unexpected_git_sources = selected_git_groups.keys - expected_by_repository.keys
  unless unexpected_git_sources.empty?
    raise Agentlab::Error, "selected graph contains unrecorded Git sources: #{unexpected_git_sources.sort.join(', ')}"
  end

  git_sources = expected_by_repository.sort.map do |repository, expected|
    selected = selected_git_groups.fetch(repository, [])
    selected.each do |record|
      actual_commit = record.fetch("source").split("#", 2)[1]
      expected_commit = expected.fetch("commit")
      unless actual_commit == expected_commit
        raise Agentlab::Error, "Git source #{repository} resolved #{actual_commit}, expected #{expected_commit}"
      end
    end
    {
      "repository" => expected.fetch("repository"),
      "commit" => expected.fetch("commit"),
      "selected" => !selected.empty?,
      "packages" => selected.map do |record|
        record.slice("name", "version", "role", "features", "dependency_path")
      end
    }
  end

  cargo_version = capture_command(environment, ["cargo", "--version"], "Cargo version query").strip
  counts = {
    "selected_packages" => selected_records.length,
    "runtime_packages" => selected_records.count { |record| record.fetch("role") == "runtime" },
    "build_packages" => selected_records.count { |record| record.fetch("role") == "build" },
    "workspace_path_packages" => selected_records.count { |record| record.fetch("workspace_path_package") },
    "registry_packages" => selected_records.count { |record| record.fetch("origin") == "registry" },
    "git_packages" => selected_git_packages.length,
    "selected_git_repositories" => git_sources.count { |record| record.fetch("selected") },
    "excluded_git_repositories" => git_sources.count { |record| !record.fetch("selected") }
  }

  receipt = {
    "schema_version" => 2,
    "release" => {
      "version" => version,
      "source_tag" => package.upstream.fetch("source_tag"),
      "source_commit" => package.upstream.fetch("source_commit"),
      "source_sha256" => package.upstream.fetch("source_sha256"),
      "source_cargo_lock_sha256" => source_lock_sha256,
      "normalized_cargo_lock_sha256" => normalized_lock_sha256,
      "lock_normalization" => {
        "required" => !normalized_local_packages.empty?,
        "from_version" => "0.0.0",
        "to_version" => version,
        "local_package_count" => normalized_local_packages.length,
        "local_packages" => normalized_local_packages
      }
    },
    "selection" => {
      "root_package" => "codex-cli",
      "root_manifest" => "codex-rs/cli/Cargo.toml",
      "target_triple" => target,
      "included_dependency_kinds" => %w[normal build],
      "excluded_dependency_kinds" => ["dev"]
    },
    "generator" => {
      "cargo_version" => cargo_version,
      "offline_verification" => true,
      "selected_tree_command" => stable_command(selected_tree_command, workspace_manifest),
      "runtime_tree_command" => stable_command(runtime_tree_command, workspace_manifest)
    },
    "counts" => counts,
    "git_sources" => git_sources,
    "packages" => selected_records
  }

  selected_rendered = JSON.pretty_generate(receipt) + "\n"
  resolver_supplement = {
    "schema" => "agentlab-codex-cargo-resolver-supplement/v1",
    "release" => receipt.fetch("release").slice(
      "version",
      "source_tag",
      "source_commit",
      "source_sha256",
      "source_cargo_lock_sha256",
      "normalized_cargo_lock_sha256"
    ),
    "authoritative_closure" => {
      "name" => File.basename(output),
      "sha256" => Digest::SHA256.hexdigest(selected_rendered),
      "packages" => selected_records.length,
      "target_triple" => target
    },
    "resolution" => {
      "root_package" => "codex-cli",
      "root_manifest" => "codex-rs/cli/Cargo.toml",
      "active_target_witness" => "all",
      "included_dependency_kinds" => %w[normal build],
      "excluded_dependency_kinds" => ["dev"],
      "feature_policy" => "Cargo-selected features from codex-cli; --all-features is not used",
      "dev_dependency_avoidance" => "RUSTC_BOOTSTRAP=1 cargo -Z avoid-dev-deps, matching Fedora cargo-rpm-macros behavior",
      "fixed_point" => "Starting from the authoritative selected identities, follow every non-development normal/build Cargo.lock dependency of external packages and every non-development workspace dependency declaration, regardless of target predicate or optional activation.",
      "reason_model" => "Each resolver-only package records a deterministic dependency_path plus the immediate lock reference that requires its source metadata."
    },
    "generator" => {
      "cargo_version" => cargo_version,
      "offline_verification" => true,
      "resolver_tree_command" => stable_command(resolver_tree_command, workspace_manifest),
      "workspace_metadata_command" => stable_command(workspace_metadata_command, workspace_manifest),
      "license_metadata" => "normalized Cargo package manifest from the checksum-verified registry archive"
    },
    "counts" => {
      "directory_resolution_packages" => fixed_point.fetch("paths").length,
      "all_target_graph_packages" => resolver_tree.length,
      "authoritative_packages" => selected_records.length,
      "resolver_only_packages" => resolver_records.length,
      "active_all_target_resolver_only_packages" => resolver_records.count { |record| record.fetch("active_in_all_target_graph") },
      "inactive_optional_resolver_only_packages" => resolver_records.count { |record| !record.fetch("active_in_all_target_graph") },
      "registry_packages" => resolver_records.count { |record| record.fetch("origin") == "registry" },
      "git_packages" => resolver_records.count { |record| record.fetch("origin") == "git" },
      "workspace_path_packages" => resolver_records.count { |record| record.fetch("origin") == "path" }
    },
    "packages" => resolver_records,
    "scope" => "resolver-only source and license metadata required by Cargo directory-source resolution; not part of the authoritative Linux build graph or linked-license closure"
  }

  selected_source_plan = verify_selected_sources!(receipt, normalized_lock, effective_cargo_home)
  selected_source_licenses = {}
  selected_license_provenance = {}
  selected_source_plan.fetch("registry").each do |source_record|
    package_record = source_record.fetch("package")
    package_id = package_record.values_at("name", "version", "source")
    selected_source_licenses[package_id] = source_record.fetch("license")
    selected_license_provenance[package_id] = "checksum-verified registry archive Cargo.toml"
  end
  selected_source_plan.fetch("git").each do |git_source|
    git_source.fetch("packages").each do |package_record|
      _manifest_path, manifest = git_package_manifest_at_commit(
        git_source.fetch("checkout"),
        git_source.fetch("commit"),
        package_record
      )
      package_id = package_record.values_at("name", "version", "source")
      selected_source_licenses[package_id] = cargo_package_metadata(
        manifest,
        package_record.fetch("name"),
        package_record.fetch("version")
      )
      selected_license_provenance[package_id] = "exact-commit Git object Cargo.toml after normalized repository URL and tracked-checkout verification"
    end
  end
  selected_records.select { |record| record.fetch("origin") == "path" }.each do |package_record|
    package_id = package_record.values_at("name", "version", "source")
    selected_source_licenses[package_id] = cargo_metadata_license(workspace_packages.fetch(package_id))
    selected_license_provenance[package_id] = "exact release workspace metadata with inherited workspace package license"
  end
  unless selected_source_licenses.keys.sort_by { |package_id| JSON.generate(package_id) } == selected_tree.keys.sort_by { |package_id| JSON.generate(package_id) }
    raise Agentlab::Error, "verified selected source license identities differ from the authoritative closure"
  end

  selected_by_id = selected_records.to_h do |record|
    [record.values_at("name", "version", "source"), record]
  end
  resolver_by_id = resolver_records.to_h do |record|
    [record.values_at("name", "version", "source"), record]
  end
  known_license_ids = selected_by_id.keys + resolver_by_id.keys
  unknown_fedora_license_packages = fedora_license_tree.keys - known_license_ids
  unless unknown_fedora_license_packages.empty?
    raise Agentlab::Error, "Fedora all-target license tree contains identities outside the selected and resolver receipts"
  end

  selected_license_records = selected_records.map do |record|
    package_id = record.values_at("name", "version", "source")
    cargo_license = selected_license_tree.fetch(package_id).fetch("license")
    source_license = selected_source_licenses.fetch(package_id)
    unless source_license == { "expression" => cargo_license }
      raise Agentlab::Error, "Cargo tree/source license mismatch for #{record.fetch('name')} #{record.fetch('version')}"
    end
    normalized_license = normalize_cargo_license_expression(cargo_license)
    record.slice(
      "name",
      "version",
      "origin",
      "source",
      "checksum",
      "role",
      "manifest_path",
      "workspace_path_package"
    ).merge(
      "cargo_manifest_license" => source_license,
      "cargo_tree_license" => cargo_license,
      "license_provenance" => selected_license_provenance.fetch(package_id),
      "normalized_spdx_candidate" => normalized_license,
      "legacy_slash_normalized" => cargo_license != normalized_license,
      "linked_linux" => linked_linux_tree.key?(package_id),
      "fedora_all_target_linked" => fedora_license_tree.key?(package_id)
    )
  end

  resolver_license_records = resolver_records.map do |record|
    package_id = record.values_at("name", "version", "source")
    license_metadata = record.fetch("license")
    expression = license_metadata["expression"]
    normalized_license = normalize_cargo_license_expression(expression) if expression
    record.slice("name", "version", "origin", "source", "checksum", "active_in_all_target_graph").merge(
      "cargo_manifest_license" => license_metadata,
      "normalized_spdx_candidate" => normalized_license,
      "legacy_slash_normalized" => expression && expression != normalized_license,
      "linked_linux" => false,
      "fedora_all_target_linked" => fedora_license_tree.key?(package_id)
    ).compact
  end

  license_record_by_id = (selected_license_records + resolver_license_records).to_h do |record|
    [record.values_at("name", "version", "source"), record]
  end
  linux_linked_records = linked_linux_tree.keys.map { |package_id| license_record_by_id.fetch(package_id) }
  fedora_linked_records = fedora_license_tree.keys.map { |package_id| license_record_by_id.fetch(package_id) }
  linux_linked_expressions = linux_linked_records.map { |record| record.fetch("normalized_spdx_candidate") }
  fedora_linked_expressions = fedora_linked_records.map { |record| record["normalized_spdx_candidate"] }
  unless fedora_linked_expressions.all?
    raise Agentlab::Error, "Fedora all-target linked graph contains a package without an SPDX expression"
  end

  v8_record = selected_license_records.select do |record|
    record.fetch("name") == "v8" && record.fetch("version") == "149.2.0"
  end
  raise Agentlab::Error, "expected one selected v8 149.2.0 package" unless v8_record.one?
  rusty_v8 = dependencies.fetch("selected_special_sources").find do |source|
    source.fetch("component") == "rusty_v8"
  end
  raise Agentlab::Error, "missing Rusty V8 source evidence" unless rusty_v8
  bubblewrap = dependencies.fetch("vendored_native_sources").find do |source|
    source.fetch("component") == "bubblewrap"
  end
  raise Agentlab::Error, "missing excluded Bubblewrap evidence" unless bubblewrap

  resolver_rendered_for_license = JSON.pretty_generate(resolver_supplement) + "\n"
  license_audit = {
    "schema" => "agentlab-codex-selected-cargo-license-audit/v1",
    "release" => receipt.fetch("release").slice(
      "version",
      "source_tag",
      "source_commit",
      "source_sha256",
      "source_cargo_lock_sha256",
      "normalized_cargo_lock_sha256"
    ),
    "authoritative_closure" => {
      "name" => File.basename(output),
      "sha256" => Digest::SHA256.hexdigest(selected_rendered),
      "packages" => selected_records.length,
      "target_triple" => target
    },
    "resolver_supplement" => {
      "name" => File.basename(resolver_output),
      "sha256" => Digest::SHA256.hexdigest(resolver_rendered_for_license),
      "packages" => resolver_records.length
    },
    "selection" => {
      "root_package" => "codex-cli",
      "root_manifest" => "codex-rs/cli/Cargo.toml",
      "feature_policy" => "Cargo-selected features from codex-cli; --all-features is not used",
      "selected_source_graph" => {
        "target" => target,
        "included_edges" => %w[normal build],
        "excluded_edges" => ["dev"]
      },
      "linked_linux_graph" => {
        "target" => target,
        "excluded_edges" => %w[build dev proc-macro],
        "dev_dependency_avoidance" => "RUSTC_BOOTSTRAP=1 cargo -Z avoid-dev-deps"
      },
      "fedora_macro_graph" => {
        "target" => "all",
        "excluded_edges" => %w[build dev proc-macro],
        "reason" => "Matches cargo2rpm license-breakdown and license-summary graph selection."
      }
    },
    "generator" => {
      "cargo_version" => cargo_version,
      "offline_verification" => true,
      "selected_source_license_verification" => "Registry Cargo.toml metadata comes from checksum-verified archives; Git metadata comes from exact commit objects after normalized repository URL and tracked-checkout verification; workspace metadata comes from the exact release source copy.",
      "selected_license_tree_command" => stable_command(selected_license_tree_command, workspace_manifest),
      "linked_linux_tree_command" => stable_command(linked_linux_tree_command, workspace_manifest),
      "fedora_license_tree_command" => stable_command(fedora_license_tree_command, workspace_manifest),
      "legacy_license_normalization" => "Replace each slash-separated Cargo alternative with SPDX OR, matching Fedora cargo2rpm license output normalization."
    },
    "counts" => {
      "selected_packages" => selected_license_records.length,
      "selected_linked_linux_packages" => linux_linked_records.length,
      "selected_compile_only_packages" => selected_license_records.count { |record| !record.fetch("linked_linux") },
      "selected_build_role_packages" => selected_license_records.count { |record| record.fetch("role") == "build" },
      "selected_normal_path_compile_only_packages" => selected_license_records.count do |record|
        record.fetch("role") == "runtime" && !record.fetch("linked_linux")
      end,
      "resolver_only_packages" => resolver_license_records.length,
      "fedora_all_target_linked_packages" => fedora_linked_records.length,
      "fedora_all_target_linked_selected_packages" => fedora_linked_records.count do |record|
        selected_by_id.key?(record.values_at("name", "version", "source"))
      end,
      "fedora_all_target_linked_resolver_only_packages" => fedora_linked_records.count do |record|
        resolver_by_id.key?(record.values_at("name", "version", "source"))
      end,
      "selected_legacy_slash_expressions" => selected_license_records.count { |record| record.fetch("legacy_slash_normalized") },
      "resolver_legacy_slash_expressions" => resolver_license_records.count { |record| record.fetch("legacy_slash_normalized", false) },
      "linux_linked_unique_license_expressions" => linux_linked_expressions.uniq.length,
      "fedora_all_target_unique_license_expressions" => fedora_linked_expressions.uniq.length
    },
    "aggregate_candidates" => {
      "linux_cargo_linked" => {
        "expression" => aggregate_license_expression(linux_linked_expressions),
        "unique_expressions" => linux_linked_expressions.uniq.sort,
        "complete_for_cargo_manifest_metadata" => true
      },
      "fedora_all_target_cargo_macro" => {
        "expression" => aggregate_license_expression(fedora_linked_expressions),
        "unique_expressions" => fedora_linked_expressions.uniq.sort,
        "complete_for_cargo_manifest_metadata" => true,
        "use" => "Comparison witness for Fedora cargo-rpm-macros; not the authoritative Linux product closure."
      },
      "final_binary" => {
        "complete" => false,
        "reason" => "Cargo manifest metadata does not cover the Rusty V8/Chromium native static source closure, system-library decisions, or required license texts."
      }
    },
    "selected_packages" => selected_license_records,
    "resolver_only_packages" => resolver_license_records,
    "native_static_components" => [
      {
        "component" => "rusty_v8",
        "cargo_package" => v8_record.first.slice(
          "name",
          "version",
          "source",
          "checksum",
          "cargo_manifest_license",
          "cargo_tree_license",
          "normalized_spdx_candidate",
          "linked_linux"
        ),
        "upstream_v8" => rusty_v8.fetch("upstream_v8").to_s,
        "prototype_archive_sha256" => rusty_v8.fetch("local_prototype").fetch("archive_sha256"),
        "recursive_source_license_inventory_complete" => false,
        "required_license_texts_complete" => false,
        "system_library_decisions_complete" => false,
        "scope" => "The v8 crate's Cargo license is recorded above; its statically linked Chromium/V8 implementation requires separate source and license accounting."
      }
    ],
    "excluded_native_sources" => [
      {
        "component" => "bubblewrap",
        "path" => bubblewrap.fetch("path"),
        "license" => bubblewrap.fetch("license"),
        "reason" => bubblewrap.fetch("status")
      }
    ],
    "validation" => {
      "authoritative_closure_unchanged" => true,
      "resolver_supplement_kept_separate" => true,
      "selected_cargo_license_metadata_complete" => true,
      "selected_source_license_metadata_verified" => true,
      "resolver_cargo_license_metadata_complete" => true,
      "legacy_cargo_license_syntax_normalized" => true,
      "linked_linux_graph_verified" => true,
      "fedora_macro_graph_verified" => true,
      "license_texts_verified" => false,
      "fedora_allowed_spdx_verified" => false,
      "native_static_licenses_verified" => false,
      "final_binary_license_complete" => false,
      "production_license_tag_approved" => false
    },
    "scope" => "Deterministic Cargo manifest license metadata and linked-graph accounting; not a complete native/static license closure, legal review, final RPM License expression, or source-publication approval."
  }
end

rendered = "#{JSON.pretty_generate(receipt)}\n"
resolver_rendered = "#{JSON.pretty_generate(resolver_supplement)}\n"
license_rendered = "#{JSON.pretty_generate(license_audit)}\n"
if check
  raise Agentlab::Error, "missing receipt: #{output}" unless File.file?(output)
  raise Agentlab::Error, "Codex Cargo closure receipt is stale" unless File.read(output) == rendered
  raise Agentlab::Error, "missing resolver supplement: #{resolver_output}" unless File.file?(resolver_output)
  unless File.read(resolver_output) == resolver_rendered
    raise Agentlab::Error, "Codex Cargo resolver supplement is stale"
  end
  raise Agentlab::Error, "missing license audit: #{license_output}" unless File.file?(license_output)
  unless File.read(license_output) == license_rendered
    raise Agentlab::Error, "Codex Cargo license audit is stale"
  end

  puts "Codex Cargo closure receipt is current: #{receipt.fetch('counts').fetch('selected_packages')} packages; resolver supplement #{resolver_supplement.fetch('counts').fetch('resolver_only_packages')} packages; linked license graph #{license_audit.fetch('counts').fetch('selected_linked_linux_packages')} packages"
else
  File.write(output, rendered)
  File.write(resolver_output, resolver_rendered)
  File.write(license_output, license_rendered)
  puts "Wrote #{output}: #{receipt.fetch('counts').fetch('selected_packages')} packages"
  puts "Wrote #{resolver_output}: #{resolver_supplement.fetch('counts').fetch('resolver_only_packages')} resolver-only packages"
  puts "Wrote #{license_output}: #{license_audit.fetch('counts').fetch('selected_linked_linux_packages')} linked Linux Cargo packages"
end
