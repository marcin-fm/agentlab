#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "lib/agentlab"

selected_name = nil
OptionParser.new do |parser|
  parser.banner = "Usage: scripts/check-packages [--package NAME]"
  parser.on("--package NAME", "Validate only one package") { |name| selected_name = name }
end.parse!

packages = selected_name ? [Agentlab.package_named(selected_name)] : Agentlab.packages
project_chroots = Agentlab.config.fetch("chroots")
errors = []
warnings = []

Agentlab.copr_chroot_matrix_errors(project_chroots, require_all_stable_releases: true).each do |error|
  errors << "config/copr.yml: #{error}"
end

packages.each do |package|
  unless %w[enabled blocked].include?(package.status)
    errors << "#{package.name}: status must be enabled or blocked"
  end

  if package.status == "blocked" && package.data.dig("copr", "enabled") == true
    errors << "#{package.name}: blocked package cannot enable COPR"
  end

  if package.status == "enabled" && package.data.dig("copr", "enabled") != true
    errors << "#{package.name}: enabled package must enable COPR"
  end

  if package.status == "enabled" && Array(package.data["blockers"]).any?
    errors << "#{package.name}: enabled package still has blockers"
  end

  package_chroots = package.data.dig("copr", "chroots")
  if package_chroots
    unless package_chroots.is_a?(Array) && package_chroots.any? && package_chroots.all? { |chroot| chroot.is_a?(String) && !chroot.empty? }
      errors << "#{package.name}: copr.chroots must be a nonempty array of strings"
    else
      unknown_chroots = package_chroots - project_chroots
      errors << "#{package.name}: copr.chroots contains project-unknown chroots: #{unknown_chroots.join(', ')}" if unknown_chroots.any?
    end
  end

  omitted_target_families = package.data.dig("copr", "omitted_target_families")
  omitted_families = []
  if omitted_target_families
    unless omitted_target_families.is_a?(Hash) && omitted_target_families.any?
      errors << "#{package.name}: copr.omitted_target_families must be a nonempty mapping"
    else
      omitted_families = omitted_target_families.keys
      unknown_families = omitted_families - %w[stable rawhide]
      errors << "#{package.name}: copr.omitted_target_families contains unknown families: #{unknown_families.join(', ')}" if unknown_families.any?
      omitted_target_families.each do |family, reason|
        unless reason.is_a?(String) && !reason.strip.empty?
          errors << "#{package.name}: copr.omitted_target_families.#{family} must explain the omission"
        end
      end
      errors << "#{package.name}: copr.omitted_target_families cannot omit every target family" if (omitted_families & %w[stable rawhide]).length == 2
    end

    selected_chroots = package.chroots(project_chroots)
    if omitted_families.include?("stable") && (selected_chroots & Agentlab::STABLE_COPR_CHROOTS).any?
      errors << "#{package.name}: copr.chroots selects stable targets that copr.omitted_target_families omits"
    end
    if omitted_families.include?("rawhide") && (selected_chroots & Agentlab::RAWHIDE_COPR_CHROOTS).any?
      errors << "#{package.name}: copr.chroots selects Rawhide targets that copr.omitted_target_families omits"
    end
  end

  if package.enabled?
    matrix_chroots = package.chroots(project_chroots).dup
    matrix_chroots.concat(Agentlab::STABLE_COPR_CHROOTS) if omitted_families.include?("stable")
    matrix_chroots.concat(Agentlab::RAWHIDE_COPR_CHROOTS) if omitted_families.include?("rawhide")
    Agentlab.copr_chroot_matrix_errors(
      matrix_chroots.uniq,
      require_all_stable_releases: false
    ).each do |error|
      errors << "#{package.name}: copr.chroots #{error}"
    end
  end

  errors << "#{package.name}: missing spec #{package.spec_path}" unless File.file?(package.spec_path)
  next unless File.file?(package.spec_path)

  spec = File.read(package.spec_path)
  spec_name = spec[/^Name:\s+(\S+)/, 1]
  spec_version = spec[/^Version:\s+(\S+)/, 1]
  spec_release = spec[/^Release:\s+(\S+)/, 1]
  spec_sha256 = spec[/^%global source_sha256\s+(\h{64})$/, 1]
  manifest_version = package.upstream["current_version"].to_s
  spec_version_expected = package.upstream.fetch("rpm_version", manifest_version).to_s
  manifest_sha256 = package.upstream["source_sha256"].to_s
  errors << "#{package.name}: spec Name is #{spec_name.inspect}" unless spec_name == package.name
  errors << "#{package.name}: spec Version #{spec_version.inspect} != manifest RPM version #{spec_version_expected.inspect}" unless spec_version == spec_version_expected
  unless spec_release&.match?(/\A0\.(?:0\.)?[1-9][0-9]*%\{\?dist\}\z/)
    errors << "#{package.name}: Release #{spec_release.inspect} must use 0.x%{?dist} or legacy 0.0.x%{?dist}"
  end

  changelog = spec.split(/^%changelog\s*$/, 2)[1].to_s
  changelog_release = changelog[/^\* [^\n]+ - #{Regexp.escape(spec_version.to_s)}-(\S+)$/, 1]
  expected_changelog_release = spec_release&.delete_suffix("%{?dist}")
  unless changelog_release == expected_changelog_release
    errors << "#{package.name}: latest changelog release #{changelog_release.inspect} != spec Release #{expected_changelog_release.inspect}"
  end
  errors << "#{package.name}: spec source SHA-256 does not match manifest" unless spec_sha256 == manifest_sha256
  errors << "#{package.name}: source SHA-256 must be 64 lowercase hex characters" unless manifest_sha256.match?(/\A[0-9a-f]{64}\z/)

  dependencies_path = File.join(package.directory, "dependencies.yml")
  if File.file?(dependencies_path)
    dependencies = Agentlab.load_yaml(dependencies_path)
    target_release = dependencies["target_release"].to_s
    errors << "#{package.name}: dependency target #{target_release.inspect} != manifest #{manifest_version.inspect}" unless target_release == manifest_version
    errors << "#{package.name}: bundled(npm(...)) is not valid Fedora Node metadata" if spec.include?("bundled(npm(")
    errors << "#{package.name}: private application must not provide npm(#{package.name})" if spec.match?(/^Provides:\s+npm\(#{Regexp.escape(package.name)}\)/)

    spec.scan(/^Provides:\s+bundled\(([^)]+)\)\s*=\s*(\S+)/).each do |capability, _version|
      errors << "#{package.name}: bundled Node capability #{capability.inspect} must start with nodejs-" unless capability.start_with?("nodejs-")
    end

    if dependencies.key?("closure_audit")
      audit = dependencies.fetch("closure_audit")
      required_audit_flags = %w[
        production_build_sources_verified
        test_sources_verified
        licenses_verified
        native_sources_verified
        generated_sources_verified
        bundled_provides_verified
        upstream_contact_recorded
        offline_verified
      ]

      if package.enabled?
        errors << "#{package.name}: closure audit is not current" unless audit["audited_release"].to_s == manifest_version
        required_audit_flags.each do |flag|
          errors << "#{package.name}: closure audit flag #{flag} is not true" unless audit[flag] == true
        end

        generated_block = spec[/# BEGIN GENERATED BUNDLED NODE PROVIDES\n(.*?)# END GENERATED BUNDLED NODE PROVIDES/m, 1]
        errors << "#{package.name}: generated bundled Node Provides block is empty" unless generated_block&.match?(/^Provides:/)
      end
    end

    if dependencies.key?("source_closure_files")
      source_files = dependencies.fetch("source_closure_files")
      source_hashes = dependencies.fetch("source_closure_sha256", {})
      source_delivery = dependencies.fetch("source_delivery", {})
      generated_during_srpm = source_delivery["method"] == "copr-git-scm-make_srpm"
      if generated_during_srpm
        implementation = source_delivery["implementation"]
        implementation_path = implementation.is_a?(String) && File.join(Agentlab::ROOT, implementation)
        errors << "#{package.name}: generated source implementation is missing" unless implementation_path && File.file?(implementation_path)
        errors << "#{package.name}: generated source hashes are not enforced" unless source_delivery["expected_hashes_enforced"] == true
        errors << "#{package.name}: target builds must keep networking forbidden" unless source_delivery["target_build_network"] == "forbidden"
        errors << "#{package.name}: generated source delivery still requires an external asset" unless source_delivery["external_generated_asset_required"] == false

        makefile_path = File.join(Agentlab::ROOT, ".copr", "Makefile")
        makefile = File.file?(makefile_path) ? File.read(makefile_path) : ""
        errors << "#{package.name}: COPR Makefile does not select the package spec" unless makefile.include?("#{package.name}.spec)")
        errors << "#{package.name}: COPR Makefile does not invoke #{implementation}" unless implementation && makefile.include?(implementation)
      end
      closure_filename = source_files["closure_manifest"]
      closure_path = closure_filename.is_a?(String) && File.join(package.directory, closure_filename)
      source_files.each do |key, filename|
        unless filename.is_a?(String)
          errors << "#{package.name}: closure source filename must be a string"
          next
        end
        expected_sha256 = source_hashes[key]
        valid_sha256 = expected_sha256.is_a?(String) && expected_sha256.match?(/\A[0-9a-f]{64}\z/)
        if generated_during_srpm && !valid_sha256
          errors << "#{package.name}: closure source #{filename} is missing a valid SHA-256"
        end
        next unless package.enabled?

        path = File.join(package.directory, filename)
        if File.file?(path) && valid_sha256
          actual_sha256 = Digest::SHA256.file(path).hexdigest
          errors << "#{package.name}: closure source #{filename} SHA-256 does not match" unless actual_sha256 == expected_sha256
        elsif !generated_during_srpm
          errors << "#{package.name}: enabled package is missing closure source #{filename}"
        end
      end

      if closure_path && File.file?(closure_path)
        begin
          closure = JSON.parse(File.read(closure_path))
          expected_block = Agentlab.node_bundled_provides_block(closure)
          actual_block = spec[/# BEGIN GENERATED BUNDLED NODE PROVIDES\n.*?# END GENERATED BUNDLED NODE PROVIDES/m]
          errors << "#{package.name}: bundled Node Provides block does not match #{closure_filename}" unless actual_block == expected_block
        rescue JSON::ParserError, Agentlab::Error, KeyError => e
          errors << "#{package.name}: invalid closure manifest #{closure_filename}: #{e.message}"
        end
      elsif package.enabled? && !generated_during_srpm
        errors << "#{package.name}: closure manifest is not configured or missing"
      end

      native_filename = source_files["native_manifest"]
      native_path = native_filename.is_a?(String) && File.join(package.directory, native_filename)
      if native_path && File.file?(native_path)
        begin
          JSON.parse(File.read(native_path))
        rescue JSON::ParserError => e
          errors << "#{package.name}: invalid native manifest #{native_filename}: #{e.message}"
        end
      end
    end
  end

  if dependencies && (receipt_config = dependencies["selected_lock_receipt"])
    receipt_filename = dependencies.dig("source_closure_files", "selected_lock_audit")
    receipt_path = receipt_filename.is_a?(String) && File.join(package.directory, receipt_filename)
    unless receipt_path && File.file?(receipt_path)
      errors << "#{package.name}: selected lock receipt is missing"
    else
      expected_sha256 = receipt_config["sha256"].to_s
      actual_sha256 = Digest::SHA256.file(receipt_path).hexdigest
      errors << "#{package.name}: selected lock receipt SHA-256 does not match" unless actual_sha256 == expected_sha256

      begin
        receipt = JSON.parse(File.read(receipt_path))
        errors << "#{package.name}: selected lock receipt release does not match" unless receipt["release"].to_s == manifest_version
        expected_schema = receipt_config.fetch("schema", "opencode-selected-lock-audit/v1")
        errors << "#{package.name}: selected lock receipt schema is invalid" unless receipt["schema"] == expected_schema
        errors << "#{package.name}: selected lock receipt source tag does not match" unless receipt["source_tag"] == package.upstream["source_tag"]
        errors << "#{package.name}: selected lock receipt source commit does not match" unless receipt["source_commit"] == package.upstream["source_commit"]
        errors << "#{package.name}: selected lock receipt performed dependency resolution" unless receipt.dig("validation", "no_dependency_resolution_performed") == true
        errors << "#{package.name}: selected lock receipt incorrectly claims source verification" unless receipt.dig("validation", "source_archives_verified") == false
        errors << "#{package.name}: selected lock receipt incorrectly claims license verification" unless receipt.dig("validation", "licenses_verified") == false

        expected_counts = {
          "selected_workspaces" => receipt.dig("selection", "selected_workspaces"),
          "selected_packages" => receipt.dig("selection", "selected_packages"),
          "runtime_packages" => receipt.dig("selection", "roles", "runtime"),
          "build_packages" => receipt.dig("selection", "roles", "build"),
          "registry_packages" => receipt.dig("selection", "origins", "registry"),
          "github_packages" => receipt.dig("selection", "origins", "github"),
          "platform_excluded" => receipt.dig("selection", "platform_excluded")
        }
        expected_counts["test_packages"] = receipt.dig("selection", "roles", "test") if receipt_config.key?("test_packages")
        expected_counts["policy_excluded"] = receipt.dig("selection", "policy_excluded") if receipt_config.key?("policy_excluded")
        expected_counts.each do |key, value|
          errors << "#{package.name}: selected lock receipt #{key} does not match" unless value == receipt_config[key]
        end
        errors << "#{package.name}: selected lock receipt lock SHA-256 does not match" unless receipt.dig("lockfile", "sha256") == receipt_config["lock_sha256"]
        Hash(receipt_config["validation"]).each do |key, value|
          errors << "#{package.name}: selected lock receipt validation #{key} does not match" unless receipt.dig("validation", key) == value
        end
        Hash(receipt_config["source_identity"]).each do |key, value|
          errors << "#{package.name}: selected lock receipt source identity #{key} does not match" unless receipt.dig("source_identity", key) == value
        end
      rescue JSON::ParserError => e
        errors << "#{package.name}: invalid selected lock receipt #{receipt_filename}: #{e.message}"
      end
    end
  end

  if dependencies && (source_config = dependencies["source_acquisition_receipt"])
    source_filename = dependencies.dig("source_closure_files", "source_audit")
    source_path = source_filename.is_a?(String) && File.join(package.directory, source_filename)
    unless source_path && File.file?(source_path)
      errors << "#{package.name}: source acquisition receipt is missing"
    else
      actual_sha256 = Digest::SHA256.file(source_path).hexdigest
      errors << "#{package.name}: source acquisition receipt SHA-256 does not match" unless actual_sha256 == source_config["sha256"]

      begin
        receipt = JSON.parse(File.read(source_path))
        errors << "#{package.name}: source acquisition receipt release does not match" unless receipt["release"].to_s == manifest_version
        errors << "#{package.name}: source acquisition receipt schema is invalid" unless receipt["schema"] == "opencode-source-acquisition/v1"
        errors << "#{package.name}: source acquisition receipt selected-lock SHA-256 does not match" unless receipt["selected_lock_receipt_sha256"] == source_config["selected_lock_receipt_sha256"]
        errors << "#{package.name}: source acquisition receipt lacks registry integrity proof" unless receipt.dig("validation", "registry_integrity_verified") == true
        errors << "#{package.name}: source acquisition receipt lacks archive safety proof" unless receipt.dig("validation", "archive_paths_verified") == true
        errors << "#{package.name}: source acquisition receipt executed lifecycle scripts" unless receipt.dig("validation", "lifecycle_scripts_executed") == false
        errors << "#{package.name}: source acquisition receipt incorrectly claims license verification" unless receipt.dig("validation", "licenses_verified") == false
        errors << "#{package.name}: source acquisition receipt incorrectly claims native-source verification" unless receipt.dig("validation", "native_sources_verified") == false

        summary = receipt.fetch("summary", {})
        expected_counts = {
          "selected_package_records" => summary["selected_package_records"],
          "unique_sources" => summary["unique_sources"],
          "registry_sources" => summary.dig("origins", "registry"),
          "github_sources" => summary.dig("origins", "github"),
          "sources_without_declared_license" => summary["sources_without_declared_license"],
          "sources_without_license_files" => summary["sources_without_license_files"],
          "sources_with_lifecycle_scripts" => summary["sources_with_lifecycle_scripts"],
          "lifecycle_script_count" => summary["lifecycle_script_count"],
          "sources_with_native_payloads" => summary["sources_with_native_payloads"],
          "native_payload_count" => summary["native_payload_count"],
          "sources_with_wasm_payloads" => summary["sources_with_wasm_payloads"],
          "wasm_payload_count" => summary["wasm_payload_count"],
          "sources_with_executable_payloads" => summary["sources_with_executable_payloads"],
          "executable_payload_count" => summary["executable_payload_count"],
          "sources_with_native_source" => summary["sources_with_native_source"]
        }
        expected_counts.each do |key, value|
          errors << "#{package.name}: source acquisition receipt #{key} does not match" unless value == source_config[key]
        end
      rescue JSON::ParserError => e
        errors << "#{package.name}: invalid source acquisition receipt #{source_filename}: #{e.message}"
      end
    end
  end

  errors.concat(Agentlab.validate_opencode_review_evidence(package, dependencies, manifest_version)) if dependencies

  errors.concat(Agentlab.validate_rust_v8_evidence(package, dependencies, spec)) if dependencies

  errors.concat(Agentlab.validate_bun_build_plan(package, spec))

  errors.concat(Agentlab.validate_pdfium_source(package, spec))

  next unless Agentlab.command_available?("rpmspec")

  _stdout, stderr, status = Agentlab.capture(["rpmspec", "-P", package.spec_path])
  errors << "#{package.name}: rpmspec parse failed: #{stderr.strip}" unless status.success?
end

unless selected_name
  active_names = packages.map(&:name)
  archive_root = File.join(Agentlab::ROOT, "archived")
  Dir.glob(File.join(archive_root, "*")).sort.each do |archive_directory|
    next unless File.directory?(archive_directory)

    archive_name = File.basename(archive_directory)
    manifest_path = File.join(archive_directory, "package.yml")
    retirement_path = File.join(archive_directory, "retirement.yml")
    unless File.file?(manifest_path)
      errors << "#{archive_name}: archived package is missing package.yml"
      next
    end

    manifest = Agentlab.load_yaml(manifest_path)

    errors << "#{archive_name}: package exists in both packages/ and archived/" if active_names.include?(archive_name)
    errors << "#{archive_name}: archived manifest name #{manifest['name'].inspect} does not match its directory" unless manifest["name"] == archive_name

    unless File.file?(retirement_path)
      errors << "#{archive_name}: archived package is missing retirement.yml"
      next
    end

    retirement = Agentlab.load_yaml(retirement_path)
    errors << "#{archive_name}: retirement name #{retirement['name'].inspect} does not match its directory" unless retirement["name"] == archive_name
    errors << "#{archive_name}: retirement date must use YYYY-MM-DD" unless retirement["retired_on"].to_s.match?(/\A\d{4}-\d{2}-\d{2}\z/)
    errors << "#{archive_name}: retirement reason is required" if retirement["reason"].to_s.strip.empty?
    errors << "#{archive_name}: retirement COPR project is required" if retirement["copr_project"].to_s.strip.empty?
    retirement_chroots = retirement["configured_chroots_at_retirement"]
    unless retirement_chroots.is_a?(Array) && retirement_chroots.any? && retirement_chroots.all? { |chroot| chroot.is_a?(String) && !chroot.empty? }
      errors << "#{archive_name}: retirement chroots must be a nonempty array of strings"
    end
  end
end

warnings << "rpmspec is unavailable; spec parsing was skipped" unless Agentlab.command_available?("rpmspec")

warnings.each { |warning| warn "warning: #{warning}" }
if errors.any?
  errors.each { |error| warn "error: #{error}" }
  exit 1
end

puts "Validated #{packages.length} package#{'s' unless packages.length == 1}."
