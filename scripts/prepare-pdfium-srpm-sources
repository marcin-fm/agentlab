    "tree_file_records" => 1_619,
    "tree_sha256" => "fa5b6a4274bdd0cb1f20dcae021dac976c3c80caa988b57e82d9461957a7388f"
  },
  {
    "id" => "fast-float",
    "archive_path" => "third_party/fast_float/src",
    "output_path" => "third_party/fast_float/src",
    "revision" => "cb1d42aaa1e14b09e1452cfdef373d051b8c02a4",
    "tree_file_records" => 100,
    "tree_sha256" => "a7dc489826edf39b143fbff7d2776d7b24d8c1ff277deaf11b1d7b7744b153f5"
