#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "fileutils"
require "find"
require "json"
require "open3"
require "optparse"
require "pathname"
require "rubygems/package"
require "tempfile"
require "tmpdir"
require "uri"
require "zlib"

module PdfiumSources
  class Error < StandardError; end

  def self.atomic_write(path, content)
    Tempfile.create([".pdfium-source-", ".tmp"], File.dirname(path)) do |file|
      file.binmode
      file.write(content)
      file.flush
      file.fsync
      File.chmod(0o644, file.path)
      File.rename(file.path, path)
    end
  end
end

PACKAGE = "pdfium"
VERSION = "146.0.7678.0"
UPSTREAM_URL = "https://commondatastorage.googleapis.com/chromium-browser-official/chromium-#{VERSION}-lite.tar.xz"
UPSTREAM_FILENAME = "chromium-#{VERSION}-lite.tar.xz"
UPSTREAM_ROOT = "chromium-#{VERSION}"
UPSTREAM_SIZE_BYTES = 1_474_309_344
UPSTREAM_SHA256 = "b6193d9ad3bfefb4d947a1719070bcb1328a690f82d150b9812cfa885fe3b875"
OUTPUT_FILENAME = "pdfium-#{VERSION}-source.tar.gz"
OUTPUT_ROOT = "pdfium-#{VERSION}"
OUTPUT_SIZE_BYTES = 70_932_985
OUTPUT_SHA256 = "c7dc7e87a0ab457d9088e1215cdd54da3ebd941b9d77f38b1a7e9c8606cb2b75"
OUTPUT_TREE_RECORDS = 15_141
OUTPUT_TREE_SHA256 = "edcbeca5eb923a7127416246377ea0ac927a7a54f6cb388fb2c4411b9ae3af60"
RECEIPT_FILENAME = "pdfium-#{VERSION}-source-receipt.json"
SOURCE_POLICY_FILENAME = "source-closure.yml"
SOURCE_POLICY_SHA256 = "9ff235c6e1046ee586def0a3bcba89ef19ed7097053d1c451d7350bc4f7df5d7"
SCRIPT_FILENAME = "prepare-pdfium-srpm-sources"
RELEASE_TAG = "pdfium-sources-#{VERSION}-pdfium-efbbd0fc9582"
RELEASE_URL = "https://github.com/marcin-fm/agentlab/releases/tag/#{RELEASE_TAG}"
OUTPUT_URL = "https://github.com/marcin-fm/agentlab/releases/download/#{RELEASE_TAG}/#{OUTPUT_FILENAME}"
GCLIENT_ARGS = <<~GN.freeze
  build_with_chromium = false
  checkout_android = false
  checkout_skia = false
GN

SELECTED_SOURCES = [
